{%- liquid
	assign min    = 1
	assign max    = 6
	assign diff   = max | minus: min
	assign random = 'now' | date: '%N' | modulo: diff | plus: min

	if index > 6
		assign index = random
	endif
-%}

<div class="product-card text-left">
	<div class="product-media-wrap square-media card-item" tabindex="-1">
		{{- 'product-' | append: index | placeholder_svg_tag: 'placeholder-svg' -}}

		<div class="form-add-to-cart">
			<button type="button" class="add-to-cart-button" disabled>{{- 'products.product.sold_out' | t -}}</button>
		</div>
	</div>

	<div class="product-card-content text-{{ settings.card_alignment }}">
		<h2 class="product-title card-item h6">
			<span>{{- 'onboarding.products.title' | t -}}</span>
		</h2>

		{% render 'price', product: false, price_class: 'card-item' %}
	</div>
</div>
