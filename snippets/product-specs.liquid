{%- assign features = product.metafields.custom.chemical_properties.value -%}
  
{%- if features != blank -%}
  <div class="product-specs-table trupesh">
    {%- for item in features -%}
      {%- assign colon_index = item | split: ':' -%}
      {%- assign label = colon_index[0] -%}
      {%- assign label_with_colon = label | append: ':' -%}
      {%- assign value = item | remove_first: label_with_colon -%}

      {%- if label != blank and value != blank -%}
        <div class="spec-row">
          <span class="spec-label">{{ label }}</span>
          <span class="spec-value">{{ value }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}

<style>
  .product-specs-table {
    width: 100%;
    border-bottom: 1px solid #e5e7eb;
    margin-top: 8px;
    padding-bottom: 14px;
  }

  .spec-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 10px 0;
    gap: 16px;
  }

  .spec-label {
    font-size: 14px;
    color: #374151;
    flex-shrink: 0;
    min-width: 140px;
  }

  .spec-value {
    font-size: 14px;
    color: #111827;
    text-align: right;
  }

  @media (max-width: 768px) {
    .spec-label {
      min-width: 110px;
      font-size: 13px;
    }
    .spec-value {
      font-size: 13px;
    }
  }
</style>
