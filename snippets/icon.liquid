{%- comment -%}
	Renders a theme svg icons

	Accepts:
	- code: {String} Code of svg icon
	- color: {String} Color code value (optional)

	Usage:
		{% render 'icon', code: 'heart', color: color %}
{%- endcomment -%}

{%- liquid
	assign tabchar = 'CQ==' | base64_decode

	unless color
		assign color = 'currentColor'
	endunless
-%}

{%- capture icon -%}
