{%- liquid
  assign animation = settings.section_animation
  assign product_form_id = 'product-form-' | append: section.id

  capture saved_number
    render 'saved-price', product: product
  endcapture

  unless routes.account_login_url == '/account/login'
    assign new_customer_account = ' new-customer-accounts'
  endunless
-%}

<div class="product-summary{% if class != blank %} {{ class }}{% endif %}">
  <div
    class="product-summary-inner text-{{ section.settings.alignment }}"
    data-url="{{ shop.url | append: product.url }}"
    data-selected-id="{{ product.selected_or_first_available_variant.id }}"
  >
    <div class="sr-only">
      {%- liquid
        if product.featured_media
          echo product.featured_media | image_url: width: 1066 | image_tag: loading: 'lazy', class: 'product-image'
        else
          echo 'image' | placeholder_svg_tag: 'placeholder-svg product-image'
        endif
      -%}
    </div>

    {%- for block in section.blocks -%}
      {%- liquid
        assign current_variant = product.selected_or_first_available_variant
        assign font_size = block.settings.font_size

        capture tags_handle
          echo product.tags | join: ', '
        endcapture

        if block.type == 'floated-product-form'
          continue
        endif
      -%}

      <div
        class="summary-item {{ block.type }}{% if saved_number == blank and block.type == 'sale-label' %} hidden{% endif %}"
        data-{{ block.id }}
        {{ block.shopify_attributes }}
      >
        {%- case block.type -%}
          {%- when '@app' -%}
            <div class="product-block">
              {%- render block -%}
            </div>
          {%- when 'text' -%}
            {%- if block.settings.text != blank -%}
              <div class="product-text rte">
                {{- block.settings.text -}}
              </div>
            {%- endif -%}

          {%- when 'short_description' -%}
            {%- if product.description != blank -%}
              <div class="product-description rte">
                <p class="short-content" style="display: block;">
                  {%- if product.metafields.custom.short_description != blank -%}
                    {{- product.metafields.custom.short_description | strip_html | truncate: 150 -}}
                  {%- else -%}
                    {{- block.settings.short_description | strip_html | truncate: 150 -}}
                  {%- endif -%}
                </p>
                <p class="full-content" style="display: none;">
                  {%- if product.metafields.custom.short_description != blank -%}
                    {{- product.metafields.custom.short_description -}}
                  {%- else -%}
                    {{- block.settings.short_description -}}
                  {%- endif -%}
                </p>

                <span class="read-more-btn">{{- 'products.product.read_more' | t -}}</span>
              </div>
            {%- endif -%}
          {%- when 'title' -%}
            <h1 class="product-title {{ font_size }} rte">
              {{- product.title | escape -}}
            </h1>
          {%- when 'price' -%}
            <div class="product-price-wrapper {{ font_size }} text-body">
              {%- render 'price', product: product, use_variant: true -%}

              {%- form 'product', product, id: 'product-form-installment', class: 'installment' -%}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                {{ form | payment_terms }}
              {%- endform -%}

              {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
                <div class="tax-note">
                  {%- liquid
                    if cart.taxes_included
                      echo 'products.product.include_taxes' | t
                    endif

                    if shop.shipping_policy.body != blank
                      echo 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url
                    endif
                  -%}
                </div>
              {%- endif -%}
            </div>
          {%- when 'availability' -%}
            {%- liquid
              capture icon_tick
                echo '<span class="availability-icon icon-tick">'
                render 'icon', code: 'tick-status'
                echo '</span>'
              endcapture

              capture icon_close
                echo '<span class="availability-icon icon-close">'
                render 'icon', code: 'close'
                echo '</span>'
              endcapture
            -%}

            <div class="product-availability">
              {%- if product.available -%}
                {%- liquid
                  assign should_calculate_inventory = true

                  for variant in product.variants
                    if variant.inventory_policy == 'continue' or variant.inventory_management == null
                      assign should_calculate_inventory = false
                      break
                    endif
                  endfor
                -%}

                {%- if should_calculate_inventory and block.settings.low_stock > 0 -%}
                  {%- liquid
                    assign all_inventory = 0

                    for variant in product.variants
                      if variant.inventory_management
                        assign all_inventory = variant.inventory_quantity | at_least: 0 | plus: all_inventory
                      endif
                    endfor
                  -%}

                  {%- if all_inventory <= block.settings.low_stock -%}
                    <span class="product-stock-status inventory--low">
                      {{- icon_close -}}
                      {{- 'products.product.low_stock_with_quantity_count' | t: count: all_inventory -}}
                    </span>
                  {%- else -%}
                    <span class="product-stock-status inventory--high">
                      {{- icon_tick -}}
                      {{- 'products.product.in_stock_with_quantity_count' | t: count: all_inventory -}}
                    </span>
                  {%- endif -%}
                {%- else -%}
                  {%- if product.variants.first.inventory_policy == 'continue'
                    and product.variants.first.inventory_quantity <= 0
                    and product.variants.first.requires_shipping
                  -%}
                    <span class="product-stock-status inventory--high">
                      {{- icon_tick -}}
                      {{- 'products.product.oversell_stock' | t -}}
                    </span>
                  {%- else -%}
                    <span class="product-stock-status inventory--high">
                      {{- icon_tick -}}
                      {{- 'products.product.in_stock' | t -}}
                    </span>
                  {%- endif -%}
                {%- endif -%}
              {%- else -%}
                <span class="product-stock-status inventory--low">
                  {{- icon_close -}}
                  {{- 'products.product.out_of_stock' | t -}}
                </span>
              {%- endif -%}
            </div>
          {%- when 'divider' -%}
            <div class="product-divider"></div>
          {%- when 'information' -%}
            <div class="product-information rte">
              {%- if block.settings.vendor -%}
                <div class="info-item product-vendor">
                  <span class="info-name">{{- 'products.product.information.vendor' | t -}}</span>

                  {{- product.vendor | link_to_vendor: class: 'product-vendor-link link-underline-transparent' -}}
                </div>
              {%- endif -%}

              {%- if block.settings.collections and product.collections.first -%}
                <div class="info-item product-collections">
                  <span class="info-name">
                    {{- 'products.product.information.collections' | t -}}
                    :</span
                  >

                  {%- for cat in product.collections -%}
                    <a
                      href="{{ cat.url }}"
                      class="link-underline-transparent"
                      aria-label="{{- 'general.text.link' | t -}}"
                    >
                      {{- cat.title -}}
                    </a>
                    {%- unless forloop.last %}, {% endunless %}
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- if block.settings.tags and tags_handle != blank -%}
                <div class="info-item product-tags">
                  <span class="info-name">
                    {{- 'products.product.information.tags' | t -}}
                    :</span
                  >

                  {{- tags_handle -}}
                </div>
              {%- endif -%}

              {%- if block.settings.type and product.type != blank -%}
                <div class="info-item product-type">
                  <span class="info-name">
                    {{- 'products.product.information.type' | t -}}
                    :</span
                  >

                  {{- product.type -}}
                </div>
              {%- endif -%}

              {%- if block.settings.sku and current_variant.sku != blank -%}
                <div class="info-item product-sku">
                  <span class="info-name">
                    {{- 'products.product.information.sku' | t -}}
                    :</span
                  >

                  {{- current_variant.sku -}}
                </div>
              {%- endif -%}

              {%- if block.settings.barcode and current_variant.barcode != blank -%}
                <div class="info-item product-barcode">
                  <span class="info-name">
                    {{- 'products.product.information.barcode' | t -}}
                    :</span
                  >

                  {{- current_variant.barcode -}}
                </div>
              {%- endif -%}
            </div>
          {%- when 'custom-liquid' -%}
            <div class="product-custom-liquid">
              {{- block.settings['custom-liquid'] -}}
            </div>
          {%- when 'collapsible-tab' -%}
            <details class="product-accordion">
              <summary class="accordion-summary" aria-expanded="false">
                {%- liquid
                  if block.settings.icon != 'none'
                    render 'icon-accordion', icon: block.settings.icon
                  endif
                -%}

                <div class="accordion-title rte {{ block.settings.font_size}}">
                  {%- liquid
                    echo block.settings.heading | default: block.settings.page.title
                  -%}
                </div>

                <span class="accordion-caret">
                  <span class="plus">{%- render 'icon', code: 'plus' -%}</span>
                  <span class="minus">{%- render 'icon', code: 'minus' -%}</span>
                </span>
              </summary>

              <div class="accordion-content details-content rte">
                {%- liquid
                  echo block.settings.content
                  echo block.settings.page.content
                -%}
              </div>
            </details>
          {%- when 'popup' -%}
            <div class="product-popup">
              <button class="popup-toggle link-underline-transparent" type="button" aria-haspopup="dialog">
                {%- liquid
                  render 'icon', code: 'info'
                  echo block.settings.text | default: block.settings.page.title
                -%}
              </button>

              {%- if block.settings.page != blank -%}
                <div class="popup-view">
                  <div class="popup-inner">
                    <button
                      type="button"
                      class="popup-close primary-button"
                      aria-label="{{- 'accessibility.close' | t -}}"
                    >
                      {%- render 'icon', code: 'close-thin' -%}
                    </button>

                    <div class="popup-content">
                      <h2 class="popup-heading text-center">{{- block.settings.page.title -}}</h2>

                      {{ block.settings.page.content }}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- when 'share' -%}
            <div class="product-share" data-{{ block.settings.type }}>
              {%- if block.settings.type == 'os' -%}
                <button class="share-button link-underline hidden">
                  {%- liquid
                    render 'icon', code: 'share'
                    echo block.settings.share_label | escape
                  -%}
                </button>

                <details>
                  <summary class="share-button link-underline hidden">
                    {%- liquid
                      render 'icon', code: 'share'
                      echo block.settings.share_label | escape
                    -%}
                  </summary>

                  <div class="share-content">
                    <div class="share-field">
                      <span class="share-message hidden" role="status"></span>

                      <input
                        type="text"
                        class="field-input"
                        id="share-url-{{ section.id }}"
                        value="{{ shop.url | append: product.url }}{% unless product.has_only_default_variant %}?variant={{ product.selected_or_first_available_variant.id }}{% endunless %}"
                        placeholder="{{ 'general.share.share_url' | t }}"
                        onclick="this.select();"
                        readonly
                      >
                      <label class="field-label" for="share-url-{{ section.id }}">
                        {{- 'general.share.share_url' | t -}}
                      </label>
                    </div>

                    <span class="share-button-close hidden">
                      {% render 'icon', code: 'close-thin' %}
                      <span class="sr-only">{{ 'general.share.close' | t }}</span>
                    </span>

                    <span class="share-button-copy">
                      {% render 'icon', code: 'clipboard' %}
                      <span class="sr-only">{{ 'general.share.copy_to_clipboard' | t }}</span>
                    </span>
                  </div>
                </details>
              {%- else -%}
                {%- assign product_url = shop.url | append: product.url -%}
                <span class="share-label">{{ block.settings.share_label | escape }} :</span>

                <ul class="social-media-list" role="list">
                  <li>
                    <a
                      href="//facebook.com/sharer/sharer.php?u={{ product_url }}"
                      class="icon"
                      target="_blank"
                      rel="noopener"
                      aria-label="{{ 'general.social.links.facebook' | t }}"
                    >
                      {%- render 'icon', code: 'facebook' -%}
                      <span class="tooltip tooltip-top">{{- 'general.social.links.facebook' | t -}}</span>
                    </a>
                  </li>

                  <li>
                    <a
                      href="//twitter.com/intent/tweet?text={{ product.title }}"
                      class="icon"
                      target="_blank"
                      rel="noopener"
                      aria-label="{{ 'general.social.links.twitter' | t }}"
                    >
                      {%- render 'icon', code: 'twitter' -%}
                      <span class="tooltip tooltip-top">{{- 'general.social.links.twitter' | t -}}</span>
                    </a>
                  </li>

                  <li>
                    <a
                      href="//pinterest.com/pin/create/button/?url={{ product_url }}&media={{ product.featured_media | image_url: width: 1024 }}&description={{ product.description | strip_html }}"
                      class="icon"
                      target="_blank"
                      rel="noopener"
                      aria-label="{{ 'general.social.links.pinterest' | t }}"
                    >
                      {%- render 'icon', code: 'pinterest' -%}
                      <span class="tooltip tooltip-top">{{- 'general.social.links.pinterest' | t -}}</span>
                    </a>
                  </li>

                  <li>
                    <a
                      href="mailto:info@example.com?&subject=&cc=&bcc=&body={{ product_url }}%0A{{ product.title }}"
                      class="icon"
                      target="_blank"
                      rel="noopener"
                      aria-label="{{ 'general.social.links.email' | t }}"
                    >
                      {%- render 'icon', code: 'link-icon-sumary' -%}
                      <span class="tooltip tooltip-top">{{- 'general.social.links.email' | t -}}</span>
                    </a>
                  </li>
                </ul>
              {%- endif -%}
            </div>
          {%- when 'variant-picker' -%}
            {%- unless product.has_only_default_variant -%}
              <div
                class="product-variants variant-{{ block.settings.picker_type }} swatches-{{ settings.swatch_style }}"
                data-url="{{ product.url }}"
              >
                {%- for option in product.options_with_values -%}
                  {%- liquid
                    assign selected_value = option.selected_value
                    assign id = 'option-' | append: section.id | append: '-' | append: forloop.index
                  -%}

                  <div class="variant-field">
                    {%- if block.settings.picker_type == 'swatch' -%}
                      <div class="field-title">
                        {{- option.name -}}
                        :
                        <span class="selected-value">{{- selected_value -}}</span>
                      </div>

                      <div class="field-wrap">
                        <div class="field-wrap-inner">
                          {%- for value in option.values -%}
                            <input
                              type="radio"
                              id="{{ id | append: forloop.index }}"
                              name="{{ option.name | escape }}"
                              value="{{ value | escape }}"
                              form="{{ product_form_id }}"
                              class="field-value sr-only"
                              {% if selected_value == value %}
                                checked
                              {% endif %}
                            >
                            {%- liquid
                              if value.swatch.image
                                assign image_url = value.swatch.image | image_url: width: 100
                                assign swatch_value = 'url(' | append: image_url | append: ')'
                                assign swatch_focal_point = value.swatch.image.presentation.focal_point
                                assign swatch_type = 'image'
                              elsif value.swatch.color
                                assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                                assign contrast = swatch_value | color_contrast: '#ffffff'
                                assign swatch_type = 'color'
                              else
                                assign swatch_value = null
                                assign swatch_type = 'button'
                              endif
                            -%}

                            <label
                              class="field-label {% if swatch_type == 'button' %}field-button{% else %}swatch swatch-{{ swatch_type }}{% endif %}{% if swatch_type == 'color' and contrast < 4.5 %} dark{% endif %}"
                              for="{{ id | append: forloop.index }}"
                              {% if swatch_value %}
                                style="--swatch--background: {{ swatch_value }};{% if swatch_focal_point %}--swatch-focal-point: {{ swatch_focal_point }};{% endif %}"
                              {% endif %}
                            >
                              <span class="{% if swatch_value %}sr-only{% else %}swatch-text{% endif %}">
                                {{- value -}}
                              </span>
                            </label>
                          {%- endfor -%}
                        </div>
                      </div>
                    {%- else -%}
                      <div class="field-title">
                        {{- option.name -}}
                        :
                        <span class="selected-value">{{- selected_value -}}</span>
                      </div>

                      <div class="field-wrap">
                        <select
                          class="field-value"
                          name="[{{ option.name | escape }}]"
                          form="{{ product_form_id }}"
                          data-noui
                        >
                          {%- for value in option.values -%}
                            <option
                              value="{{ value | escape }}"
                              {% if selected_value == value %}
                                selected="selected"
                              {% endif %}
                            >
                              {{- value -}}
                            </option>
                          {%- endfor -%}
                        </select>
                      </div>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>

              {% comment %} Product variant data {% endcomment %}
              <script data-product-variants>
                {
                  {
                    product.variants | json;
                  }
                }
              </script>

              {% comment %} Product quantity data {% endcomment %}
              <script data-inventory-quantity>
                [{%- liquid
                	for var in product.variants
                		echo '{"id":' | append: var.id | append: ',"qty":' | append: var.inventory_quantity | append: '}'

                		unless forloop.last
                			echo ','
                		endunless
                	endfor
                -%}]
              </script>
            {%- endunless -%}
          {%- when 'add-to-cart' -%}
            {%- liquid
              assign form_class = 'product-buy'

              if product.selected_or_first_available_variant.available == false
                assign form_class = 'product-buy disabled'
              endif
            -%}

            {%- if block.settings.show_gift_card and product.gift_card? -%}
              <div class="product-warnings error-messages message"></div>
            {% else %}
              <div class="product-warning error-messages message"></div>
            {% endif %}

            {%- if product.requires_selling_plan -%}
              <div class="selling-plan-message error-messages message hidden"></div>
            {%- endif -%}

            {%- form 'product',
              product,
              id: product_form_id,
              class: form_class,
              novalidate: 'novalidate',
              data-type: 'add-to-cart-form'
            -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

              {%- liquid
                if block.settings.show_gift_card and product.gift_card?
                  render 'gift-card-recipient-form', product: product, form: form, section: section
                endif
              -%}

              <noscript>
                <div class="no-js-select-variants{% if product.has_only_default_variant %} hidden{% endif %}">
                  <label for="no-js-option-{{ section.id }}">
                    {{- 'products.product.product_variants' | t -}}
                    :</label
                  >

                  <select name="id" id="no-js-option-{{ section.id }}" form="{{ product_form_id }}" data-noui>
                    {%- for variant in product.variants -%}
                      <option
                        value="{{ variant.id }}"
                        {% if variant == product.selected_or_first_available_variant %}
                          selected="selected"
                        {% endif %}
                        {% if variant.available == false %}
                          disabled
                        {% endif %}
                      >
                        {{- variant.title }}
                        {%- if variant.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}
                        - {{ variant.price | money | strip_html -}}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              </noscript>

              <div class="item-field">
                {%- if block.settings.quantity_selector -%}
                  <span class="field-title sr-only">
                    {{- 'products.product.quantity.label' | t -}}
                  </span>

                  <div class="product-quantity">
                    {%- render 'quantity', product: product -%}
                  </div>
                {%- endif -%}

                {% if customer %}
                  <button
                    type="submit"
                    name="add"
                    class="button add-to-cart-button primary-button{% if block.settings.text_transform != 'none' %} text-{{ block.settings.text_transform }}{% endif %}{% if product.requires_selling_plan and current_variant.selling_plan_allocations.size == 0 %} selling-plan-error{% endif %} {% if block.settings.show_price %} has-price {% else %} no-price{% endif %}"
                    style="border-radius: 12px;"
                  >
                    {%- liquid
                      if product.selected_or_first_available_variant.available
                        echo 'products.product.add_to_cart' | t
                      else
                        echo 'products.product.out_of_stock' | t
                      endif
                    -%}
                    {% if block.settings.show_price %}
                      <span> - </span>
                      {%- render 'price', product: product, use_variant: true -%}
                    {% endif %}
                  </button>
                {% else %}
                  <a
                    href="{{ routes.account_login_url }}"
                    class="button primary-button account-login-btn{{ new_customer_account }}"
                    style="padding-top: 16px; padding-bottom: 16px;"
                  >
                    Log in to Buy
                  </a>
                {% endif %}
              </div>

              {%- liquid
                if block.settings.dynamic_checkout
                  echo form | payment_button
                endif
              -%}
            {%- endform -%}
          {%- when 'image-with-link' -%}
            {%- liquid
              assign tag = 'div'

              if block.settings.url != blank
                assign tag = 'a'
              endif
            -%}

            <{{ tag }}
              class="custom-image"
              {% if block.settings.url != blank %}
                href="{{ block.settings.url | default: '#' }}"
              {% endif %}
            >
              {%- liquid
                if block.settings.image != blank and block.settings.image_width > 0
                  echo block.settings.image | image_url: width: block.settings.image_width | image_tag: loading: 'lazy'
                else
                  echo 'collection-1' | placeholder_svg_tag: 'placeholder-svg'
                endif
              -%}
            </{{ tag }}>
          {%- when 'icon-box' -%}
            <div class="product-icon-box">
              <div class="list-item">
                {%- for index in (1..3) -%}
                  {%- liquid
                    assign icon = 'icon_item_' | append: index
                    assign title = 'title_item_' | append: index
                    assign description = 'description_item_' | append: index
                  -%}

                  {%- if block.settings[icon] != blank
                    or block.settings[title] != blank
                    or block.settings[description] != blank
                  -%}
                    <div class="item vertical-{{ block.settings.vertical_align }}">
                      {%- if block.settings[icon] != blank -%}
                        <div class="item-icon{% if settings.image_lazy and block.settings[icon] %} lazy-image{% endif %}">
                          {%- render 'lazy-image', image: block.settings[icon], width: 100 -%}
                        </div>
                      {%- endif -%}

                      {%- if block.settings[description] != blank -%}
                        <div class="item-content">
                          <div class="item-description rte">
                            {{- block.settings[description] -}}
                          </div>
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>

          {%- when 'fetures' -%}
            {%- assign features = product.metafields.custom.fetures.value -%}
            {%- if features != blank -%}
              {%- render 'product-specs' -%}
            {%- endif -%}

          {%- when 'coa-button' -%}
            {%- render 'product-coa-button' -%}
            {% comment %} Description {% endcomment %}
          {%- when 'description' -%}
            {%- if product.description != blank -%}
              <div class="product-description rte" style="color: oklch(44.6% .03 256.802);">
                {{- product.description -}}
              </div>
            {%- endif -%}

            {% comment %} Complementary mobile {% endcomment %}
          {%- when 'complementary' -%}
            {%- liquid
              assign limit = block.settings.product_list_limit
            -%}

            <div
              class="complementary-products-container-mobile "
              data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ limit }}&intent=complementary"
            >
              {%- if recommendations.performed and recommendations.products_count > 0 -%}
                <div class="product-accordion" aria-label="{{ 'accessibility.complementary_products' | t }}">
                  <div class="heading-wrapper{% if animation %} scroll-trigger{% endif %}">
                    <div class="collection-heading">
                      <h2 class="collection-head h6 rte">
                        {{- block.settings.heading -}}
                      </h2>
                    </div>
                  </div>

                  <div class="complementary-content">
                    <div class="complementary-products ">
                      <div class="complementary-products-inner">
                        <unity-slider class="unity-slider" data-slider-id="slider-1">
                          <template data-options>
                            { "duration": 25, "_autoheight": true, "_fade": true, "_prevBtn": ".unity-button-prev",
                            "_nextBtn": ".unity-button-next" }
                          </template>

                          <div class="unity-slider-viewport">
                            <div class="unity-slider-container">
                              {%- for product in recommendations.products limit: limit -%}
                                <div class="unity-slide" data-id="{{ recommendations.products.id }}">
                                  {%- render 'product-card-complementary', product: product, index: forloop.index -%}
                                </div>
                              {%- else -%}
                                {%- for i in (1..4) -%}
                                  <div class="unity-slide">
                                    {%- render 'product-card-placeholder', index: forloop.index -%}
                                  </div>
                                {%- endfor -%}
                              {%- endfor -%}
                            </div>
                          </div>
                          <div class="control-banner-product-slider arrow-small">
                            <div class="unity-arrows" data-slider-id="slider-1">
                              <button
                                class="unity-button complementary-content unity-button-prev"
                                title="{{ 'general.unity.prev' | t }}-smr"
                                aria-label="{{ 'general.unity.prev' | t }}-smr"
                                id="{{ 'general.unity.prev' | t }}-smr"
                                aria-labelledby="{{ 'general.unity.prev' | t }}-smr"
                              >
                                {%- render 'icon', code: 'chevron-left' -%}
                              </button>

                              <button
                                class="unity-button complementary-content unity-button-next"
                                title="{{ 'general.unity.next' | t }}-smr"
                                aria-label="{{ 'general.unity.next' | t }}-smr"
                                id="{{ 'general.unity.next' | t }}-smr"
                                aria-labelledby="{{ 'general.unity.next' | t }}-smr"
                              >
                                {%- render 'icon', code: 'chevron-right' -%}
                              </button>
                            </div>
                          </div>
                        </unity-slider>
                      </div>
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>
</div>
