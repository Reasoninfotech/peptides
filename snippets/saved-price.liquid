{%- comment -%}
	Get saved price percent on selected product

	Accepts:
	- product: {Object} Product Liquid object

	Usage:
		{% render 'saved-price', product: product %}
{%- endcomment -%}

{%- liquid
	if product.available
		assign target = product.selected_or_first_available_variant

		if target.compare_at_price > target.price
			assign saved_price       = target.compare_at_price | minus: target.price | times: 100.0 | divided_by: target.compare_at_price
			assign saved_price_split = saved_price | split: '.'
			assign final_saved_price = saved_price | round

			if saved_price_split[1] == '0' or saved_price_split[1] == '00'
				assign final_saved_price = saved_price_split[0]
			endif

			echo final_saved_price
		endif
	endif
-%}