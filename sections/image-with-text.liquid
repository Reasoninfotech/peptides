{%- liquid
	assign section_id    = '#shopify-section-' | append: section.id
	assign animation     = settings.section_animation
	assign full          = section.settings.full
	assign layout        = section.settings.layout
	assign image         = section.settings.image
	assign heading       = section.settings.heading_text
	assign heading_size  = section.settings.heading_size
	assign description   = section.settings.text
	assign desktop_align = section.settings.desktop_align
	assign mobile_align  = section.settings.mobile_align
	assign caption       = section.settings.caption
	assign width         = section.settings.width
	assign height        = section.settings.height

	case width
		when 'small'
			assign width_value = '33'
		when 'medium'
			assign width_value = '50'
		when 'large'
			assign width_value = '66'
	endcase

	case height
		when 'small'
			assign height_value = '400px'
		when 'medium'
			assign height_value = '580px'
		when 'large'
			assign height_value = '760px'
	endcase
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	@media (min-width: 992px) {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}

		{{ section_id }} .image {
			width: {{ width_value }}%;
			height: {{ height_value }};
		}

		{{ section_id }} .{{ width }}-width {
			width: {{ 100 | minus: width_value }}%;
		}

		{{ section_id }} .{{ height }}-heigth {
			width: {{ height_value }};
		}
	}
</style>

<div class="section-wrapper color-{{ section.settings.color_scheme }}">
	<div class="{% if full %}stretch-section stretch-padding{% else %}container{% endif %}">
		<div class="image-with-text border-large {{ layout }}-first color-{{ section.settings.content_color_scheme }}">
			<div class="image adapt-media{% if animation %} scroll-trigger{% endif %}">
				<div class="{% if image == blank %}adapt-svg-placeholder{% endif %}{% if settings.image_lazy and image %} lazy-image{% endif %}">
					{%- liquid
						if image != blank
							render 'lazy-image', image: image, width: 1200, class: 'border-large'
						else
							render 'icon', code: 'placeholder'
						endif
					-%}
				</div>
			</div>

			<div class="content {{ width }}-width {{ height }}-height">
				<div class="content-inner-wrapper flex-align-{{ section.settings.desktop_position }}">
					<div class="content-inner text-{{ desktop_align }} text-{{ mobile_align }}-mobile rte">
						{%- if caption != blank -%}
							<div class="sub-heading rte{% if animation %} scroll-trigger{% endif %}">{{- caption -}}</div>
						{%- endif -%}

						{%- if heading != blank -%}
							<h2 class="heading {{ heading_size }} rte{% if animation %} scroll-trigger{% endif %}">{{- heading -}}</h2>
						{%- endif -%}

						{%- if description != blank -%}
							<div class="description{% if animation %} scroll-trigger{% endif %}">{{- description -}}</div>
						{%- endif -%}

						{%- if section.settings.button_label != blank -%}
							<div class="button-wrapper">
								<a class="button primary-button{% if animation %} scroll-trigger{% endif %}" href="{{ section.settings.button_link | default: '#' }}" aria-label="{{- 'general.text.link' | t -}}">
									{{- section.settings.button_label -}}
								</a>
							</div>
						{%- endif -%}
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.image-with-text.name",
	"tag": "section",
	"class": "image-with-text-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "checkbox",
			"id": "full",
			"default": false,
			"label": "t:general.layout.full.label"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "t:general.image.label"
		},
		{
			"type": "select",
			"id": "layout",
			"options": [
				{
					"value": "image",
					"label": "t:sections.image-with-text.settings.layout.option_1.label"
				},
				{
					"value": "text",
					"label": "t:sections.image-with-text.settings.layout.option_2.label"
				}
			],
			"default": "image",
			"label": "t:sections.image-with-text.settings.layout.label",
			"info": "t:sections.image-with-text.settings.layout.info"
		},
		{
			"type": "select",
			"id": "height",
			"options": [
				{
					"value": "adapt",
					"label": "t:general.image.height.option_1.label"
				},
				{
					"value": "small",
					"label": "t:general.image.height.option_2.label"
				},
				{
					"value": "medium",
					"label": "t:general.image.height.option_3.label"
				},
				{
					"value": "large",
					"label": "t:general.image.height.option_4.label"
				}
			],
			"default": "medium",
			"label": "t:general.image.height.label"
		},
		{
			"type": "select",
			"id": "width",
			"options": [
				{
					"value": "small",
					"label": "t:general.image.desktop_image_width.option_1.label"
				},
				{
					"value": "medium",
					"label": "t:general.image.desktop_image_width.option_2.label"
				},
				{
					"value": "large",
					"label": "t:general.image.desktop_image_width.option_3.label"
				}
			],
			"default": "medium",
			"label": "t:general.image.desktop_image_width.label",
			"info": "t:general.image.desktop_image_width.info"
		},
		{
			"type": "header",
			"content": "t:sections.image-with-text.settings.header_content.content"
		},
		{
			"type": "color_scheme",
			"id": "content_color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "select",
			"id": "desktop_position",
			"options": [
				{
					"value": "start",
					"label": "t:general.layout.desktop_position.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.desktop_position.option_2.label"
				},
				{
					"value": "end",
					"label": "t:general.layout.desktop_position.option_3.label"
				}
			],
			"default": "center",
			"label": "t:general.layout.desktop_position.label"
		},
		{
			"type": "select",
			"id": "desktop_align",
			"options": [
				{
					"value": "left",
					"label": "t:general.layout.desktop_alignment.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.desktop_alignment.option_2.label"
				},
				{
					"value": "right",
					"label": "t:general.layout.desktop_alignment.option_3.label"
				}
			],
			"default": "left",
			"label": "t:general.layout.desktop_alignment.label"
		},
		{
			"type": "header",
			"content": "t:sections.image-with-text.settings.mobile_layout.content"
		},
		{
			"type": "select",
			"id": "mobile_align",
			"options": [
				{
					"value": "left",
					"label": "t:general.layout.mobile_alignment.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.mobile_alignment.option_2.label"
				},
				{
					"value": "right",
					"label": "t:general.layout.mobile_alignment.option_3.label"
				}
			],
			"default": "left",
			"label": "t:general.layout.mobile_alignment.label"
		},
		{
			"type": "text",
			"id": "caption",
			"label": "t:general.typography.caption.label"
		},
		{
			"type": "inline_richtext",
			"id": "heading_text",
			"default": "Image with text",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h3",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h2",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h3",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "richtext",
			"id": "text",
			"default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
			"label": "t:general.typography.description.label"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "Button label",
			"label": "t:general.typography.button_label.label"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:general.typography.link.label"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.image-with-text.presets.name"
		}
	]
}
{% endschema %}
