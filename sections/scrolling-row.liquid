{%- liquid
	assign section_id        = '#shopify-section-' | append: section.id
	assign animation         = settings.section_animation
	assign scale_heading     = section.settings.scale_heading | divided_by: 100.0
	assign desktop_alignment = section.settings.desktop_alignment
	assign mobile_layout     = section.settings.mobile_layout
	assign caption           = section.settings.caption
	assign heading           = section.settings.heading_text
	assign heading_size      = section.settings.heading_size
	assign button_label      = section.settings.button_label

	if section.settings.image_layout contains 'right'
		assign odd_class = ' row-reverse'
	else
		assign even_class = ' row-reverse'
	endif
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	{{ section_id }} .content-location .heading{
		--heading-scale: {{ scale_heading }};
	}

	@media (min-width: 992px) {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
</style>

<scrolling-row>
	<section class="section-wrapper color-{{ section.settings.color_scheme }} full-services">
		<div class="stretch-section full-services__wrapper">
			{%- if caption != blank or heading != blank or button_label != blank -%}
				<div class="scroll-top container{% if animation %} scroll-trigger{% endif %}">
					{%- if caption != blank or heading != blank -%}
						<div class="scroll-top-left">
							{%- if caption != blank -%}
									<div class="caption sub-heading rte">{{- caption -}}</div>
								{%- endif -%}

							{%- if heading != blank -%}
								<div class="title-wrapper text-left">
									<h2 class="headings {{ heading_size }} rte">{{- heading -}}</h2>
								</div>
							{%- endif -%}
						</div>
					{%- endif -%}

					{%- if button_label != blank -%}
						<a class="button primary-button" href="{{ section.settings.button_link | default: '#' }}" aria-label="{{- 'general.text.link' | t -}}">
							{{- button_label -}}
						</a>
					{%- endif -%}
				</div>
			{% endif %}

			<div class="full-services__list multirow-wrapper{% if animation %} scroll-trigger{% endif %} {{ mobile_layout }}">
				{%- liquid
					assign top        = 0
				-%}

				{%- for block in section.blocks -%}
					<div class="full-services__item row-item" style="--offset-top: {{ top }}px;" data-{{ block.id }} {{ block.shopify_attributes }}>
						{%- case block.type -%}
							{%- when '@app' -%}
								{%- render block -%}

							{%- when 'row' -%}
								{%- liquid
									assign image         = block.settings.image
									assign heading       = block.settings.heading
									assign map           = block.settings.image_map
									assign content_left  = block.settings.content_left
									assign content_right = block.settings.content_right
								-%}

								<div class="image-item">
									<div class="image {% if image == blank %} adapt-svg-placeholder{% endif %}{% if settings.image_lazy and image %} lazy-image{% endif %}">
										{%- liquid
											if image != blank
												render 'lazy-image', image: image, width: 664
											else
												render 'icon', code: 'placeholder'
											endif
										-%}
									</div>
								</div>

								<div class="container content-location border-large{% if section.settings.image_layout contains 'alternate' %}{% cycle odd_class, even_class %}{% else %}{{ odd_class }}{% endif %}">
									{%- if heading != blank -%}
										<div class="heading h1 rte">{{- heading -}}</div>
									{%- endif -%}

									{%- if content_left != blank or content_right != blank -%}
										<div class="content-wrapper flex-justify-top">
											<div class="content flex-align-{% if desktop_alignment == 'left' %}start{% elsif desktop_alignment == 'right' %}end{% else %}center{% endif %}">
												<div class="content-inner text-{{ section.settings.desktop_alignment }} text-left-mobile">
													<div class="map{% if map == blank %} adapt-svg-placeholder{% endif %}{% if settings.image_lazy and map %} lazy-image{% endif %}">
														{%- liquid
															if map != blank
																render 'lazy-image', image: map, width: 518, class: 'border-large'
															else
																render 'icon', code: 'placeholder'
															endif
														-%}
													</div>
													<div class="infor">
														<div class="left-content">
															{%- if content_left != blank -%}
																{{ content_left | replace: '[', '<span class="address">' | replace: ']', '</span>' }}
															{%- endif -%}
														</div>

														<div class="right-content">
															{%- if content_right != blank -%}
																{{ content_right | replace: '[', '<span class="address">' | replace: ']', '</span>' }}
															{%- endif -%}
														</div>
													</div>
												</div>
											</div>
										</div>
									{%- endif -%}
								</div>
						{%- endcase -%}
					</div>
				{%- endfor -%}
			</div>
		</div>
	</section>
</scrolling-row>

{% schema %}
{
	"name": "t:sections.scrolling_row.name",
	"tag": "section",
	"class": "scrolling-row-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "t:general.typography.text.label"
		},
		{
			"type": "text",
			"id": "caption",
			"default": "Caption",
			"label": "t:general.typography.caption.label"
		},
		{
			"type": "inline_richtext",
			"id": "heading_text",
			"default": "Heading",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h3",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h2",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h3",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "Button label",
			"label": "t:general.typography.button_label.label"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:general.typography.link.label"
		},
		{
			"type": "range",
			"id": "scale_heading",
			"min": 50,
			"max": 400,
			"step": 5,
			"default": 200,
			"unit": "%",
			"label": "t:sections.scrolling_row.settings.scale_heading.name"
		},
		{
			"type": "select",
			"id": "image_layout",
			"options": [
				{
					"value": "alternate-left",
					"label": "t:sections.multirow.settings.image_layout.options__1.label"
				},
				{
					"value": "alternate-right",
					"label": "t:sections.multirow.settings.image_layout.options__2.label"
				},
				{
					"value": "align-left",
					"label": "t:sections.multirow.settings.image_layout.options__3.label"
				},
				{
					"value": "align-right",
					"label": "t:sections.multirow.settings.image_layout.options__4.label"
				}
			],
			"default": "alternate-left",
			"label": "t:sections.multirow.settings.image_layout.label",
			"info": "t:sections.multirow.settings.image_layout.info"
		},
		{
			"type": "select",
			"id": "desktop_alignment",
			"options": [
				{
					"value": "left",
					"label": "t:general.layout.desktop_alignment.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.desktop_alignment.option_2.label"
				},
				{
					"value": "right",
					"label": "t:general.layout.desktop_alignment.option_3.label"
				}
			],
			"default": "left",
			"label": "t:general.layout.desktop_alignment.label",
			"info": "t:general.layout.horizontal.mobile_left.label"
		},
		{
			"type": "select",
			"id": "mobile_layout",
			"options": [
				{
					"value": "list",
					"label": "t:sections.scrolling_row.settings.mobile_layout.options__1.label"
				},
				{
					"value": "scroll",
					"label": "t:sections.scrolling_row.settings.mobile_layout.options__2.label"
				}
			],
			"default": "list",
			"label": "t:sections.scrolling_row.settings.mobile_layout.label"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"blocks": [
		{
			"type": "@app"
		},
		{
			"type": "row",
			"name": "t:sections.multirow.settings.row.name",
			"settings": [
				{
					"type": "image_picker",
					"id": "image",
					"label": "t:general.background.image.label"
				},
				{
					"type": "inline_richtext",
					"id": "heading",
					"default": "Row",
					"label": "t:general.typography.heading.label"
				},
				{
					"type": "image_picker",
					"id": "image_map",
					"label": "t:sections.scrolling_row.blocks.image.name"
				},
				{
					"type": "richtext",
					"id": "content_left",
					"default": "<p>Content left</p>",
					"label": "t:sections.scrolling_row.blocks.content_left.name"
				},
				{
					"type": "richtext",
					"id": "content_right",
					"default": "<p>Content right</p>",
					"label": "t:sections.scrolling_row.blocks.content_left.name"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.scrolling_row.name",
			"blocks": [
				{
					"type": "row"
				},
				{
					"type": "row"
				},
				{
					"type": "row"
				},
				{
					"type": "row"
				}
			]
		}
	]
}
{% endschema %}
