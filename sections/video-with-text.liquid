{%- liquid
	assign section_id    = '#shopify-section-' | append: section.id
	assign animation     = settings.section_animation
	assign full          = section.settings.full
	assign layout        = section.settings.layout
	assign caption       = section.settings.caption
	assign heading       = section.settings.heading_text
	assign heading_size  = section.settings.heading_size
	assign description   = section.settings.text
	assign desktop_align = section.settings.desktop_align
	assign mobile_align  = section.settings.mobile_align
	assign height        = section.settings.height
	assign button_label  = section.settings.button_label

	case height
		when 'small'
			assign height_value = '453px'
		when 'medium'
			assign height_value = '580px'
		when 'large'
			assign height_value = '700px'
	endcase
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	{{ section_id }} .video-item.height-{{ height }} {
		height: {{ height_value }};
	}

	@media (min-width: 992px) {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
</style>

<div class="section-wrapper color-{{ section.settings.color_scheme }}">
	<div class="{% if full %}stretch-section stretch-padding{% else %}container{% endif %}">
		<div class="video-with-text border-large {{ layout }}-first color-{{ section.settings.content_color_scheme }}">
			<div class="video-item border-large height-{{ height }}{% if animation %} scroll-trigger{% endif %}">
				{%- if section.settings.source == 'host' -%}
					{% if section.settings.url.type == 'youtube' %}
						<iframe class="js-youtube" data-src="//youtube.com/embed/{{ section.settings.url.id }}?controls=1&mute=0&showinfo=0&rel=0&autoplay=1&loop=1&playlist={{ section.settings.url.id }}" frameborder="0" allowfullscreen></iframe>
					{% elsif section.settings.url.type == 'vimeo' %}
						<iframe class="js-vimeo" data-src="//player.vimeo.com/video/{{ section.settings.url.id }}?autoplay=1&loop=1" frameborder="0"></iframe>
					{% endif %}
				{%- elsif section.settings.native_url != blank -%}
					{{ section.settings.native_url | video_tag: image_size: '1920x', loop: true, muted: false, controls: true, autoplay: false, preload: 'none' }}
				{%- endif -%}

				<div class="video-image-wrapper border-large">
					{%- liquid
						if section.settings.image
							echo section.settings.image | image_url: width: 2100 | image_tag: width: 1920, loading: 'lazy'
						else
							echo 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg'
						endif
					-%}
				</div>

				<button type="button" class="play-video" aria-label="{{  }}'general.text.link' | t -}}">{% render 'icon', code: 'play' %}</button>
			</div>

			{%- if caption != blank or heading != blank or description != blank or button_label != blank -%}
				<div class="content">
					<div class="content-inner-wrapper">
						<div class="content-inner text-{{ desktop_align }} text-{{ mobile_align }}-mobile rte">
							{%- if caption != blank -%}
								<div class="sub-heading rte{% if animation %} scroll-trigger{% endif %}">{{- caption -}}</div>
							{%- endif -%}

							{%- if heading != blank -%}
								<h2 class="heading {{ heading_size }} rte{% if animation %} scroll-trigger{% endif %}">{{- heading -}}</h2>
							{%- endif -%}

							{%- if description != blank -%}
								<div class="description{% if animation %} scroll-trigger{% endif %}">{{- description -}}</div>
							{%- endif -%}

							{%- if button_label != blank -%}
								<div class="button-wrapper">
									<a class="button primary-button{% if animation %} scroll-trigger{% endif %}" href="{{ section.settings.button_link | default: '#' }}" aria-label="play-{{- 'general.text.button' | t -}}">
										{{- button_label -}}
									</a>
								</div>
							{%- endif -%}
						</div>
					</div>
				</div>
			{%- endif -%}
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.video-with-text.name",
	"tag": "section",
	"class": "video-with-text-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "checkbox",
			"id": "full",
			"default": false,
			"label": "t:general.layout.full.label"
		},
		{
			"type": "select",
			"id": "source",
			"default": "host",
			"label": "t:sections.video.settings.source.label",
			"options": [
				{
					"value": "host",
					"label": "t:sections.video.settings.source.options.option_1.label"
				},
				{
					"value": "native",
					"label": "t:sections.video.settings.source.options.option_2.label"
				}
			]
		},
		{
			"type": "video_url",
			"id": "url",
			"accept": ["vimeo", "youtube"],
			"default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
			"label": "t:sections.video.settings.url.label"
		},
		{
			"type": "video",
			"id": "native_url",
			"label": "t:sections.video.settings.native_url.label",
			"info": "t:sections.video.settings.native_url.info"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "t:sections.video.settings.cover_image.label"
		},
		{
			"type": "select",
			"id": "height",
			"options": [
				{
					"value": "small",
					"label": "t:sections.slider.settings.height.option_2.label"
				},
				{
					"value": "medium",
					"label": "t:sections.slider.settings.height.option_3.label"
				},
				{
					"value": "large",
					"label": "t:sections.slider.settings.height.option_4.label"
				}
			],
			"label": "t:general.dimensions.height.label"
		},
		{
			"type": "select",
			"id": "layout",
			"options": [
				{
					"value": "video",
					"label": "t:sections.video-with-text.settings.layout.option_1.label"
				},
				{
					"value": "text",
					"label": "t:sections.video-with-text.settings.layout.option_2.label"
				}
			],
			"default": "video",
			"label": "t:sections.video-with-text.settings.layout.label",
			"info": "t:sections.video-with-text.settings.layout.info"
		},
		{
			"type": "header",
			"content": "t:general.typography.content.label"
		},
		{
			"type": "text",
			"id": "caption",
			"label": "t:general.typography.caption.label"
		},
		{
			"type": "inline_richtext",
			"id": "heading_text",
			"default": "Video with text",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h3",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h2",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h3",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "richtext",
			"id": "text",
			"default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
			"label": "t:general.typography.description.label"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "Button label",
			"label": "t:general.typography.button_label.label"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:general.typography.link.label"
		},
		{
			"type": "select",
			"id": "desktop_align",
			"options": [
				{
					"value": "left",
					"label": "t:general.layout.desktop_alignment.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.desktop_alignment.option_2.label"
				},
				{
					"value": "right",
					"label": "t:general.layout.desktop_alignment.option_3.label"
				}
			],
			"default": "left",
			"label": "t:general.layout.alignment.label"
		},
		{
			"type": "select",
			"id": "mobile_align",
			"options": [
				{
					"value": "left",
					"label": "t:general.layout.mobile_alignment.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.mobile_alignment.option_2.label"
				},
				{
					"value": "right",
					"label": "t:general.layout.mobile_alignment.option_3.label"
				}
			],
			"default": "left",
			"label": "t:general.layout.mobile_alignment.label"
		},
		{
			"type": "color_scheme",
			"id": "content_color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.video-with-text.name"
		}
	]
}
{% endschema %}
