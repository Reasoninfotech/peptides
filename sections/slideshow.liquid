{%- liquid
	assign section_id    = '#shopify-section-' | append: section.id
	assign animation     = settings.section_animation
	assign full          = section.settings.full
	assign height        = section.settings.height

	case height
		when 'small'
			assign height_value = '450px'
		when 'medium'
			assign height_value = '580px'
		when 'large'
			assign height_value = '700px'
	endcase

	unless routes.account_login_url == '/account/login'
  	  assign new_customer_account = ' new-customer-accounts'
  	endunless
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	@media (min-width: 992px) {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}

	{%- if height != 'auto' -%}
		{{ section_id }} .theme-slider.height-{{ height }} .unity-slide {
			height: {{ height_value }};
		}
	{%- endif -%}

	{% comment %} Blocks {% endcomment %}
	{%- for block in section.blocks -%}
		{%- assign overlay_opacity = block.settings.overlay_opacity -%}

		@media (min-width: 992px) {
			{{ section_id }} [data-{{ block.id }}] .slider-content-inner {
				max-width: {{ block.settings.content_width }}%;
			}
		}

		{{ section_id }} .unity-slide[data-{{ block.id }}] .slider-image:before {
			content: '';
			background: linear-gradient(to bottom,{%- if overlay_opacity == 100 -%}rgb(0,0,0){%- else -%}rgba(0,0,0,0.{{ overlay_opacity }}){%- endif -%},{%- if overlay_opacity == 100 -%}rgb(0,0,0){%- else -%}rgba(0,0,0,0.{{ overlay_opacity }}){%- endif -%});
		}

		{{ section_id }} [data-{{ block.id }}] {
			--description-line: {{ block.settings.description_line }};
		}
	{%- endfor -%}


	.slide-element-inner .rte p{
		color: #efe5e5!important; 
		font-size: 18px!important; 
		margin-bottom: 0px!important;
		line-height: 1.5!important;
	}
</style>

<div class="section-wrapper color-{{ section.settings.color_scheme }}" style="margin-top: 0px;">
	<div class="{% if full %}stretch-section{% else %}container{% endif %}">
		<div class="theme-slider height-{{ height }}">
			<unity-slider class="unity-slider">
				<template data-options>
					{
						"loop": true,
						"_autoplay": {{ 5 | times: 1000 }},
						"_autoheight": true,
						"_fade": false,
						"_prevBtn": "{{ section_id }} .unity-button-prev",
						"_nextBtn": "{{ section_id }} .unity-button-next",
						"_dotsNode": "{{ section_id }} .unity-dots"
					}
				</template>

				<template data-thumbs-options>
					{
						"loop": true,
						"containScroll": "keepSnaps"
					}
				</template>

				<div class="unity-slider-viewport">
					<div class="unity-slider-container">
						{%- for block in section.blocks -%}
							<div class="unity-slide no-content{% if animation and forloop.index == 1 %} scroll-trigger{% endif %}" data-id="{{ block.id }}" data-{{ block.id }} {{ block.shopify_attributes }} {% if request.design_mode %} data-index="{{ forloop.index0 }}"{% endif %}>
								{%- case block.type -%}
									{%- when '@app' -%}
										{%- render block -%}
									{%- when 'slide' -%}
										{%- liquid
											assign slide_image  = block.settings.image
											assign mobile_image = block.settings.mobile_image
											assign image_load   = 'eager'
											assign caption      = block.settings.caption
											assign heading      = block.settings.heading
											assign text         = block.settings.text
											assign button       = block.settings.button

											if forloop.index > 1
												assign image_load = 'lazy'
											endif
										-%}
										<a class="slide-element-inner" href="{{ block.settings.link | default: '#' }}" aria-label="{{- 'general.text.link' | t -}}" tabindex="0" >
											<div class="slider-image">
												<div class="image{% if mobile_image != blank %} hidden-tablet hidden-mobile{% endif %}{% if settings.image_lazy and slide_image %} lazy-image{% endif %}">
													{%- liquid
														if slide_image != blank
															render 'lazy-image', image: slide_image, width: 1920, lazy: image_load
														else
															echo 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg'
														endif
													-%}
												</div>

												{%- if mobile_image != blank -%}
													<div class="image hidden-desktop{% if settings.image_lazy and mobile_image %} lazy-image{% endif %}">
														{%- render 'lazy-image', image: mobile_image, width: 1000, lazy: image_load -%}
													</div>
												{%- endif -%}
											</div>

											<div class="slider-content flex-justify-{{ block.settings.position_y }} container">
												<div class="slider-content-inner flex-align-{{ block.settings.position_x }}">
													<div class="content-wrap text-{{ block.settings.text_align }} text-{{ block.settings.mobile_text_align }}-mobile">
														{%- if caption != blank -%}
															<div class="slider-element slider-caption sub-heading">
																<div class="slide-element-inner rte">{{- caption -}}</div>
															</div>
														{%- endif -%}

														{%- if heading != blank -%}
															<div class="slider-element slider-heading">
																<h2 class="slide-element-inner rte {{ block.settings.heading_size }}" style="color: #efe5e5; font-size: 48px; margin-bottom: 16px; line-height: 1.1;">{{- heading | replace: "/", "<br>" | raw -}}</h2>
															</div>
														{%- endif -%}

														{%- if text != blank -%}
															<div class="slider-element slider-description">
																<div class="slide-element-inner rte {{ block.settings.description_size }}">{{- text -}}</div>
															</div>
														{%- endif -%}

														{%- if button != blank -%}
														    <div class="slider-element slider-button" style="margin: 0px;">
																{% if customer %}
																<span class="button" tabindex="0" style="background-color: #1a4d2e!important; border-radius: 10px!important; padding: 16px 32px; font-size: 16px; color: white;">
																	{{- button | escape -}}
																</span>
																{% else %}
																	<a href="{{ routes.storefront_login_url }}&return_to=/pages/dashboard" aria-label="{{- 'general.text.link' | t -}}" class="button{{ new_customer_account }}" style="background-color: #1a4d2e!important; border-radius: 10px!important; padding: 16px 32px; font-size: 16px; color: white;">
																		{{- button | escape -}}
																	</a>
																{% endif %}
																{% comment %} <span class="button {{ block.settings.button_style }}-button slide-element-inner" tabindex="0" >
																	{{- button | escape -}}
																</span> {% endcomment %}
															</div>
														{%- endif -%}
													</div>
												</div>
											</div>
										</a>
								{%- endcase -%}
							</div>
						{%- endfor -%}
					</div>
				</div>

				<div class="slider-pagination{% if full %} container{% endif %}">
					<div class="thumb-slider">
						<div class="unity-thumbs-slider-viewport" tabindex="-1">
							<div class="unity-thumbs-slider-container">
								{%- for block in section.blocks -%}
									<div class="unity-thumbs-slide unity-thumbs-slide-selected" {{ block.shopify_attributes }}>
										<button class="unity-thumb-number">
											<span class="progress-arc" aria-hidden="true"></span>
											<span class="thumb-number">{{ forloop.index }}</span>
										</button>
									</div>
								{%- endfor -%}
							</div>
						</div>
					</div>
				</div>
			</unity-slider>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.slider.name",
	"tag": "section",
	"class": "slideshow-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "checkbox",
			"id": "full",
			"default": true,
			"label": "t:general.layout.full.label"
		},
		{
			"type": "select",
			"id": "height",
			"default": "medium",
			"options": [
				{
					"value": "auto",
					"label": "t:sections.slider.settings.height.option_1.label"
				},
				{
					"value": "small",
					"label": "t:sections.slider.settings.height.option_2.label"
				},
				{
					"value": "medium",
					"label": "t:sections.slider.settings.height.option_3.label"
				},
				{
					"value": "large",
					"label": "t:sections.slider.settings.height.option_4.label"
				}
			],
			"label": "t:general.dimensions.height.label"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 0,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 0,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 0,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 0,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"blocks": [
		{
			"type": "@app"
		},
		{
			"type": "slide",
			"name": "t:sections.slider.blocks.slider.name",
			"limit": 5,
			"settings": [
				{
					"type": "image_picker",
					"id": "image",
					"label": "t:sections.slider.blocks.slider.settings.image.label"
				},
				{
					"type": "image_picker",
					"id": "mobile_image",
					"label": "t:sections.slider.blocks.slider.settings.mobile_image.label"
				},
				{
					"type": "range",
					"id": "overlay_opacity",
					"min": 0,
					"max": 100,
					"step": 1,
					"default": 0,
					"unit": "%",
					"label": "t:sections.slider.blocks.slider.settings.overlay_opacity.label",
					"info": "t:sections.slider.blocks.slider.settings.overlay_opacity.info"
				},
				{
					"type": "header",
					"content": "t:general.typography.text.label"
				},
				{
					"type": "text",
					"id": "caption",
					"default": "Image caption",
					"label": "t:general.typography.caption.label"
				},
				{
					"type": "inline_richtext",
					"id": "heading",
					"default": "Image slide",
					"label": "t:general.typography.heading.label"
				},
				{
					"type": "select",
					"id": "heading_size",
					"options": [
						{
							"value": "h3",
							"label": "t:general.typography.heading_size.option_1.label"
						},
						{
							"value": "h2",
							"label": "t:general.typography.heading_size.option_2.label"
						},
						{
							"value": "h1",
							"label": "t:general.typography.heading_size.option_3.label"
						}
					],
					"default": "h2",
					"label": "t:general.typography.heading_size.label"
				},
				{
					"type": "richtext",
					"id": "text",
					"default": "<p>Tell your brand's story through images</p>",
					"label": "t:general.typography.description.label"
				},
				{
					"type": "select",
					"id": "description_size",
					"options": [
						{
							"value": "h5",
							"label": "t:general.typography.heading_size.option_1.label"
						},
						{
							"value": "h4",
							"label": "t:general.typography.heading_size.option_2.label"
						},
						{
							"value": "h3",
							"label": "t:general.typography.heading_size.option_3.label"
						}
					],
					"default": "h4",
					"label": "t:general.typography.description_size.label"
				},
				{
					"type": "text",
					"id": "button",
					"default": "Button label",
					"label": "t:general.typography.button_label.label"
				},
				{
				  "type": "checkbox",
				  "id": "use_custom_button",
				  "label": "Use Custom Button",
				  "default": false
				},
				{
					"type": "url",
					"id": "link",
					"label": "t:general.typography.button_link.label"
				},
				{
					"type": "select",
					"id": "button_style",
					"options": [
						{
							"value": "primary",
							"label": "t:general.typography.style.option_1.label"
						},
						{
							"value": "secondary",
							"label": "t:general.typography.style.option_2.label"
						}
					],
					"default": "primary",
					"label": "t:general.typography.style.label"
				},
				{
					"type": "header",
					"content": "t:general.layout.name"
				},
				{
					"type": "range",
					"id": "content_width",
					"min": 10,
					"max": 100,
					"step": 1,
					"default": 100,
					"unit": "%",
					"label": "t:sections.slider.blocks.slider.settings.content_width.label"
				},
				{
					"type": "select",
					"id": "position_x",
					"options": [
						{
							"value": "start",
							"label": "t:sections.slider.blocks.slider.settings.position_x.options__1.label"
						},
						{
							"value": "center",
							"label": "t:sections.slider.blocks.slider.settings.position_x.options__2.label"
						},
						{
							"value": "end",
							"label": "t:sections.slider.blocks.slider.settings.position_x.options__3.label"
						}
					],
					"default": "center",
					"label": "t:sections.slider.blocks.slider.settings.position_x.label",
					"info": "t:general.layout.alignment.mobile_center.label"
				},
				{
					"type": "select",
					"id": "position_y",
					"options": [
						{
							"value": "start",
							"label": "t:sections.slider.blocks.slider.settings.position_y.options__1.label"
						},
						{
							"value": "center",
							"label": "t:sections.slider.blocks.slider.settings.position_y.options__2.label"
						},
						{
							"value": "end",
							"label": "t:sections.slider.blocks.slider.settings.position_y.options__3.label"
						}
					],
					"default": "center",
					"label": "t:sections.slider.blocks.slider.settings.position_y.label",
					"info": "t:general.layout.alignment.mobile_center.label"
				},
				{
					"type": "select",
					"id": "text_align",
					"options": [
						{
							"value": "left",
							"label": "t:general.layout.alignment.option_1.label"
						},
						{
							"value": "center",
							"label": "t:general.layout.alignment.option_2.label"
						},
						{
							"value": "right",
							"label": "t:general.layout.alignment.option_3.label"
						}
					],
					"default": "center",
					"label": "t:general.layout.alignment.label"
				},
				{
					"type": "header",
					"content": "t:general.layout.mobile_layout.content"
				},
				{
					"type": "select",
					"id": "mobile_text_align",
					"options": [
						{
							"value": "left",
							"label": "t:general.layout.mobile_alignment.option_1.label"
						},
						{
							"value": "center",
							"label": "t:general.layout.mobile_alignment.option_2.label"
						},
						{
							"value": "right",
							"label": "t:general.layout.mobile_alignment.option_3.label"
						}
					],
					"default": "center",
					"label": "t:general.layout.mobile_alignment.label"
				},
				{
					"type": "select",
					"id": "description_line",
					"options": [
						{
							"value": "1",
							"label": "t:sections.slider.blocks.slider.settings.description_line.option_1.label"
						},
						{
							"value": "2",
							"label": "t:sections.slider.blocks.slider.settings.description_line.option_2.label"
						},
						{
							"value": "3",
							"label": "t:sections.slider.blocks.slider.settings.description_line.option_3.label"
						}
					],
					"default": "2",
					"label": "t:sections.slider.blocks.slider.settings.description_line.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.slider.name",
			"blocks": [
				{
					"type": "slide"
				},
				{
					"type": "slide"
				},
				{
					"type": "slide"
				}
			]
		}
	]
}
{% endschema %}
