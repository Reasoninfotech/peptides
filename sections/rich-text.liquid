{%- liquid
	assign section_id = '#shopify-section-' | append: section.id
	assign full       = section.settings.full
	assign animation  = settings.section_animation
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	@media (min-width: 992px)  {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}

		{{ section_id }} .rich-text-blocks {
			width: {{ section.settings.width }}%;
			margin: 0 auto;
		}

		{%- for block in section.blocks -%}
			{%- if block.type == 'heading' -%}
				{{ section_id }} [data-{{ block.id }}] {
					margin-bottom: {{ block.settings.vertical }}px;
				}
			{%- endif -%}
		{%- endfor -%}
	}
</style>

<div class="section-wrapper color-{{ section.settings.color_scheme }}">
	<div class="{% if full %}stretch-section stretch-padding{% else %}container{% endif %}">
		<div class="rich-text-blocks text-{{ section.settings.align }}">
			{%- for block in section.blocks -%}
				{%- case block.type -%}
					{%- when '@app' -%}
						{%- render block -%}
					{%- when 'heading' -%}
						{%- liquid
							assign tag = block.settings.tag
							assign num = tag | remove: 'h' | times: 1

							case block.settings.font_size
								when 'small'
									assign cls = num | plus: 1
								when 'medium'
									assign cls = num
								when 'large'
									assign cls = num | minus: 1
							endcase
						-%}

						<{{ tag }} class="heading {{ cls | prepend: 'h' }}{% if animation %} scroll-trigger{% endif %}" data-{{ block.id }} {{ block.shopify_attributes }}>{{- block.settings.content -}}</{{ tag }}>
					{%- when 'text' -%}
						<div class="text rte{% if animation %} scroll-trigger{% endif %}" {{ block.shopify_attributes }} {{ block.shopify_attributes }}>{{- block.settings.content -}}</div>
					{%- when 'button' -%}
						<a href="{{ block.settings.link }}" aria-label="{{- 'general.text.link' | t -}}" class="button {{ block.settings.style }}-button {{ block.settings.size }}-button{% if animation %} scroll-trigger{% endif %}" {{ block.shopify_attributes }}>
							{{- block.settings.label | escape -}}
						</a>
				{%- endcase -%}
			{%- endfor -%}
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.rich-text.name",
	"tag": "section",
	"class": "richtext-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "checkbox",
			"id": "full",
			"default": false,
			"label": "t:general.layout.full.label"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "select",
			"id": "align",
			"options": [
				{
					"value": "left",
					"label": "t:general.layout.alignment.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.alignment.option_2.label"
				},
				{
					"value": "right",
					"label": "t:general.layout.alignment.option_3.label"
				}
			],
			"default": "center",
			"label": "t:general.layout.alignment.label"
		},
		{
			"type": "range",
			"id": "width",
			"min": 50,
			"max": 100,
			"step": 5,
			"default": 100,
			"unit": "%",
			"label": "t:general.dimensions.content_width.label"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 1,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"blocks": [
		{
			"type": "@app"
		},
		{
			"type": "heading",
			"name": "t:general.typography.heading.label",
			"settings": [
				{
					"type": "text",
					"id": "content",
					"default": "Talk about your brand",
					"label": "t:general.typography.content.label"
				},
				{
					"type": "select",
					"id": "tag",
					"default": "h4",
					"label": "t:sections.rich-text.blocks.heading.settings.tag.label",
					"options": [
						{
							"value": "h1",
							"label": "t:general.typography.h1_tag.label"
						},
						{
							"value": "h2",
							"label": "t:general.typography.h2_tag.label"
						},
						{
							"value": "h3",
							"label": "t:general.typography.h3_tag.label"
						},
						{
							"value": "h4",
							"label": "t:general.typography.h4_tag.label"
						},
						{
							"value": "h5",
							"label": "t:general.typography.h5_tag.label"
						},
						{
							"value": "h6",
							"label": "t:general.typography.h6_tag.label"
						}
					]
				},
				{
					"type": "select",
					"id": "font_size",
					"options": [
						{
							"value": "small",
							"label": "t:general.typography.heading_size.option_1.label"
						},
						{
							"value": "medium",
							"label": "t:general.typography.heading_size.option_2.label"
						},
						{
							"value": "large",
							"label": "t:general.typography.heading_size.option_3.label"
						}
					],
					"default": "medium",
					"label": "t:general.typography.font_size.label"
				},
				{
					"type": "range",
					"id": "vertical",
					"min": -100,
					"max": 100,
					"step": 2,
					"default": 0,
					"unit": "px",
					"label": "t:sections.rich-text.blocks.heading.settings.vertical.label"
				}
			]
		},
		{
			"type": "text",
			"name": "t:general.typography.text.label",
			"settings": [
				{
					"type": "richtext",
					"id": "content",
					"default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>",
					"label": "t:general.typography.content.label"
				}
			]
		},
		{
			"type": "button",
			"name": "t:general.typography.button.label",
			"settings": [
				{
					"type": "text",
					"id": "label",
					"default": "Button label",
					"label": "t:general.typography.text.label"
				},
				{
					"type": "url",
					"id": "link",
					"label": "t:general.typography.link.label"
				},
				{
					"type": "select",
					"id": "size",
					"options": [
						{
							"value": "small",
							"label": "t:sections.rich-text.blocks.button.settings.size.option_1.label"
						},
						{
							"value": "medium",
							"label": "t:sections.rich-text.blocks.button.settings.size.option_2.label"
						},
						{
							"value": "large",
							"label": "t:sections.rich-text.blocks.button.settings.size.option_3.label"
						}
					],
					"default": "small",
					"label": "t:sections.rich-text.blocks.button.settings.size.label"
				},
				{
					"type": "select",
					"id": "style",
					"options": [
						{
							"value": "primary",
							"label": "t:sections.rich-text.blocks.button.settings.style.option_1.label"
						},
						{
							"value": "secondary",
							"label": "t:sections.rich-text.blocks.button.settings.style.option_2.label"
						}
					],
					"default": "primary",
					"label": "t:sections.rich-text.blocks.button.settings.style.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.rich-text.name",
			"blocks": [
				{
					"type": "heading"
				},
				{
					"type": "text"
				},
				{
					"type": "button"
				}
			]
		}
	]
}
{% endschema %}
