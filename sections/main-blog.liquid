{%- liquid
	assign section_id = '#shopify-section-' | append: section.id
	assign animation  = settings.section_animation
	assign full       = section.settings.full
	assign layout     = section.settings.layout
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	@media (min-width: 992px) {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
</style>

{%- paginate blog.articles by 6 -%}
	<div class="section-wrapper color-{{ section.settings.color_scheme }}">
		<div class="main-blog{% if section.settings.show_heading or section.settings.description != blank %} has-heading{% endif %}{% if paginate.pages > 1 %} has-pagination{% endif %}" role="list">
			{%- if section.settings.show_heading or section.settings.description != blank -%}
				<div class="blog-header color-{{ section.settings.title_color_scheme }}">
					<div class="{% if full %}stretch-section stretch-padding{% else %}container{% endif %}">
						{%- if section.settings.show_heading -%}
							<h1 class="blog-heading h2{% if animation %} scroll-trigger{% endif %}">{{- blog.title -}}</h1>
						{%- endif -%}

						{%- if section.settings.description != blank -%}
							<div class="blog-description rte{% if animation %} scroll-trigger{% endif %}">{{- section.settings.description -}}</div>
						{%- endif -%}
					</div>
				</div>
			{%- endif -%}

			<div class="{% if full %}stretch-section stretch-padding{% else %}container{% endif %}">
				<div class="blog-main-content">
					<div class="blog-list-item blog-{{ layout }}{% if layout == 'grid' %} grid grid-3 grid-tablet-1 grid-mobile-1{% endif %}" role="list">
						{%- for article in blog.articles -%}
							<div class="grid-item {{ section.settings.card_layout }}-item color-{{ section.settings.card_color_scheme }} border-large" data-{{ forloop.index0 }} data-index="{{ forloop.index }}">
								{%- render 'post-card', article: article, in_search_results: false -%}
							</div>
						{%- endfor -%}
					</div>
				</div>
			</div>
		</div>

		{%- liquid
			if paginate.pages > 1
				render 'pagination', paginate: paginate
			endif
		-%}
	</div>
{%- endpaginate -%}

{% schema %}
{
	"name": "t:sections.main-blog.name",
	"tag": "section",
	"class": "blog-list-section",
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "checkbox",
			"id": "full",
			"default": false,
			"label": "t:general.layout.full.label"
		},
		{
			"type": "select",
			"id": "layout",
			"options": [
				{
					"value": "grid",
					"label": "t:sections.main-blog.settings.desktop_layout.option_1.label"
				},
				{
					"value": "collage",
					"label": "t:sections.main-blog.settings.desktop_layout.option_2.label"
				}
			],
			"default": "grid",
			"label":  "t:sections.main-blog.settings.desktop_layout.label"
		},
		{
			"type": "header",
			"content": "t:general.typography.heading.label"
		},
		{
			"type": "checkbox",
			"id": "show_heading",
			"default": true,
			"label": "t:sections.main-blog.settings.show_heading.label"
		},
		{
			"type": "richtext",
			"id": "description",
			"label": "t:general.typography.description.label"
		},
		{
			"type": "color_scheme",
			"id": "title_color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "t:sections.collage-blog-posts.settings.card.content"
		},
		{
			"type": "select",
			"id": "card_layout",
			"options": [
				{
					"value": "standard",
					"label": "t:sections.main-blog.settings.card_layout.option_1.label"
				},
				{
					"value": "overlay",
					"label": "t:sections.main-blog.settings.card_layout.option_2.label"
				}
			],
			"default": "standard",
			"label":  "t:general.layout.name"
		},
		{
			"type": "select",
			"id": "image_ratio",
			"options": [
				{
					"value": "adapt",
					"label": "t:sections.main-blog.settings.image_ratio.option_1.label"
				},
				{
					"value": "portrait",
					"label": "t:sections.main-blog.settings.image_ratio.option_2.label"
				},
				{
					"value": "square",
					"label": "t:sections.main-blog.settings.image_ratio.option_3.label"
				}
			],
			"default": "square",
			"label": "t:sections.main-blog.settings.image_ratio.label"
		},
		{
			"type": "checkbox",
			"id": "show_date",
			"default": true,
			"label": "t:sections.main-blog.settings.show_date.label"
		},
		{
			"type": "checkbox",
			"id": "show_comment",
			"default": true,
			"label": "t:sections.main-blog.settings.show_comment.label"
		},
		{
			"type": "checkbox",
			"id": "show_author",
			"default": false,
			"label": "t:sections.main-blog.settings.show_author.label"
		},
		{
			"type": "checkbox",
			"id": "show_blog",
			"default": true,
			"label": "t:sections.main-blog.settings.show_blog.label"
		},
		{
			"type": "checkbox",
			"id": "show_excerpt",
			"default": true,
			"label": "t:sections.main-blog.settings.show_excerpt.label"
		},
		{
			"type": "checkbox",
			"id": "show_read_more",
			"default": true,
			"label": "t:sections.main-blog.settings.show_read_more.label"
		},
		{
			"type": "color_scheme",
			"id": "card_color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 2,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 2,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	]
}
{% endschema %}
