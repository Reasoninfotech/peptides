<script>
    // Trigger Invoice Email via App backend
    function triggerInvoiceEmail(event, orderId) {
        event.preventDefault();
        event.stopPropagation();

        const btn = event.currentTarget;
        const originalText = btn.innerText;
        btn.innerText = "Sending...";

        // This requires your Custom App backend to handle the POST request
        // and trigger the Shopify Admin API `orderInvoiceSend` mutation.
        fetch('/apps/adjust-discount/send-invoice', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ order_id: orderId })
        })
            .then(response => {
                // Note: Update backend handling as needed!
                alert('Request sent to send invoice email! (Ensure backend is configured)');
                btn.innerText = "Email Sent";
            })
            .catch(error => {
                alert('Error triggering invoice email.');
                btn.innerText = originalText;
            });
    }

    // Dropdown toggle
    function toggleDropdown(event, dropdownId) {
        event.stopPropagation();
        const dropdowns = document.querySelectorAll('.dropdown-content');
        dropdowns.forEach(dropdown => {
            if (dropdown.id !== dropdownId) {
                dropdown.classList.remove('show');
            }
        });
        document.getElementById(dropdownId).classList.toggle('show');
    }

    // Close the dropdown if the user clicks outside of it
    window.addEventListener('click', function (event) {
        if (!event.target.matches('.order-dots')) {
            const dropdowns = document.querySelectorAll('.dropdown-content');
            dropdowns.forEach(dropdown => {
                if (dropdown.classList.contains('show')) {
                    dropdown.classList.remove('show');
                }
            });
        }
    });

    // Sidebar toggle
    function showSection(event, sectionId) {
        // Remove active class from all sections and links
        document.querySelectorAll('.section').forEach(sec => sec.classList.remove('active'));
        document.querySelectorAll('.sidebar-link').forEach(link => {
            if (link.getAttribute('onclick')) {
                link.classList.remove('active-tab');
            }
        });

        // Add active class to target section and clicked link
        document.getElementById(sectionId).classList.add('active');
        if (event && event.currentTarget) {
            event.currentTarget.classList.add('active-tab');
        } else {
            // Find the link that corresponds to this section and make it active
            const link = document.querySelector(`.sidebar-link[onclick*="'${sectionId}'"]`);
            if (link) link.classList.add('active-tab');
        }
    }

    // Handle incoming deep links (e.g. from site header)
    window.addEventListener('DOMContentLoaded', function () {
        const hash = window.location.hash.substring(1);
        if (hash === 'recent-orders' || hash === 'order-table') {
            showSection(null, 'dashboard');
            setTimeout(() => {
                const tableContainer = document.querySelector('.recent-orders-container');
                if (tableContainer) tableContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
        } else if (hash === 'orders' || hash === 'dashboard') {
            showSection(null, hash);
        }
    });

    // Chart Initialization
    (function () {
        const lineCtx = document.getElementById('ordersChart');
        const pieCtx = document.getElementById('distributionChart');
        if (!lineCtx || !pieCtx) return;

        let chartLabels, chartValues, pieData;

        {% if customer %}
        const monthlyData = {};
        let Fulfilled = 0;
        let unfulfilled = 0;

        {% for order in customer.orders %}
        {% assign month_name = order.created_at | date: "%b" %}
        if (monthlyData['{{ month_name }}']) {
            monthlyData['{{ month_name }}'] += 1;
        } else {
            monthlyData['{{ month_name }}'] = 1;
        }

        {% assign f_status = order.fulfillment_status %}
        {% if f_status == 'fulfilled' %}
        Fulfilled++;
        {% else %}
        unfulfilled++;
        {% endif %}
        {% endfor %}

        chartLabels = Object.keys(monthlyData).length > 0 ? Object.keys(monthlyData).reverse() : ['Jan', 'Feb', 'Mar', 'Apr'];
        chartValues = Object.keys(monthlyData).length > 0 ? Object.values(monthlyData).reverse() : [0, 0, 0, 0];
        if (Fulfilled === 0 && unfulfilled === 0) Fulfilled = 1;
        pieData = [Fulfilled, unfulfilled];
        {% else %}
        chartLabels = ['Feb', 'Apr', 'Jun', 'Aug', 'Oct', 'Dec'];
        chartValues = [45, 65, 78, 88, 95, 105];
        pieData = [69, 12];
        {% endif %}

        // Line Chart (Orders by Month)
        new Chart(lineCtx, {
            type: 'line',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Orders',
                    data: chartValues,
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    borderWidth: 2,
                    pointBackgroundColor: '#3b82f6',
                    pointBorderColor: '#fff',
                    pointRadius: 4,
                    fill: false,
                    tension: 0.1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { borderDash: [4, 4], color: '#f0f0f0' },
                        ticks: { stepSize: 30 }
                    },
                    x: {
                        grid: { display: false }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });

        // Pie Chart (Order Distribution)
        new Chart(pieCtx, {
            type: 'pie',
            data: {
                labels: ['Fulfilled Orders', 'Unfulfilled Orders'],
                datasets: [{
                    data: pieData,
                    backgroundColor: ['#10b981', '#f59e0b'],
                    borderWidth: 1,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'left',
                        labels: { boxWidth: 12, usePointStyle: true }
                    }
                }
            }
        });
    })();
</script>

