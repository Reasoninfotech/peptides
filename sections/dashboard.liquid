                <script>
                    let currentPage = 1;
                    let rowsPerPage = 5;

                    function paginateTable() {
                        const tbody = document.getElementById('ordersBody');
                        if (!tbody) return;
                        const rows = Array.from(tbody.querySelectorAll('tr'));

                        if (rows.length === 0) return;

                        // Handle "All"
                        const isAll = rowsPerPage === 'all';
                        const totalRows = rows.length;
                        const totalPages = isAll ? 1 : Math.ceil(totalRows / rowsPerPage);

                        // Ensure current page is valid
                        if (currentPage < 1) currentPage = 1;
                        if (currentPage > totalPages) currentPage = totalPages;

                        const startIndex = isAll ? 0 : (currentPage - 1) * rowsPerPage;
                        const endIndex = isAll ? totalRows : startIndex + rowsPerPage;

                        // Toggle visibility
                        rows.forEach((row, index) => {
                            if (index >= startIndex && index < endIndex) {
                                row.style.display = '';
                            } else {
                                row.style.display = 'none';
                            }
                        });

                        // Update buttons and text
                        document.getElementById('pageInfo').innerText =
                            totalPages > 0 ? `Page ${currentPage} of ${totalPages}` : `Page 1 of 1`;
                        document.getElementById('prevPageBtn').disabled = currentPage <= 1;
                        document.getElementById('nextPageBtn').disabled = currentPage >= totalPages || isAll;

                        // Show pagination
                        document.getElementById('paginationControls').style.display = 'flex';
                    }

                    function changeRowsPerPage() {
                        const select = document.getElementById('rowsPerPage');
                        const val = select.value;
                        rowsPerPage = val === 'all' ? 'all' : parseInt(val);
                        currentPage = 1;
                        paginateTable();
                    }

                    function nextPage() {
                        currentPage++;
                        paginateTable();
                    }

                    function prevPage() {
                        currentPage--;
                        paginateTable();
                    }

                    // Init pagination
                    window.addEventListener('DOMContentLoaded', () => {
                        paginateTable();
                        paginateOrders();
                    });

                    let currentPageOrders = 1;
                    let rowsPerPageOrders = 5;

                    function paginateOrders() {
                        const container = document.getElementById('orders');
                        if (!container) return;
                        const cards = Array.from(container.querySelectorAll('.order-card'));

                        if (cards.length === 0) return;

                        const isAll = rowsPerPageOrders === 'all';
                        const totalCards = cards.length;
                        const totalPages = isAll ? 1 : Math.ceil(totalCards / rowsPerPageOrders);

                        if (currentPageOrders < 1) currentPageOrders = 1;
                        if (currentPageOrders > totalPages) currentPageOrders = totalPages;

                        const startIndex = isAll ? 0 : (currentPageOrders - 1) * rowsPerPageOrders;
                        const endIndex = isAll ? totalCards : startIndex + rowsPerPageOrders;

                        cards.forEach((card, index) => {
                            if (index >= startIndex && index < endIndex) {
                                card.style.display = '';
                            } else {
                                card.style.display = 'none';
                            }
                        });

                        document.getElementById('pageInfoOrders').innerText =
                            totalPages > 0 ? `Page ${currentPageOrders} of ${totalPages}` : `Page 1 of 1`;
                        document.getElementById('prevPageBtnOrders').disabled = currentPageOrders <= 1;
                        document.getElementById('nextPageBtnOrders').disabled = currentPageOrders >= totalPages || isAll;

                        document.getElementById('paginationControlsOrders').style.display = 'flex';
                    }

                    function changeRowsPerPageOrders() {
                        const select = document.getElementById('rowsPerPageOrders');
                        const val = select.value;
                        rowsPerPageOrders = val === 'all' ? 'all' : parseInt(val);
                        currentPageOrders = 1;
                        paginateOrders();
                    }

                    function nextPageOrders() {
                        currentPageOrders++;
                        paginateOrders();
                    }

                    function prevPageOrders() {
                        currentPageOrders--;
                        paginateOrders();
                    }
                </script>

