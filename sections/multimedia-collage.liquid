{% schema %}
{
	"name": "t:sections.multimedia-collage.name",
	"tag": "section",
	"class": "multimedia-collage-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "checkbox",
			"id": "full",
			"default": false,
			"label": "t:general.layout.full.label"
		},
		{
		  "type": "select",
		  "id": "image_position",
		  "label": "Image Position",
		  "options": [
		    {
		      "value": "first",
		      "label": "Image First"
		    },
		    {
		      "value": "second",
		      "label": "Image Second"
		    }
		  ],
		  "default": "second"
		},
		{
			"type": "text",
			"id": "caption",
			"default": "Caption",
			"label": "t:general.typography.caption.label"
		},
		{
			"type": "inline_richtext",
			"id": "heading_text",
			"default": "Multimedia collage",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h3",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h2",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h3",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "richtext",
			"id": "text",
			"default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
			"label": "t:general.typography.description.label"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "Button label",
			"label": "t:general.typography.button_label.label"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:general.typography.link.label"
		},
		{
			"type": "select",
			"id": "desktop_layout",
			"options": [
				{
					"value": "left",
					"label": "t:sections.multimedia-collage.settings.desktop_layout.options__1.label"
				},
				{
					"value": "right",
					"label": "t:sections.multimedia-collage.settings.desktop_layout.options__2.label"
				}
			],
			"default": "left",
			"label": "t:sections.multimedia-collage.settings.desktop_layout.label"
		},
		{
			"type": "select",
			"id": "mobile_layout",
			"options": [
				{
					"value": "multimedia-collage",
					"label": "t:sections.multimedia-collage.settings.mobile_layout.options__1.label"
				},
				{
					"value": "column",
					"label": "t:sections.multimedia-collage.settings.mobile_layout.options__2.label"
				}
			],
			"default": "column",
			"label": "t:sections.multimedia-collage.settings.mobile_layout.label"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"blocks": [
		{
			"type": "@app"
		},
		{
			"type": "image",
			"name": "t:general.image.label",
			"limit": 1,
			"settings": [
				{
					"type":"image_picker",
					"id":"image",
					"label": "t:general.image.label"
				}
			]
		},
		{
			"type": "collection",
			"name": "t:sections.multimedia-collage.blocks.collection.label",
			"limit": 1,
			"settings": [
				{
					"type": "color_scheme",
					"id": "collection_color_scheme",
					"label": "t:settings_schema.colors.label",
					"default": "scheme-1"
				},
				{
					"type": "collection",
					"id": "collection",
					"label": "t:sections.multimedia-collage.blocks.collection.label"
				}
			]
		},
		{
			"type": "product",
