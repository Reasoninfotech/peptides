{%- liquid
  assign section_id = '#shopify-section-' | append: section.id
  assign animation = settings.section_animation
  assign full = section.settings.full
  assign caption = section.settings.caption
  assign heading = section.settings.heading_text
  assign heading_size = section.settings.heading_size
  assign description = section.settings.text
  assign button_label = section.settings.button_label
-%}

<style>
  {{ section_id }} .section-wrapper {
  	padding-top: {{ section.settings.padding_top_mobile }}px;
  	padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media (min-width: 992px) {
  	{{ section_id }} .section-wrapper {
  		padding-top: {{ section.settings.padding_top }}px;
  		padding-bottom: {{ section.settings.padding_bottom }}px;
  	}
  }

  .multimedia-collage-title h2{
	font-weight: 500;
  	font-size: 30px;
  	color: #1a4d2e!important;
  	margin-bottom: 16px;
  }

  {{ section_id }} .multimedia-collage-content {
  display: flex;
  flex-wrap: wrap;
  }
  
  /* Default: image second */
  {{ section_id }} .image-block {
    order: 2;
  }
  
  /* If user selects Image First */
  {% if section.settings.image_position == 'first' %}
    {{ section_id }} .image-block {
      order: 0;
    }
  {% endif %}
</style>

<btf-multimedia-collage>
  <div class="section-wrapper color-{{ section.settings.color_scheme }}">
    <div class="{% if full %}stretch-section stretch-padding{% else %}container{% endif %}">
      <div class="multimedia-collage grid{% if caption != blank or heading != blank or description != blank or button_label != blank %} has-titlle{% endif %}">
		{% if section.settings.image_position == 'second' %}
        {%- if caption != blank or heading != blank or description != blank or button_label != blank -%}
          <div class="multimedia-collage-title">
            {%- if caption != blank -%}
              <p class="caption sub-heading rte{% if animation %} scroll-trigger{% endif %}">{{- caption -}}</p>
            {%- endif -%}

            {%- if heading != blank -%}
              <h2 class="heading  rte{% if animation %} scroll-trigger{% endif %}">{{- heading -}}</h2>
            {%- endif -%}

            {%- if description != blank -%}
              <div class="description{% if animation %} scroll-trigger{% endif %}">{{- description -}}</div>
            {%- endif -%}

            {%- if button_label != blank -%}
              <a
                class="button primary-button flex-justify-center{% if animation %} scroll-trigger{% endif %}"
                href="{{ section.settings.button_link | default: '#' }}"
                aria-label="{{- 'general.text.link' | t -}}"
              >
                {{- button_label -}}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="multimedia-collage-content grid {{ section.settings.mobile_layout }} video-background-section ">
          {%- for block in section.blocks -%}
            <div class="collage-item collage-item-{{ section.settings.desktop_layout }} {% if block.type == 'image' %}image-block{% endif %}">
              {%- case block.type -%}
                {%- when 'image' -%}
                  {%- assign image = block.settings.image -%}

                  <div class="image-wrap adapt-media">
                    <div class="image border-large{% if settings.image_lazy and image != blank %} lazy-image{% endif %}">
                      {%- liquid
                        if image != blank
                          render 'lazy-image', image: image, width: 52
                        else
                          render 'icon', code: 'placeholder'
                        endif
                      -%}
                    </div>
                  </div>

                {%- when 'product' -%}
                  <div class="product-wrap border-large color-{{ block.settings.product_color_scheme }}">
                    {%- liquid
                      assign product = block.settings.product
                    -%}

                    {%- liquid
                      if product != blank
                        render 'product-card', product: product
                      else
                        render 'product-card-placeholder', index: forloop.index
                      endif
                    -%}
                  </div>

                {%- when 'collection' -%}
                  {%- liquid
                    assign collection_image = block.settings.collection.featured_image
                    assign replace_title = block.settings.collection.title
                    assign collection_product_count = block.settings.collection.all_products_count | default: 0

                    unless collection_image
                      for product in block.settings.collection.products
                        if product.featured_image
                          assign collection_image = product.featured_image

                          break
                        endif
                      endfor
                    endunless
                  -%}
                  {% if block.settings.collection %}
                    <div
                      class="collection-card-item border-large color-{{ block.settings.collection_color_scheme }}"
                      data-title="{{ replace_title | escape }}"
                      data-{{ forloop.index0 }}
                      {% if request.design_mode %}
                        data-index="{{ forloop.index0 }}"
                      {% endif %}
                      data-href="{{ block.settings.collection.url }}"
                    >
                      <div class="card-item-inner border-large">
                        <div class="card-media portrait-media">
                          <a
                            class="card-link {% if settings.image_lazy and collection_image != blank %} lazy-image{% endif %}"
                            href="{{ block.settings.collection.url }}"
                            aria-label="{{- 'general.text.link' | t -}}"
                            {{ block.shopify_attributes }}
                          >
                            {%- liquid
                              if collection_image != blank
                                assign image_load = 'eager'

                                if forloop.index > 1
                                  assign image_load = 'lazy'
                                endif

                                render 'lazy-image', image: collection_image, width: 768, lazy: image_load
                              else
                                render 'icon', code: 'placeholder'
                              endif
                            -%}
                          </a>
                        </div>

                        <div class="collection-card-content">
                          <a
                            class="card-title card-link link-underline-transparent"
                            href="{{ block.settings.collection.url }}"
                            aria-label="{{- 'general.text.link' | t -}}"
                            {{ block.shopify_attributes }}
                          >
                            <span class="collection-title">
                              {%- liquid
                                if block.settings.collection != blank
                                  echo replace_title | escape
                                else
                                  echo 'onboarding.collections.title' | t
                                endif
                              -%}
                            </span>

                            {%- if section.settings.show_product_count -%}
                              <span class="collection-product-count">
                                (
                                {{- collection_product_count -}}
                                )</span
                              >
                            {% endif %}
                          </a>
                        </div>
                      </div>
                    </div>
                  {%- else -%}
                    <div
                      class="card-item"
                      data-{{ forloop.index0 }}
                      {% if request.design_mode %}
                        data-index="{{ forloop.index0 }}"
                      {% endif %}
                      data-href="#"
                      data-title="{{- 'onboarding.collections.title' | t -}}"
                      {{ block.shopify_attributes }}
                    >
                      <div class="card-item-inner product-card">
                        <div class="card-media {{ section.settings.image_ratio }}-media {{ section.settings.image_type }}">
                          {%- render 'icon', code: 'placeholder' -%}
                        </div>

                        <div class="product-card-content">
                          <div class="card-title card-link link-underline-transparent">
                            <span class="collection-title">{{ 'onboarding.collections.title' | t }}</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  {%- endif -%}

                {%- when 'video' -%}
                  {%- liquid
                    assign video_url = block.settings.video_url
                    assign video = block.settings.video
                    assign cover_image = block.settings.cover_image
                    assign description = block.settings.description

                    assign has_video_url = false
                    assign has_local_video = false
                    assign has_video = false

                    if video_url != blank
                      assign has_video_url = true
                    endif

                    if video != blank
                      assign has_local_video = true
                    endif

                    if has_video_url or has_local_video
                      assign has_video = true
                    endif
                  -%}

                  <div class="video-wrap">
                    <div
                      class="video-item border-large{% if animation %} scroll-trigger{% endif %}"
                      data-autoplay="{{ block.settings.autoplay }}"
                    >
                      {%- if video_url != blank -%}
                        {% if video_url.type == 'youtube' %}
                          <iframe
                            class="js-video-embed js-youtube"
                            data-src="https://www.youtube.com/embed/{{ video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ video_url.id }}&controls=1&playsinline=1"
                            frameborder="0"
                            allow="autoplay; encrypted-media"
                            allowfullscreen
                            title="{{ description | escape }}"
                          >
                          </iframe>
                        {% elsif video_url.type == 'vimeo' %}
                          <iframe
                            class="js-video-embed js-vimeo"
                            data-src="https://player.vimeo.com/video/{{ video_url.id }}?autoplay=1&muted=1&loop=1&background=1"
                            frameborder="0"
                            allow="autoplay; fullscreen"
                            title="{{ description | escape }}"
                          >
                          </iframe>
                        {% endif %}
                      {%- else -%}
                        <video
                          class="js-local-video"
                          playsinline
                          {% if block.settings.autoplay %}
                            autoplay muted loop
                          {% endif %}
                          preload="none"
                          poster="{{ video.preview_image.src | image_url: width: '540' }}"
                        >
                          <source
                            data-src="{{ video.sources[1].url | default: video.sources[0].url }}"
                            type="video/mp4"
                          >
                          {{
                            video.preview_image.src
                            | image_url: width: 540
                            | image_tag: width: 540, loading: 'lazy', alt: product.title
                          }}
                        </video>
                      {% endif %}
                      {% if block.settings.autoplay == false or has_video == false %}
                        <div class="video-image-wrapper">
                          {%- liquid
                            if cover_image
                              echo cover_image | image_url: width: 1920 | image_tag: width: 1920, loading: 'lazy'
                            else
                              echo 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg'
                            endif
                          -%}
                        </div>

                        <button
                          type="button"
                          class="play-video toggle-popup-bg-video"
                          aria-label="{{- 'general.text.button' | t -}}"
                        >
                          {% render 'icon', code: 'play' %}
                        </button>
                      {% endif %}
                    </div>
                  </div>
              {%- endcase -%}
            </div>
          {%- endfor -%}
        </div>
		{% else %}
			<div class="multimedia-collage-content grid {{ section.settings.mobile_layout }} video-background-section ">
          {%- for block in section.blocks -%}
            <div class="collage-item collage-item-{{ section.settings.desktop_layout }} {% if block.type == 'image' %}image-block{% endif %}">
              {%- case block.type -%}
                {%- when 'image' -%}
                  {%- assign image = block.settings.image -%}

                  <div class="image-wrap adapt-media">
                    <div class="image border-large{% if settings.image_lazy and image != blank %} lazy-image{% endif %}">
                      {%- liquid
