{%- liquid
  assign section_id = '#shopify-section-' | append: section.id
-%}

<style>
  {{ section_id }} {
  	padding-top: {{ section.settings.padding_top_mobile }}px;
  	padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
     text-align: center;
  }

  @media (min-width: 992px) {
  	{{ section_id }} {
  		padding-top: {{ section.settings.padding_top }}px;
  		padding-bottom: {{ section.settings.padding_bottom }}px;
  	}
  }
   {{ section_id }} .sign-in-btn {
     display: inline-block;
     padding: 12px 32px;
     background-color: #1a4d2e;
     color: #ffffff;
     border-radius: 8px;
     font-size: 16px;
     font-weight: 500;
     text-decoration: none;
     transition: background-color 0.2s;
   }
   {{ section_id }} .sign-in-btn:hover {
     background-color: #143b22;
   }

   /* Target App Form Submit Button */
   ._formSubmitButton_cit2d_96,
   [data-testid="btn-form-submit"] {
     background-color: #1a4d2e !important;
     color: #ffffff !important;
     border-radius: 8px !important;
     font-size: 16px !important;
     font-weight: 600 !important;
     padding: 14px 32px !important;
     border: none !important;
     cursor: pointer !important;
     transition: background-color 0.2s !important;
     width: 100% !important;
     display: block !important;
     text-align: center !important;
   }

   ._formSubmitButton_cit2d_96:hover,
   [data-testid="btn-form-submit"]:hover {
     background-color: #143b22 !important;
   }

   .under-review-container {
     max-width: 600px;
     margin: 0 auto;
     padding: 40px 20px;
     background: #fdfdfd;
     border: 1px solid #e5e7eb;
     border-radius: 12px;
     box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
     text-align: center;
   }

   .under-review-container h2 {
     color: #1a4d2e;
     font-size: 24px;
     font-weight: 600;
     margin-bottom: 16px;
   }

   .under-review-container p {
     color: #4b5563;
     font-size: 16px;
     line-height: 1.6;
     margin: 0;
   }

   /* Hide apps section (form) when under review */
   .customer-under-review #shopify-section-apps,
   .customer-under-review .shopify-section-apps,
   .customer-under-review [id^="shopify-section-template--"][id$="__apps"] {
     display: none !important;
   }
</style>

<style>
  .wave-loader-wrapper {
    width: 100%;
    max-width: 600px;
    margin: 0 auto 30px auto;
    display: block;
  }
  .wave-item {
    width: 100%;
    height: 150px;
    background: #f6f7f8;
    background-image: linear-gradient(to right, #f6f7f8 0%, #edeef1 20%, #f6f7f8 40%, #f6f7f8 100%);
    background-repeat: no-repeat;
    background-size: 800px 100%;
    display: inline-block;
    position: relative;
    animation: wave-animation 1.2s linear infinite forwards;
    border-radius: 8px;
  }
  @keyframes wave-animation {
    0% { background-position: -468px 0; }
    100% { background-position: 468px 0; }
  }

  /* Prevent placeholder flicker during loading */
  .gf_placeholder,
  [id*="globo-formbuilder"] .gf_placeholder,
  #globo-formbuilder-container img,
  #globo-formbuilder-container [style*="background-image"] {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
  }
</style>

<div class="container {% if settings.section_animation %}scroll-trigger{% endif %}">
  <div class="wave-loader-wrapper" id="wave-loader">
    <div class="wave-item"></div>
  </div>

  {%- if customer -%}
    {%- if customer.tags contains 'approved' -%}
      <script>
        window.location.href = '/pages/dashboard';
      </script>

    {%- else -%}
      <div class="under-review-container">
        <h2>{{ section.settings.review_heading }}</h2>
        <p>{{ section.settings.review_text }}</p>
      </div>

      <script>
        document.body.classList.add('customer-under-review');

        if (window.location.pathname !== '/pages/sign-up') {
          window.location.href = '/pages/sign-up';
        }
      </script>
    {%- endif -%}
  {%- else -%}
    <div class="login-prompt">
      <p style="margin-bottom: 12px;">{{ section.settings.text }}</p>
      <a href="{{ routes.account_login_url }}?return_to=/pages/sign-up" class="sign-in-btn" id="sign-in-btn">
        {{ section.settings.button_label }}
      </a>
    </div>
  {%- endif -%}
</div>

<script>
  document.getElementById('sign-in-btn').addEventListener('click', function (e) {
    setTimeout(function () {
      document.getElementById('sign-in-btn').click();
    }, 2000);
  });
  setTimeout(function () {
    var loader = document.getElementById('wave-loader');
    if (loader) {
      loader.style.display = 'none';
    }
  }, 700);
  (function () {
    function styleButton(button) {
      if (button.closest('.login-prompt')) return; // Don't style our own if it were a button

      if (
        button.textContent.trim().toLowerCase() === 'submit' ||
        button.getAttribute('data-testid') === 'btn-form-submit'
      ) {
        button.style.setProperty('background-color', '#1a4d2e', 'important');
        button.style.setProperty('color', '#ffffff', 'important');
        button.style.setProperty('border-radius', '8px', 'important');
        button.style.setProperty('font-size', '16px', 'important');
        button.style.setProperty('font-weight', '500', 'important');
        button.style.setProperty('padding', '14px 32px', 'important');
        button.style.setProperty('border', 'none', 'important');
        button.style.setProperty('cursor', 'pointer', 'important');
        button.style.setProperty('transition', 'background-color 0.2s', 'important');

        // Hover effects
        button.onmouseenter = function () {
          this.style.setProperty('background-color', '#143b22', 'important');
        };
        button.onmouseleave = function () {
          this.style.setProperty('background-color', '#1a4d2e', 'important');
        };
      }
    }

    function searchForButtons(root) {
      if (!root) return;

      // Selectors to target the button
      const selectors = [
        '._formSubmitButton_cit2d_96',
        '[data-testid="btn-form-submit"]',
        'button[type="submit"]',
        'button',
      ];

      selectors.forEach((selector) => {
        const buttons = root.querySelectorAll(selector);
        buttons.forEach((button) => styleButton(button));
      });

      // Recurse into Shadow DOM if present
      const allElements = root.querySelectorAll('*');
      allElements.forEach((el) => {
        if (el.shadowRoot) {
          searchForButtons(el.shadowRoot);
        }
      });
    }

    function applySubmitStyles() {
      searchForButtons(document);
    }

    // Run on load and periodically to catch dynamically loaded app buttons
    document.addEventListener('DOMContentLoaded', applySubmitStyles);
    window.addEventListener('load', applySubmitStyles);

    // Check more frequently and for longer since apps with Shadow DOM load asynchronously
    const interval = setInterval(applySubmitStyles, 500);
    setTimeout(() => clearInterval(interval), 10000); // Check for 10 seconds
  })();
</script>

{% schema %}
{
  "name": "Sign In Button",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Prompt Text",
      "default": "Already have an account?"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Sign In Here"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 40,
      "unit": "px",
      "label": "Padding Bottom"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 10,
      "unit": "px",
      "label": "Padding Top Mobile"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "Padding Bottom Mobile"
    },
    {
      "type": "header",
      "content": "Under Review Settings"
    },
    {
      "type": "text",
      "id": "review_heading",
      "label": "Under Review Heading",
      "default": "Thank you for joining us"
    },
    {
      "type": "textarea",
      "id": "review_text",
      "label": "Under Review Text",
      "default": "Thank you for your submission. Your application is under review. After approval, you will receive a welcome email and You can sign in."
    }
  ],
  "presets": [
    {
      "name": "Sign In Button"
    }
  ]
}
{% endschema %}
