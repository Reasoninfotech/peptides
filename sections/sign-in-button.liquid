{%- liquid
	assign section_id = '#shopify-section-' | append: section.id
-%}

<style>
	{{ section_id }} {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    text-align: center;
	}

	@media (min-width: 992px) {
		{{ section_id }} {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
  {{ section_id }} .sign-in-btn {
    display: inline-block;
    padding: 12px 32px;
    background-color: #1a4d2e;
    color: #ffffff;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s;
  }
  {{ section_id }} .sign-in-btn:hover {
    background-color: #143b22;
  }

  /* Target App Form Submit Button */
  ._formSubmitButton_cit2d_96,
  [data-testid="btn-form-submit"] {
    background-color: #1a4d2e !important;
    color: #ffffff !important;
    border-radius: 8px !important;
    font-size: 16px !important;
    font-weight: 600 !important;
    padding: 14px 32px !important;
    border: none !important;
    cursor: pointer !important;
    transition: background-color 0.2s !important;
    width: 100% !important;
    display: block !important;
    text-align: center !important;
  }

  ._formSubmitButton_cit2d_96:hover,
  [data-testid="btn-form-submit"]:hover {
    background-color: #143b22 !important;
  }
</style>

<div class="container {% if settings.section_animation %}scroll-trigger{% endif %}">
  <div class="login-prompt">
    <p style="margin-bottom: 12px;">{{ section.settings.text }}</p>
    <a href="{{ routes.storefront_login_url }}&return_to=/pages/dashboard" class="sign-in-btn">
      {{ section.settings.button_label }}
    </a>
  </div>
</div>

<script>
  (function() {
    function styleButton(button) {
      if (button.closest('.login-prompt')) return; // Don't style our own if it were a button
      
      if (button.textContent.trim().toLowerCase() === 'submit' || button.getAttribute('data-testid') === 'btn-form-submit') {
        button.style.setProperty('background-color', '#1a4d2e', 'important');
        button.style.setProperty('color', '#ffffff', 'important');
        button.style.setProperty('border-radius', '8px', 'important');
        button.style.setProperty('font-size', '16px', 'important');
        button.style.setProperty('font-weight', '500', 'important');
        button.style.setProperty('padding', '14px 32px', 'important');
        button.style.setProperty('border', 'none', 'important');
        button.style.setProperty('cursor', 'pointer', 'important');
        button.style.setProperty('transition', 'background-color 0.2s', 'important');

        // Hover effects
        button.onmouseenter = function() {
          this.style.setProperty('background-color', '#143b22', 'important');
        };
        button.onmouseleave = function() {
          this.style.setProperty('background-color', '#1a4d2e', 'important');
        };
      }
    }

    function searchForButtons(root) {
      if (!root) return;
      
      // Selectors to target the button
      const selectors = [
        '._formSubmitButton_cit2d_96',
        '[data-testid="btn-form-submit"]',
        'button[type="submit"]',
        'button'
      ];
      
      selectors.forEach(selector => {
        const buttons = root.querySelectorAll(selector);
        buttons.forEach(button => styleButton(button));
      });

      // Recurse into Shadow DOM if present
      const allElements = root.querySelectorAll('*');
      allElements.forEach(el => {
        if (el.shadowRoot) {
          searchForButtons(el.shadowRoot);
        }
      });
    }

    function applySubmitStyles() {
      searchForButtons(document);
    }

    // Run on load and periodically to catch dynamically loaded app buttons
    document.addEventListener('DOMContentLoaded', applySubmitStyles);
    window.addEventListener('load', applySubmitStyles);
    
    // Check more frequently and for longer since apps with Shadow DOM load asynchronously
    const interval = setInterval(applySubmitStyles, 500);
    setTimeout(() => clearInterval(interval), 10000); // Check for 10 seconds
  })();
</script>

{% schema %}
{
  "name": "Sign In Button",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Prompt Text",
      "default": "Already have an account?"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Sign In Here"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 40,
      "unit": "px",
      "label": "Padding Bottom"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 10,
      "unit": "px",
      "label": "Padding Top Mobile"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 20,
      "unit": "px",
      "label": "Padding Bottom Mobile"
    }
  ],
  "presets": [
    {
      "name": "Sign In Button"
    }
  ]
}
{% endschema %}
