{%- liquid
	assign section_id = '#shopify-section-' | append: section.id

	if localization.available_countries.size > 1
		assign country_selector = true
	endif

	if localization.available_languages.size > 1
		assign language_selector = true
	endif
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	@media (min-width: 992px) {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}

	{%- if language_selector and country_selector -%}
		{{ section_id }} .language-selector {
			padding-right: 1.2rem;
			margin-right: 0.8rem;
		}

		{{ section_id }} .language-selector:before {
			content: "";
			background-color: currentcolor;
			position: absolute;
			font-weight: bold;
			width: 0.4rem;
			height: 0.2rem;
			opacity: 0.4;
			right: 0;
		}
	{%- endif -%}
</style>

{%- capture content -%}
	{%- for block in section.blocks -%}
		{%- assign image = block.settings.icon_img -%}

		<div class="message-box unity-slide"{% if request.design_mode %} data-id="{{ block.id }}" data-index="{{ forloop.index0 }}"{% endif %} {{ block.shopify_attributes }}>
			<div class="slider-image adapt-media">
				<div class="icon-image{% if settings.image_lazy and image %} lazy-image{% endif %}">
					{%- liquid
						if image != blank
							render 'lazy-image', image: image, width: 30
						endif
					-%}
				</div>
			</div>

			<div class="title">{{- block.settings.title -}}</div>
		</div>
	{%- endfor -%}
{%- endcapture -%}

{%- capture language_country_selector -%}
	{%- if section.settings.show_country_language_selector and language_selector or country_selector -%}
		<div class="localization-selector-wrapper">
			<button class="localization-selector">
				{%- if language_selector -%}
					<div class="selector-option language-selector text-uppercase">
						<input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
						<span class="sr-only">{{- 'localization.language_label' | t -}}</span>
						<span class="icon-map">{%- render 'icon', code: 'locale' -%}</span>
						{{- localization.language.endonym_name | capitalize -}}
					</div>
				{%- endif -%}

				{% comment %} Country {% endcomment %}
				{%- if country_selector -%}
					<div class="selector-option currency-selector text-uppercase">
						<input type="hidden" name="currency_code" value="{{ localization.country.currency.iso_code }}">
						<span class="sr-only">{{- 'localization.currency_label' | t -}}</span>
						<span class="icon-map">{%- render 'icon', code: 'currency' -%}</span>
						<span class="country-code">{{- localization.country.iso_code -}}</span>
						({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})
					</div>
				{%- endif -%}
			</button>
		</div>
	{%- endif -%}
{%- endcapture -%}

<div class="section-wrapper color-{{ section.settings.color_scheme }}{% if section.settings.show_line_separator %} bottom-border{% endif %}">
	<div class="container">
		<div class="announcement-bar-inner">
			{%- liquid
				if section.settings.show_social
					render 'social-media'
				endif
			-%}

			{%- if section.blocks.size >= 1 -%}
				<div class="announcement-bar-content">
					{%- if section.blocks.size == 1 -%}
						 	{{- content -}}
					{%- elsif section.blocks.size > 1 -%}
						<div class="announcement-bar-content">
							<unity-slider class="unity-slider">
								<template data-options>
									{
										"loop": true,
										"_autoplay": {{ section.settings.delay | times: 1000 }},
										"_disableOnInteraction": false,
										"_pauseOnMouseEnter": true,
										"align": "start",
										"_autoheight": true,
										"_fade": false,
										"speed": 10,
										"_prevBtn": "{{ section_id }} .unity-button-prev",
										"_nextBtn": "{{ section_id }} .unity-button-next",
										"_dotsNode": "{{ section_id }} .unity-dots"
									}
								</template>

								<div class="unity-arrows">
									<button class="unity-button unity-button-prev" title ="{{ 'general.unity.prev' | t }}-announ" aria-label="{{ 'general.unity.prev' | t }}-announ" id="{{ 'general.unity.prev' | t }}-announ" aria-labelledby="{{ 'general.unity.prev' | t }}-announ" disabled>
										{%- render 'icon', code: 'chevron-left' -%}
									</button>
								</div>

								<div class="unity-slider-viewport">
									<div class="unity-slider-container">
										{{- content -}}
									</div>
								</div>

								<div class="unity-arrows">
									<button class="unity-button unity-button-next" title ="{{ 'general.unity.next' | t }}-announ" aria-label="{{ 'general.unity.next' | t }}-announ" id="{{ 'general.unity.next' | t }}-announ" aria-labelledby="{{ 'general.unity.next' | t }}-announ" disabled>
										{%- render 'icon', code: 'chevron-right' -%}
									</button>
								</div>
							</unity-slider>
						</div>
					{%- endif -%}
				</div>
			{%- endif -%}

			{{- language_country_selector -}}
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.announcement-bar.name",
	"class": "announcement-bar-section",
	"enabled_on": {
		"groups": ["header"]
	},
	"settings": [
		{
			"type": "checkbox",
			"id": "autoplay",
			"default": false,
			"label": "t:general.slider.autoplay.label"
		},
		{
			"type": "range",
			"id": "delay",
			"min": 3,
			"max": 20,
			"step": 1,
			"default": 5,
			"label": "t:general.slider.delay.label"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "checkbox",
			"id": "show_line_separator",
			"default": true,
			"label": "t:sections.announcement-bar.settings.show_line_separator.label"
		},
		{
			"type": "header",
			"content": "t:sections.announcement-bar.settings.heading_utilities.content"
		},
		{
			"type": "paragraph",
			"content": "t:sections.announcement-bar.settings.paragraph.content"
		},
		{
			"type": "checkbox",
			"id": "show_social",
			"default": false,
			"label": "t:sections.footer.blocks.info.settings.show_social.label"
		},
		{
			"type": "checkbox",
			"id": "show_country_language_selector",
			"default": true,
			"label": "t:general.shopify.show_currency_and_language.label"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 13,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 13,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 13,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 13,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"blocks": [
		{
			"type": "slide",
			"name": "t:general.slider.slide.label",
			"settings": [
				{
					"type":"image_picker",
					"id":"icon_img",
					"label": "t:general.image.label"
				},
				{
					"type": "inline_richtext",
					"id": "title",
					"default": "The title for your item",
					"label": "t:general.typography.heading.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.announcement-bar.name",
			"blocks": [
				{
					"type": "slide"
				},
				{
					"type": "slide"
				}
			]
		}
	]
}
{% endschema %}
