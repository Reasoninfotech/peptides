{% liquid
assign delay_time = section.settings.delay_time | times: 1000
assign popup_id = 'agePopup-' | append: section.id
%}

<style>
    .age-verification-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2147483647;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.4s;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        padding: 20px;
    }

    .age-verification-overlay.show {
        opacity: 1;
        visibility: visible;
    }

    .age-modal {
        background: #ffffff;
        max-width: 550px;
        width: 100%;
        border-radius: 12px;
        padding: 35px;
        position: relative;
        box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        text-align: left;
        transform: translateY(20px);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        max-height: 90vh;
        overflow-y: auto;
    }

    .age-verification-overlay.show .age-modal {
        transform: translateY(0);
    }

    .age-close {
        position: absolute;
        top: 15px;
        right: 20px;
        font-size: 32px;
        line-height: 1;
        cursor: pointer;
        color: #444;
        transition: color 0.2s;
        user-select: none;
    }

    .age-close:hover {
        color: #000;
    }

    .age-header-img {
        width: 100%;
        height: auto;
        margin-bottom: 20px;
        border-radius: 8px;
        display: block;
    }

    .age-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 15px;
        color: #000;
        line-height: 1.2;
    }

    .age-content {
        font-size: 15px;
        line-height: 1.5;
        color: #333;
        margin-bottom: 20px;
    }

    .age-content p {
        margin: 0 0 10px 0;
    }

    .age-content strong {
        display: block;
        margin-bottom: 5px;
        color: #000;
    }

    .age-question {
        font-size: 18px;
        font-weight: 700;
        margin: 25px 0 15px;
        color: #000;
    }

    .age-buttons {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
    }

    .age-btn {
        flex: 1;
        padding: 12px 20px;
        border-radius: 50px;
        border: 1.5px solid #000;
        background: #fff;
        cursor: pointer;
        font-weight: 600;
        font-size: 16px;
        letter-spacing: 0.5px;
        transition: all 0.2s ease;
        text-align: center;
        color: #000;
    }

    .age-btn:hover {
        background: #f8f8f8;
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    }

    .age-btn.yes-btn:active {
        transform: translateY(0);
    }

    .age-footer {
        font-size: 12px;
        line-height: 1.5;
        color: #666;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: flex-start;
        border-top: 1px solid #eee;
        padding-top: 15px;
    }

    .age-error-message {
        display: none;
        color: #d93025;
        font-size: 13px;
        font-weight: 500;
        width: 100%;
    }

    .age-checkbox {
        width: 16px;
        height: 16px;
        margin-top: 2px;
        cursor: pointer;
        flex-shrink: 0;
    }

    .age-footer label {
        cursor: pointer;
        user-select: none;
    }

    @media screen and (max-width: 480px) {
        .age-modal {
            padding: 25px;
        }

        .age-buttons {
            flex-direction: column;
        }

        .age-title {
            font-size: 20px;
        }
    }
</style>

<div class="age-verification-overlay" id="{{ popup_id }}" data-delay="{{ delay_time }}">
    <div class="age-modal">
        <div class="age-close" onclick="this.closest('.age-verification-overlay').classList.remove('show')">&times;
        </div>

        {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 800 }}" alt="Verification" class="age-header-img"
            loading="lazy">
        {% endif %}

        <div class="age-title">{{ section.settings.heading }}</div>

        <div class="age-content">
            {{ section.settings.description | newline_to_br }}
        </div>

        <div class="age-question">{{ section.settings.question }}</div>

        <div class="age-buttons">
            <button class="age-btn yes-btn">{{ section.settings.approve_button }}</button>
            <button class="age-btn no-btn">{{ section.settings.decline_button }}</button>
        </div>

        <div class="age-footer">
            <div class="age-error-message">Please check the checkbox first.</div>
            <input type="checkbox" id="age-confirm-{{ section.id }}" class="age-checkbox">
            <label for="age-confirm-{{ section.id }}">
                {{ section.settings.disclaimer }}
            </label>
        </div>
    </div>
</div>

<script>
    (function () {
        function initAgePopup() {
            const popup = document.getElementById('{{ popup_id }}');
            if (!popup) return;

            const isDesignMode = window.Shopify && window.Shopify.designMode;
            const storageKey = 'age_verified_' + '{{ section.id }}';
            const verified = localStorage.getItem(storageKey);

            // Control display logic
            if (!verified || isDesignMode) {
                const delay = isDesignMode ? 300 : (parseInt(popup.dataset.delay) || 1000);
                setTimeout(() => {
                    popup.classList.add('show');
                }, delay);
            }

            const yesBtn = popup.querySelector('.yes-btn');
            const noBtn = popup.querySelector('.no-btn');
            const checkbox = popup.querySelector('.age-checkbox');

            yesBtn?.addEventListener('click', function () {
                const errorMsg = popup.querySelector('.age-error-message');
                if (!checkbox.checked) {
                    if (errorMsg) errorMsg.style.display = 'block';
                    return;
                }
                if (errorMsg) errorMsg.style.display = 'none';
                localStorage.setItem(storageKey, 'true');
                popup.classList.remove('show');
            });

            checkbox?.addEventListener('change', function () {
                const errorMsg = popup.querySelector('.age-error-message');
                if (checkbox.checked && errorMsg) {
                    errorMsg.style.display = 'none';
                }
            });

            noBtn?.addEventListener('click', function () {
                window.location.href = '{{ section.settings.decline_url | default: "https://www.google.com" }}';
            });

            // Show popup when section is selected in editor
            if (isDesignMode) {
                document.addEventListener('shopify:section:select', (e) => {
                    if (e.detail.sectionId === '{{ section.id }}') {
                        popup.classList.add('show');
                    }
                });
            }
        }

        // Immediate or deferred init
        if (document.readyState === 'complete' || document.readyState === 'interactive') {
            initAgePopup();
        } else {
            window.addEventListener('load', initAgePopup);
        }
    })();
</script>

{% schema %}
{
"name": "Age Verification",
"settings": [
{
"type": "image_picker",
"id": "image",
"label": "Header Image (Optional)"
},
{
"type": "range",
"id": "delay_time",
"label": "Popup delay (seconds)",
"default": 1,
"min": 0,
"max": 10,
"step": 1
},
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Account Information"
},
{
"type": "textarea",
"id": "description",
"label": "Content Text",
"default": "<strong>Best Practices for Storing Research Peptides</strong>\\nResearch peptides are supplied for controlled laboratory use, with clear labeling, consistent purity, and full batch traceability to support reliable experimental outcomes."
},
{
"type": "text",
"id": "question",
"label": "Question",
"default": "Are you over 21 years of age?"
},
{
"type": "text",
"id": "approve_button",
"label": "Approve Button Text",
"default": "Yes"
},
{
"type": "text",
"id": "decline_button",
"label": "Decline Button Text",
"default": "No"
},
{
"type": "url",
"id": "decline_url",
"label": "Decline Redirect URL"
},
{
"type": "textarea",
"id": "disclaimer",
"label": "Disclaimer Text",
"default": "I confirm that I am 21+ years of age, have read and agree to the Terms & Conditions, Chargeback & Dispute Policy, and Research Use Only Policy."
}
],
"presets": [
{
"name": "Age Verification"
}
]
}
{% endschema %}