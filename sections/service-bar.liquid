{%- liquid
  assign section_id = '#shopify-section-' | append: section.id
-%}

<style>
  {{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    color: {{ section.settings.text_color }};
  }

  .service-bar__container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 30px 120px;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .service-bar__item {
    display: flex;
    align-items: center;
    gap: 20px;
    flex: 0 1 auto;
    transition: transform 0.3s ease;
  }

  .service-bar__item:hover {
    transform: translateY(-2px);
  }

  .service-bar__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    color: {{ section.settings.icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.3s ease;
  }

  .service-bar__icon svg {
    width: 100%;
    height: 100%;
    display: block;
    stroke-width: 1.25px;
  }

  .service-bar__content {
    display: flex;
    flex-direction: column;
  }

  .service-bar__title {
    font-size: 15px;
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
    line-height: 1.1;
    letter-spacing: 0.05em;
    color: {{ section.settings.text_color }};
  }

  .service-bar__subtitle {
    font-size: 13px;
    margin: 4px 0 0 0;
    opacity: 0.75;
    line-height: 1.1;
    color: {{ section.settings.text_color }};
  }

  .service-bar__image-only {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-bar__img {
    max-height: 50px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 1440px) {
    .service-bar__container {
      gap: 30px 40px;
    }
  }

  @media (max-width: 767px) {
    .service-bar__container {
      gap: 20px 10px;
      padding: 0 15px;
      justify-content: flex-start;
    }
    .service-bar__item {
       flex: 0 0 calc(50% - 5px);
       gap: 10px;
       min-width: 0;
    }
    .service-bar__icon {
      width: 32px;
      height: 32px;
      flex-shrink: 0;
    }
    .service-bar__content {
      min-width: 0;
    }
    .service-bar__title {
      font-size: 11px;
      word-break: break-word;
    }
    .service-bar__subtitle {
      font-size: 10px;
      line-height: 1.2;
    }
  }
</style>

<section class="service-bar-section">
  <div class="service-bar__container">
    {%- for block in section.blocks -%}
      <div class="service-bar__item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <div class="service-bar__image-only">
            {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'service-bar__img' }}
          </div>
        {%- else -%}
          <div class="service-bar__icon">
            {%- if block.settings.custom_icon != blank -%}
              {{ block.settings.custom_icon }}
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'shipping' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                {%- when 'tested' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
                {%- when 'support' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
                {%- when 'secure' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              {%- endcase -%}
            {%- endif -%}
          </div>
          <div class="service-bar__content">
            <h3 class="service-bar__title">{{ block.settings.title }}</h3>
            <p class="service-bar__subtitle">{{ block.settings.subtitle }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Service Bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1A4D2E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#f3d05d"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Service Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image Icon",
          "info": "If selected, this image will be shown and it will hide the SVG icon, title, and subtitle."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping Box" },
            { "value": "tested", "label": "Shield Check" },
            { "value": "support", "label": "Support Bubble" },
            { "value": "secure", "label": "Secure Lock" }
          ],
          "default": "shipping"
        },
        {
          "type": "html",
          "id": "custom_icon",
          "label": "Custom SVG Icon",
          "info": "Overrides the select icon above."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Service description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Bar",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "shipping",
            "title": "FAST SHIPPING",
            "subtitle": "2-3 business days"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "tested",
            "title": "3RD PARTY TESTED",
            "subtitle": "Independent verification"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "support",
            "title": "RESEARCH SUPPORT",
            "subtitle": "Expert guidance"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "secure",
            "title": "SECURE PAYMENT",
            "subtitle": "Encrypted transactions"
          }
        }
      ]
    }
  ]
}
{% endschema %}
