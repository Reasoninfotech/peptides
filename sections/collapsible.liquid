{%- liquid
	assign section_id   = '#shopify-section-' | append: section.id
	assign animation    = settings.section_animation
	assign heading      = section.settings.heading_text
	assign heading_size = section.settings.heading_size
	assign caption      = section.settings.caption
	assign text         = section.settings.text
	assign image        = section.settings.image
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	@media (min-width: 992px) {
		{{ section_id }} .collapsible-wrap {
			width: {{ section.settings.width }}%;
			margin: 0 auto;
		}

		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
</style>

<div class="section-wrapper color-{{ section.settings.color_scheme }}">
	<div class="container">
		<div class="collapsible-wrap">
			<div class="collapsible-top">
				{%- if caption != blank -%}
					<div class="sub-heading rte">{{- caption -}}</div>
				{%- endif -%}

				{%- if heading != blank -%}
					<h2 class="heading rte {{ heading_size }}">{{- heading -}}</h2>
				{%- endif -%}

				{%- if text != blank -%}
					<div class="description rte">{{- text -}}</div>
				{%- endif -%}
			</div>

			<div  class="collapsible-content-wrap{% if image != blank %} has-image {{section.settings.layout}}-first{% endif %}">
				{% if image != blank %}
					<div class="collapsible-image">
						<div class="{{ section.settings.image_ratio }}-media{% if settings.image_lazy and image != blank %} lazy-image{% endif %}{% if animation %} scroll-trigger{% endif %}">
							{%- liquid
								render 'lazy-image', image: image, width: 740, class: 'border-large'
							-%}
						</div>
					</div>
				{% endif %}

				<div  class="collapsible-items">
					{%- for block in section.blocks -%}
						{%- case block.type -%}
							{%- when '@app' -%}
								<div class="collapsible-item{% if animation %} scroll-trigger{% endif %}" {{ block.shopify_attributes }}>
									{%- render block -%}
								</div>
							{%- when 'tab' -%}
								<details class="collapsible-item{% if animation %} scroll-trigger{% endif %}" {{ block.shopify_attributes }}>
									<summary class="collapsible-summary" aria-expanded="false">
										<p class="collapsible-title">
											{%- liquid
												if block.settings.icon != 'none'
													render 'icon-accordion', icon: block.settings.icon
												endif

												echo block.settings.heading | default: block.settings.page.title | replace: '{product_title}', product.title
											-%}
										</p>

										<span class="accordion-caret">
											<span class="plus">
												{%- render 'icon', code: 'plus' -%}
											</span>

											<span class="minus">
												{%- render 'icon', code: 'minus' -%}
											</span>
										</span>
									</summary>

									<div class="collapsible-content details-content rte">
										{%- liquid
											echo block.settings.content
											echo block.settings.page.content
										-%}
									</div>
								</details>
						{%- endcase -%}
					{%- endfor -%}
				</div>
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.collapsible.name",
	"class": "collapsible-section has-accordion-style",
	"tag": "section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
