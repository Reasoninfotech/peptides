				},
				{
					"value": "portrait",
					"label": "t:general.image.ratio.option_2.label"
				},
				{
					"value": "square",
					"label": "t:general.image.ratio.option_3.label"
				}
			],
			"default": "adapt",
			"label": "t:general.image.ratio.label"
		},
		{
			"type": "select",
			"id": "layout",
			"options": [
				{
					"value": "image",
					"label": "t:sections.collapsible.settings.layout.option_1.label"
				},
				{
					"value": "text",
					"label": "t:sections.collapsible.settings.layout.option_2.label"
				}
			],
			"default": "text",
			"label": "t:sections.collapsible.settings.layout.label",
			"info": "t:sections.collapsible.settings.layout.info"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"blocks": [
