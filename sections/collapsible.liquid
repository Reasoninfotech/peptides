			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "range",
			"id": "width",
			"min": 40,
			"max": 100,
			"step": 1,
			"default": 100,
			"unit": "%",
			"label": "t:sections.collapsible.settings.width.label"
		},
		{
			"type": "text",
			"id": "caption",
			"default": "Caption",
			"label": "t:general.typography.caption.label"
		},
		{
