			"id": "heading_text",
			"default": "Collapsible Content",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h6",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h5",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h5",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "richtext",
			"id": "text",
			"default": "<p>This is a description for Collapsible content section.</p>",
			"label": "t:general.typography.description.label"
		},
		{
			"type": "header",
			"content": "t:sections.collapsible.settings.image_layout.content"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "t:general.image.label"
		},
		{
			"type": "select",
			"id": "image_ratio",
			"options": [
				{
					"value": "adapt",
