{% comment %}
  Section: Enhance Research / Image + Text Banner
  Theme: Unity (Shopify)
  Features:
    - Responsive padding (mobile/tablet/desktop)
    - Image with left/right position toggle
    - Title, content, button with color + font-size per breakpoint
    - Full schema settings
{% endcomment %}

{%- liquid
  assign section_id   = section.id
  assign img_position = section.settings.image_position
  assign image        = section.settings.image
  assign title        = section.settings.title
  assign content      = section.settings.content
  assign btn_label    = section.settings.button_label
  assign btn_url      = section.settings.button_url
-%}

<style>
  /* ─── CSS Variables ───────────────────────────────────── */
  #shopify-section-{{ section_id }} {
    --title-color-mobile:   {{ section.settings.title_color_mobile }};
    --title-color-tablet:   {{ section.settings.title_color_tablet }};
    --title-color-desktop:  {{ section.settings.title_color_desktop }};

    --title-size-mobile:    {{ section.settings.title_size_mobile }}px;
    --title-size-tablet:    {{ section.settings.title_size_tablet }}px;
    --title-size-desktop:   {{ section.settings.title_size_desktop }}px;

    --content-color-mobile:  {{ section.settings.content_color_mobile }};
    --content-color-tablet:  {{ section.settings.content_color_tablet }};
    --content-color-desktop: {{ section.settings.content_color_desktop }};

    --content-size-mobile:   {{ section.settings.content_size_mobile }}px;
    --content-size-tablet:   {{ section.settings.content_size_tablet }}px;
    --content-size-desktop:  {{ section.settings.content_size_desktop }}px;

    --btn-bg-mobile:    {{ section.settings.btn_bg_mobile }};
    --btn-bg-tablet:    {{ section.settings.btn_bg_tablet }};
    --btn-bg-desktop:   {{ section.settings.btn_bg_desktop }};

    --btn-color-mobile:  {{ section.settings.btn_color_mobile }};
    --btn-color-tablet:  {{ section.settings.btn_color_tablet }};
    --btn-color-desktop: {{ section.settings.btn_color_desktop }};

    --btn-size-mobile:   {{ section.settings.btn_size_mobile }}px;
    --btn-size-tablet:   {{ section.settings.btn_size_tablet }}px;
    --btn-size-desktop:  {{ section.settings.btn_size_desktop }}px;

    --section-bg:        {{ section.settings.section_bg }};
    --img-border-radius: {{ section.settings.image_border_radius }}px;
    --gap:               {{ section.settings.column_gap }}px;

    /* Padding Mobile */
    --pt-mob: {{ section.settings.padding_top_mobile }}px;
    --pb-mob: {{ section.settings.padding_bottom_mobile }}px;
    --pl-mob: {{ section.settings.padding_left_mobile }}px;
    --pr-mob: {{ section.settings.padding_right_mobile }}px;

    /* Padding Tablet */
    --pt-tab: {{ section.settings.padding_top_tablet }}px;
    --pb-tab: {{ section.settings.padding_bottom_tablet }}px;
    --pl-tab: {{ section.settings.padding_left_tablet }}px;
    --pr-tab: {{ section.settings.padding_right_tablet }}px;

    /* Padding Desktop */
    --pt-dsk: {{ section.settings.padding_top_desktop }}px;
    --pb-dsk: {{ section.settings.padding_bottom_desktop }}px;
    --pl-dsk: {{ section.settings.padding_left_desktop }}px;
    --pr-dsk: {{ section.settings.padding_right_desktop }}px;
  }

  /* ─── Section Wrapper ────────────────────────────────── */
  .er-section-{{ section_id }} {
    background-color: var(--section-bg);
    padding-top:    var(--pt-mob);
    padding-bottom: var(--pb-mob);
    padding-left:   var(--pl-mob);
    padding-right:  var(--pr-mob);
    box-sizing: border-box;
  }

  /* ─── Inner Container ────────────────────────────────── */
  .er-inner-{{ section_id }} {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  /* ─── Image Column ───────────────────────────────────── */
  .er-image-col-{{ section_id }} {
    width: 100%;
    flex-shrink: 0;
  }

  .er-image-col-{{ section_id }} img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--img-border-radius);
    object-fit: cover;
  }

  .er-image-placeholder-{{ section_id }} {
    width: 100%;
    aspect-ratio: 4/3;
    background: #e8e8e8;
    border-radius: var(--img-border-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 14px;
  }

  /* ─── Content Column ─────────────────────────────────── */
  .er-content-col-{{ section_id }} {
    width: 100%;
  }

  /* ─── Title ──────────────────────────────────────────── */
  .er-title-{{ section_id }} {
    margin: 0 0 16px;
    padding: 0;
    color: var(--title-color-mobile);
    font-size: var(--title-size-mobile);
    line-height: 1.2;
    font-weight: {{ section.settings.title_font_weight }};
    text-align: {{ section.settings.text_align_mobile }};
  }

  /* ─── Content ────────────────────────────────────────── */
  .er-content-{{ section_id }} {
    margin: 0 0 24px;
    padding: 0;
    color: var(--content-color-mobile);
    font-size: var(--content-size-mobile);
    line-height: 1.7;
    text-align: {{ section.settings.text_align_mobile }};
  }

  .er-content-{{ section_id }} p {
    margin: 0 0 12px;
  }

  .er-content-{{ section_id }} p:last-child {
    margin-bottom: 0;
  }

  /* ─── Button Wrapper ─────────────────────────────────── */
  .er-btn-wrap-{{ section_id }} {
    text-align: {{ section.settings.text_align_mobile }};
  }

  /* ─── Button ─────────────────────────────────────────── */
  .er-btn-{{ section_id }} {
    display: inline-block;
    background-color: var(--btn-bg-mobile);
    color: var(--btn-color-mobile);
    font-size: var(--btn-size-mobile);
    font-weight: {{ section.settings.btn_font_weight }};
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    border-radius: {{ section.settings.btn_border_radius }}px;
    text-decoration: none;
    border: {{ section.settings.btn_border_width }}px solid {{ section.settings.btn_border_color }};
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
    line-height: 1;
  }

  .er-btn-{{ section_id }}:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  /* ─── Tablet (≥ 768px) ───────────────────────────────── */
  @media (min-width: 768px) {
    .er-section-{{ section_id }} {
      padding-top:    var(--pt-tab);
      padding-bottom: var(--pb-tab);
      padding-left:   var(--pl-tab);
      padding-right:  var(--pr-tab);
    }

    .er-title-{{ section_id }} {
      color:     var(--title-color-tablet);
      font-size: var(--title-size-tablet);
      text-align: {{ section.settings.text_align_tablet }};
    }

    .er-content-{{ section_id }} {
      color:     var(--content-color-tablet);
      font-size: var(--content-size-tablet);
      text-align: {{ section.settings.text_align_tablet }};
    }

    .er-btn-wrap-{{ section_id }} {
      text-align: {{ section.settings.text_align_tablet }};
    }

    .er-btn-{{ section_id }} {
      background-color: var(--btn-bg-tablet);
      color:            var(--btn-color-tablet);
      font-size:        var(--btn-size-tablet);
    }
  }

  /* ─── Desktop (≥ 1024px) ─────────────────────────────── */
  @media (min-width: 1024px) {
    .er-section-{{ section_id }} {
      padding-top:    var(--pt-dsk);
      padding-bottom: var(--pb-dsk);
      padding-left:   var(--pl-dsk);
      padding-right:  var(--pr-dsk);
      gap: var(--gap);
    }

    .er-inner-{{ section_id }} {
      flex-direction: row;
      align-items: center;
    }

    /* Image LEFT */
    .er-inner-{{ section_id }}.img-left .er-image-col-{{ section_id }}   { order: 1; }
    .er-inner-{{ section_id }}.img-left .er-content-col-{{ section_id }} { order: 2; }

    /* Image RIGHT */
    .er-inner-{{ section_id }}.img-right .er-image-col-{{ section_id }}  { order: 2; }
    .er-inner-{{ section_id }}.img-right .er-content-col-{{ section_id }} { order: 1; }

    .er-image-col-{{ section_id }} {
      width: {{ section.settings.image_width_desktop }}%;
    }

    .er-content-col-{{ section_id }} {
      width: {{ 100 | minus: section.settings.image_width_desktop }}%;
      padding-left: {% if img_position == 'left' %}{{ section.settings.content_padding_desktop }}px{% else %}0{% endif %};
      padding-right: {% if img_position == 'right' %}{{ section.settings.content_padding_desktop }}px{% else %}0{% endif %};
    }

    .er-title-{{ section_id }} {
      color:     var(--title-color-desktop);
      font-size: var(--title-size-desktop);
      text-align: {{ section.settings.text_align_desktop }};
    }

    .er-content-{{ section_id }} {
      color:     var(--content-color-desktop);
      font-size: var(--content-size-desktop);
      text-align: {{ section.settings.text_align_desktop }};
    }

    .er-btn-wrap-{{ section_id }} {
      text-align: {{ section.settings.text_align_desktop }};
    }

    .er-btn-{{ section_id }} {
      background-color: var(--btn-bg-desktop);
      color:            var(--btn-color-desktop);
      font-size:        var(--btn-size-desktop);
    }
  }
</style>

<section class="er-section-{{ section_id }}">
  <div class="er-inner-{{ section_id }} img-{{ img_position }}">

    {%- comment %} ── IMAGE COLUMN ── {%- endcomment %}
    <div class="er-image-col-{{ section_id }}">
      {%- if image != blank -%}
        {%- assign img_sizes = section.settings.image_width_desktop | append: 'vw, 100vw' -%}
        {%- assign img_sizes = '(min-width: 1024px) ' | append: img_sizes -%}
        {{ image | image_url: width: 1200 | image_tag: loading: "lazy", widths: "400,600,800,1000,1200", sizes: img_sizes }}
      {%- else -%}
        <div class="er-image-placeholder-{{ section_id }}">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    {%- comment %} ── CONTENT COLUMN ── {%- endcomment %}
    <div class="er-content-col-{{ section_id }}">

      {%- unless title == blank -%}
        <{{ section.settings.title_tag }} class="er-title-{{ section_id }}">
          {{ title }}
        </{{ section.settings.title_tag }}>
      {%- endunless -%}

      {%- unless content == blank -%}
        <div class="er-content-{{ section_id }}">
          {{ content }}
        </div>
      {%- endunless -%}

      {%- if btn_label != blank and btn_url != blank -%}
        <div class="er-btn-wrap-{{ section_id }}">
          <a href="{{ btn_url }}" class="er-btn-{{ section_id }}">
            {{ btn_label }}
          </a>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>


{% schema %}
{
  "name": "Image + Text Banner",
  "tag": "section",
  "class": "section-image-text-banner",
  "settings": [

    {
      "type": "header",
      "content": "── Layout & Container ──────────────────"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container Max Width (px)",
      "min": 600,
      "max": 1600,
      "step": 10,
      "default": 1200
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column Gap (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },

    {
      "type": "header",
      "content": "── Section Padding · Mobile ────────────"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top – Mobile (px)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom – Mobile (px)",
      "min": 0, "max": 100, "step": 1, "default": 40
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "label": "Padding Left – Mobile (px)",
      "min": 0, "max": 100, "step": 1, "default": 16
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "label": "Padding Right – Mobile (px)",
      "min": 0, "max": 100, "step": 1, "default": 16
    },

    {
      "type": "header",
      "content": "── Section Padding · Tablet ────────────"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding Top – Tablet (px)",
      "min": 0, "max": 100, "step": 1, "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom – Tablet (px)",
      "min": 0, "max": 100, "step": 1, "default": 56
    },
    {
      "type": "range",
      "id": "padding_left_tablet",
      "label": "Padding Left – Tablet (px)",
      "min": 0, "max": 100, "step": 1, "default": 24
    },
    {
      "type": "range",
      "id": "padding_right_tablet",
      "label": "Padding Right – Tablet (px)",
      "min": 0, "max": 100, "step": 1, "default": 24
    },

    {
      "type": "header",
      "content": "── Section Padding · Desktop ───────────"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top – Desktop (px)",
      "min": 0, "max": 100, "step": 1, "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom – Desktop (px)",
      "min": 0, "max": 100, "step": 1, "default": 80
    },
    {
      "type": "range",
      "id": "padding_left_desktop",
      "label": "Padding Left – Desktop (px)",
      "min": 0, "max": 100, "step": 1, "default": 40
    },
    {
      "type": "range",
      "id": "padding_right_desktop",
      "label": "Padding Right – Desktop (px)",
      "min": 0, "max": 100, "step": 1, "default": 40
    },

    {
      "type": "header",
      "content": "── Image Settings ──────────────────────"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position (Desktop)",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "Image Column Width – Desktop (%)",
      "min": 20, "max": 70, "step": 1, "default": 45
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image Border Radius (px)",
      "min": 0, "max": 60, "step": 2, "default": 12
    },
    {
      "type": "range",
      "id": "content_padding_desktop",
      "label": "Content Inner Padding – Desktop (px)",
      "min": 0, "max": 80, "step": 4, "default": 32
    },

    {
      "type": "header",
      "content": "── Title Settings ──────────────────────"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Enhance your research"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Title HTML Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "p",  "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-Bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra-Bold (800)" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Title Color"
    },
    {
      "type": "color",
      "id": "title_color_mobile",
      "label": "Title Color – Mobile",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "title_color_tablet",
      "label": "Title Color – Tablet",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "title_color_desktop",
      "label": "Title Color – Desktop",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Title Font Size"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title Font Size – Mobile (px)",
      "min": 16, "max": 72, "step": 1, "default": 26
    },
    {
      "type": "range",
      "id": "title_size_tablet",
      "label": "Title Font Size – Tablet (px)",
      "min": 16, "max": 72, "step": 1, "default": 32
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Title Font Size – Desktop (px)",
      "min": 16, "max": 96, "step": 1, "default": 40
    },

    {
      "type": "header",
      "content": "── Content / Description ───────────────"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>BPC-157 has been investigated in numerous preclinical studies examining cellular repair mechanisms and tissue regeneration pathways. Research models suggest this peptide may influence angiogenesis, collagen synthesis, and wound healing cascades at the cellular level.</p>"
    },
    {
      "type": "header",
      "content": "Content Color"
    },
    {
      "type": "color",
      "id": "content_color_mobile",
      "label": "Content Color – Mobile",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "content_color_tablet",
      "label": "Content Color – Tablet",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "content_color_desktop",
      "label": "Content Color – Desktop",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Content Font Size"
    },
    {
      "type": "range",
      "id": "content_size_mobile",
      "label": "Content Font Size – Mobile (px)",
      "min": 12, "max": 28, "step": 1, "default": 14
    },
    {
      "type": "range",
      "id": "content_size_tablet",
      "label": "Content Font Size – Tablet (px)",
      "min": 12, "max": 28, "step": 1, "default": 15
    },
    {
      "type": "range",
      "id": "content_size_desktop",
      "label": "Content Font Size – Desktop (px)",
      "min": 12, "max": 28, "step": 1, "default": 16
    },

    {
      "type": "header",
      "content": "── Button Settings ─────────────────────"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Access catalog"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "select",
      "id": "btn_font_weight",
      "label": "Button Font Weight",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-Bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "btn_padding_v",
      "label": "Button Vertical Padding (px)",
      "min": 4, "max": 32, "step": 2, "default": 14
    },
    {
      "type": "range",
      "id": "btn_padding_h",
      "label": "Button Horizontal Padding (px)",
      "min": 8, "max": 80, "step": 2, "default": 28
    },
    {
      "type": "range",
      "id": "btn_border_radius",
      "label": "Button Border Radius (px)",
      "min": 0, "max": 50, "step": 1, "default": 6
    },
    {
      "type": "range",
      "id": "btn_border_width",
      "label": "Button Border Width (px)",
      "min": 0, "max": 6, "step": 1, "default": 0
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Button Border Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Button Background Color"
    },
    {
      "type": "color",
      "id": "btn_bg_mobile",
      "label": "Button BG – Mobile",
      "default": "#1d6b4e"
    },
    {
      "type": "color",
      "id": "btn_bg_tablet",
      "label": "Button BG – Tablet",
      "default": "#1d6b4e"
    },
    {
      "type": "color",
      "id": "btn_bg_desktop",
      "label": "Button BG – Desktop",
      "default": "#1d6b4e"
    },
    {
      "type": "header",
      "content": "Button Text Color"
    },
    {
      "type": "color",
      "id": "btn_color_mobile",
      "label": "Button Text Color – Mobile",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_color_tablet",
      "label": "Button Text Color – Tablet",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_color_desktop",
      "label": "Button Text Color – Desktop",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button Font Size"
    },
    {
      "type": "range",
      "id": "btn_size_mobile",
      "label": "Button Font Size – Mobile (px)",
      "min": 10, "max": 24, "step": 1, "default": 13
    },
    {
      "type": "range",
      "id": "btn_size_tablet",
      "label": "Button Font Size – Tablet (px)",
      "min": 10, "max": 24, "step": 1, "default": 14
    },
    {
      "type": "range",
      "id": "btn_size_desktop",
      "label": "Button Font Size – Desktop (px)",
      "min": 10, "max": 24, "step": 1, "default": 15
    },

    {
      "type": "header",
      "content": "── Text Alignment ──────────────────────"
    },
    {
      "type": "select",
      "id": "text_align_mobile",
      "label": "Text Align – Mobile",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_align_tablet",
      "label": "Text Align – Tablet",
