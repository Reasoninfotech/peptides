{%- liquid
	assign section_id   = '#shopify-section-' | append: section.id
	assign animation    = settings.section_animation
	assign full         = section.settings.full
	assign sub_heading  = section.settings.sub_heading
	assign heading      = section.settings.heading
	assign columns      = section.settings.columns
	assign heading_size = section.settings.heading_size
	assign total        = section.settings.total

	assign preferred_type = customer.metafields.custom.type_of_peptides.value | default: customer.metafields.custom.type_of_peptides
	assign render_section = true
	
	if customer.tags contains 'approved'
		if preferred_type == "International Peptides"
			if product.available
				assign render_section = false
			endif
		endif
	endif

    assign display_heading = section.settings.heading
    if customer.tags contains 'approved'
        if preferred_type == "America-made Peptides"
            assign display_heading = "Recommended other America-made Peptides"
        elsif preferred_type == "International Peptides"
            assign display_heading = "Out of stock? Try America-made Peptides"
        endif
    endif
-%}

{%- if render_section -%}

<style>
	{{ section_id }} .featured-collection-tab {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	{{ section_id }} .unity-slider {
		--slide-size: 93%;
	}

	@media (min-width: 992px) {
		{{ section_id }} .featured-collection-tab {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}

		{{ section_id }} .unity-slider {
			--slide-size: calc( 100% / {{ columns  }});
			--slide-spacing: 0.8rem;
		}
	}
</style>

{%- if customer.tags contains 'approved' or section.settings.hide_comparison_for_guests -%}
{%- if section.blocks.size > 0 -%}
	<div class="featured-collection-tab color-{{ section.settings.color_scheme }}">
		<div class="{% if full %}stretch-section stretch-padding{% else %} container{% endif %}">
			<div class="featured-collection-tabs tabs">
				{%- for block in section.blocks -%}
					{%- liquid
						assign class_tab = section.blocks.size

						if class_tab == 1
							assign class_tab = 'single'
						endif
					-%}
				{%- endfor -%}

				{%- if sub_heading != blank -%}
					<div class="sub-heading">
						{{ sub_heading }}
					</div>
				{%- endif -%}

				{%- if display_heading != blank -%}
					<div class="heading" style="color: black; font-size: 30px; line-height: 1.2; ">
						{{ display_heading }}
					</div>
					{% comment %} <div class="heading {{ heading_size }}">
						{{ heading }}
					</div> {% endcomment %}
				{%- endif -%}

				<div class="tabs-head tabs-{% echo class_tab %}">
					<div class="tabs-head-desktop{% if animation %} scroll-trigger{% endif %}">
						{%- for block in section.blocks -%}
							<button class="tab-head{% if forloop.index == 1 %} active{% endif %}" data-index="{{ forloop.index }}" {{ block.shopify_attributes }}{% if request.design_mode %} data-id="{{ block.id }}"{% endif %} style="border: .1rem solid oklch(87.2% .01 258.338); font-weight: 400; ">
								{%- liquid
									assign collection = block.settings.collection

									if block.settings.name != blank
										echo block.settings.name | escape
									elsif collection != blank
										echo collection.title
									else
										echo 'general.text.tab' | t | append: ' ' | append: forloop.index
									endif
								-%}
							</button>
						{%- endfor -%}
					</div>

					<div class="toggle-dropdown tabs-head-mobile tab-{% echo class_tab %}">
						<div class="dropdown-summary">
							<span class="summary-info">
								{%- liquid
									for block in section.blocks limit: 1
										assign collection = block.settings.collection

										if block.settings.name != blank
											echo block.settings.name | escape
										elsif collection != blank
											echo collection.title
										else
											echo 'general.text.tab' | t | append: ' ' | append: forloop.index
										endif
									endfor
								-%}
							</span>

							{%- render 'icon', code: 'chevron-down' -%}
						</div>

						<div class="dropdown-content" role="list">
							<div class="dropdown-content-inner">
								<header class="dropdown-content-header">
									<span class="dropdown-content-title">
										{%- liquid
											for block in section.blocks limit: 1
												assign collection = block.settings.collection

												if block.settings.name != blank
													echo block.settings.name | escape
												elsif collection != blank
													echo collection.title
												else
													echo 'general.text.tab' | t | append: ' ' | append: forloop.index
												endif
											endfor
										-%}
									</span>

									{%- render 'icon', code: 'chevron-down' -%}
								</header>

								<ul class="content" role="list">
									{%- for block in section.blocks -%}
										{%- liquid
											assign collection = block.settings.collection

											if block.settings.name != blank
												assign name = block.settings.name | escape
											elsif collection != blank
												assign name = collection.title
											else
												assign name = 'general.text.tab' | t | append: ' ' | append: forloop.index
											endif
										-%}

										<li class="dropdown-item" data-value="{{ name }}" data-index="{{ forloop.index }}">{{- name -}}</li>
									{%- endfor -%}
								</ul>
							</div>
						</div>
					</div>
				</div>

				<div class="tabs-content animation-{{ section.settings.animation }}">
					{%- for block in section.blocks -%}
						{%- assign collection = block.settings.collection -%}
							<div class="product-main-slide{% if forloop.index == 1 %} active{% endif %}">
								<unity-slider class="unity-slider">
									<template data-options>
										{
											{%- if section.settings.loop -%}
												"loop": true,
											{%- endif -%}

											{%- if section.settings.autoplay -%}
												"_autoplay": {{ section.settings.delay | times: 1000 }},
											{%- endif -%}

											"align": "start",
											"_autoheight": true,
											"_fade": false,
											"speed": 10,
											"_prevBtn": "{{ section_id }} .unity-button-prev",
											"_nextBtn": "{{ section_id }} .unity-button-next",
											"_dotsNode": "{{ section_id }} .unity-dots"
										}
									</template>

									<div class="unity-arrows {% if forloop.index == 1 %} active{% endif %}" data-index="{{ forloop.index }}" style="display: none;">
										<button class="unity-button unity-button-prev" title ="{{ 'general.unity.prev' | t }}-feature-clt" aria-label="{{ 'general.unity.prev' | t }}-feature-clt" id="{{ 'general.unity.prev' | t }}-feature-clt" aria-labelledby="{{ 'general.unity.prev' | t }}-feature-clt" disabled>
											{%- render 'icon', code: 'chevron-left' -%}
										</button>

										<button class="unity-button unity-button-next" title ="{{ 'general.unity.next' | t }}-feature-clt" aria-label="{{ 'general.unity.next' | t }}-feature-clt" id="{{ 'general.unity.next' | t }}-feature-clt" aria-labelledby="{{ 'general.unity.next' | t }}-feature-clt" disabled>
											{%- render 'icon', code: 'chevron-right' -%}
										</button>
									</div>

									<div class="unity-slider-viewport">
										<div class="unity-slider-container tab-content{% if forloop.index == 1 %} active{% endif %}" data-id="{{ block.id }}" data-index="{{ forloop.index }}">
											{%- for product in collection.products limit: total -%}
                                                {%- liquid
                                                  assign target_tag = ""
                                                  if preferred_type == "America-made Peptides" or preferred_type == "International Peptides"
                                                    assign target_tag = "America-made-peptides"
                                                  endif
                                                  
                                                  assign show_this_product = true
                                                  if customer.tags contains 'approved' and target_tag != blank
                                                    unless product.tags contains target_tag
                                                      assign show_this_product = false
                                                    endunless
                                                  endif
                                                -%}
                                                {%- if show_this_product -%}
  												<div class="unity-slide">
  													{%- render 'product-card', product: product -%}
  												</div>
                                                {%- endif -%}
											{%- else -%}
												{%- for i in (1..total) -%}
													<div class="unity-slide">
														{%- render 'product-card-placeholder', index: forloop.index -%}
													</div>
												{%- endfor -%}
											{%- endfor -%}
										</div>
									</div>

									{%- if section.settings.dots -%}
									<div class="align-dots-center">
										<div class="unity-dots{% if forloop.index == 1 %} active{% endif %}" data-index="{{ forloop.index }}">
										</div>
									</div>
									{%- endif -%}
								</unity-slider>
							</div>
					{%- endfor -%}
				</div>
			</div>
		</div>
	</div>
{%- endif -%}
{%- else -%}
  {%- comment -%} Show Comparison Grid for Guests by default {%- endcomment -%}
  {%- liquid
    assign global_image = section.settings.global_image
    assign american_image = section.settings.american_image
  -%}
  <style>
    .comparison-section {
      padding: 80px 0;
      background: #fafafa;
      text-align: center;
    }
    .comparison-header {
      max-width: 800px;
      margin: 0 auto 48px;
      padding: 0 20px;
    }
    .comparison-header h2 {
      font-size: 34px;
      font-weight: 700;
      margin-bottom: 16px;
      color: #000;
      letter-spacing: -0.02em;
    }
    .comparison-header p {
      color: #666;
      line-height: 1.6;
      font-size: 17px;
    }
    .comparison-grid {
      display: flex;
      justify-content: center;
      gap: 30px;
      max-width: 1100px;
      margin: 0 auto;
      padding: 20px;
    }
    .comparison-card {
      flex: 1;
      border-radius: 20px;
      padding: 40px;
      text-align: left;
      position: relative;
      display: flex;
      flex-direction: column;
      background: #fff;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      border: 1px solid #f0f0f0;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .comparison-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    }
    .comparison-card.premium {
      background: #1A4D2E;
      color: #fff;
      border: 2px solid #E9BC47;
      box-shadow: 0 4px 20.9px rgba(212, 175, 55, 0.6);
    }
    .premium:hover {
      box-shadow: 0 8px 30px rgba(212, 175, 55, 0.7);
    }
    .card-header {
      margin-bottom: 25px;
    }
    .card-title {
      font-size: 24px;
      font-weight: 700;
      margin: 0 0 8px 0;
      color: inherit;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .card-subtitle {
      font-size: 14px;
      opacity: 0.6;
      margin: 0;
      font-weight: 500;
    }
    .premium .card-subtitle {
       color: #E5E7EB;
    }
    .card-badge-wrapper {
      position: absolute;
      top: -15px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
    }
    .card-badge {
      font-size: 11px;
      padding: 8px 20px;
      border-radius: 50px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .premium .card-badge {
      background: #E9BC47;
      color: #1A4D2E;
    }
    .card-image-box {
      background: #F9FAFB;
      border-radius: 16px;
      height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 30px;
      overflow: hidden;
      border: 1px solid #f0f0f0;
    }
    .card-image-box img {
      max-height: 85%;
      width: auto;
      object-fit: contain;
    }
    .comparison-benefits {
      list-style: none;
      padding: 0;
      margin: 0 0 40px 0;
      flex-grow: 1;
    }
    .benefit-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 15px;
      font-size: 15px;
      line-height: 1.4;
      color: #4B5563;
      font-weight: 400;
    }
    .premium .benefit-item {
      color: #fff;
    }
    .benefit-item svg {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .standard .benefit-item svg {
      color: #9CA3AF;
    }
    .premium .benefit-item svg {
      color: #fff;
    }
    .card-action-btn {
      display: block;
      width: 100%;
      padding: 16px;
      border-radius: 12px;
      text-align: center;
      text-decoration: none;
      font-weight: 700;
      font-size: 16px;
      transition: all 0.3s ease;
    }
    .standard .card-action-btn {
      background: #000;
      color: #fff;
    }
    .premium .card-action-btn {
      background: #fff;
      color: #1A4D2E;
    }
    .card-action-btn:hover {
      opacity: 0.9;
      transform: scale(0.98);
    }
    .card-footer-text {
       text-align: center;
       margin-top: 15px;
       font-size: 13px;
       font-weight: 500;
       opacity: 0.5;
    }
    .premium .card-footer-text {
       color: #E9BC47;
       opacity: 1;
    }
    .grade-tip {
      max-width: 1100px;
      margin: 40px auto 0;
      font-size: 14px;
      color: #666;
    }

    @media (max-width: 900px) {
      .comparison-grid {
        display: flex;
        flex-direction: row;
        gap: 10px;
        padding: 20px 10px;
      }
      .comparison-card {
        flex: 1;
        padding: 20px 12px;
        border-radius: 12px;
      }
      .card-header {
        margin-bottom: 15px;
      }
      .card-title {
        font-size: 15px;
        gap: 6px;
      }
      .card-subtitle {
        font-size: 11px;
      }
      .card-image-box {
        height: 110px;
        margin-bottom: 15px;
        border-radius: 10px;
      }
      .benefit-item {
        font-size: 10px;
        gap: 6px;
        margin-bottom: 10px;
      }
      .benefit-item svg {
        width: 14px;
        height: 14px;
      }
      .card-action-btn {
        padding: 12px 8px;
        font-size: 10px;
        border-radius: 8px;
      }
      .card-footer-text {
        font-size: 10px;
        margin-top: 10px;
      }
      .card-badge-wrapper {
        top: -10px;
      }
      .card-badge {
        font-size: 9px;
        padding: 5px 12px;
      }
      .comparison-header h2 {
        font-size: 24px;
      }
      .comparison-header p {
        font-size: 14px;
      }
    }
  </style>

  <div class="comparison-section">
    <div class="container">
      <div class="comparison-header">
        <h2>{{ section.settings.guest_heading }}</h2>
        <p>{{ section.settings.guest_subtext }}</p>
      </div>

      <div class="comparison-grid">
        <!-- GLOBAL -->
        <div class="comparison-card standard">
          <div class="card-header">
            <h3 class="card-title">{{ section.settings.global_title }}</h3>
            <p class="card-subtitle">{{ section.settings.global_badge }}</p>
          </div>
          <div class="card-image-box">
             {% if global_image %}
               <img src="{{ global_image | img_url: '400x' }}" alt="{{ global_image.alt | default: section.settings.global_title }}" loading="lazy">
             {% else %}
               <img src="https://cdn.shopify.com/s/files/1/0805/0013/7979/files/glp-1_international.png?v=1710925000" alt="Global" loading="lazy">
             {% endif %}
          </div>
          <ul class="comparison-benefits">
            <li class="benefit-item">{% render 'icon', code: 'checkmark' %} {{ section.settings.global_origin }} origin</li>
            <li class="benefit-item">{% render 'icon', code: 'checkmark' %} {{ section.settings.global_purity }} (HPLC verified)</li>
            <li class="benefit-item">{% render 'icon', code: 'checkmark' %} {{ section.settings.global_testing }} manufacturing</li>
            <li class="benefit-item">{% render 'icon', code: 'checkmark' %} {{ section.settings.global_lead_time }} shipping</li>
            <li class="benefit-item">{% render 'icon', code: 'checkmark' %} {{ section.settings.global_price }}</li>
            <li class="benefit-item">{% render 'icon', code: 'checkmark' %} Certificate of Analysis included</li>
          </ul>
          <a href="{{ section.settings.global_collection.url | default: '/pages/sign-up' }}" class="card-action-btn">View {{ section.settings.global_title | split: ' ' | first }} Line</a>
          <div class="card-footer-text">Standard research grade</div>
        </div>

        <!-- AMERICAN -->
        <div class="comparison-card premium">
          <div class="card-badge-wrapper">
             <span class="card-badge">★ {{ section.settings.american_badge }}</span>
          </div>
          <div class="card-header">
            <h3 class="card-title">🇺🇸 {{ section.settings.american_title }}</h3>
{% comment %} <p class="card-subtitle">Premium Line • {{ section.settings.american_testing }}</p> {% endcomment %}
          </div>
          <div class="card-image-box">
             {% if american_image %}
               <img src="{{ american_image | img_url: '400x' }}" alt="{{ american_image.alt | default: section.settings.american_title }}" loading="lazy">
             {% else %}
               <img src="https://cdn.shopify.com/s/files/1/0805/0013/7979/files/glp-1_usa.png?v=1710925000" alt="USA" loading="lazy">
             {% endif %}
          </div>
          <ul class="comparison-benefits">
            <li class="benefit-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="10" fill="white"/>
                <path d="M6 10L9 13L14 7" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ section.settings.american_origin | remove: '🇺🇸' | strip }} manufactured
            </li>
            <li class="benefit-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="10" fill="white"/>
                <path d="M6 10L9 13L14 7" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ section.settings.american_purity }} (HPLC + MS verified)
            </li>
            <li class="benefit-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="10" fill="white"/>
                <path d="M6 10L9 13L14 7" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ section.settings.american_testing }} facility
            </li>
            <li class="benefit-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="10" fill="white"/>
                <path d="M6 10L9 13L14 7" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ section.settings.american_lead_time }} shipping
            </li>
            <li class="benefit-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="10" fill="white"/>
                <path d="M6 10L9 13L14 7" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Premium quality (+15%)
            </li>
            <li class="benefit-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="10" fill="white"/>
                <path d="M6 10L9 13L14 7" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ section.settings.american_coa }}
            </li>
          </ul>
          <a href="{{ section.settings.american_collection.url | default: '/pages/sign-up' }}" class="card-action-btn">View {{ section.settings.american_title | split: ' ' | first }} Line</a>
          <div class="card-footer-text">Premium research grade</div>
        </div>
      </div>

      <div class="grade-tip">
        {{ section.settings.guest_tip }}
      </div>
    </div>
  </div>
{%- endif -%}
{%- endif -%}
<script>
  document.addEventListener('click', function (event) {
    var card = event.target.closest('.featured-collection-section .product-card');
    if (!card) return;

    var link = event.target.closest('a[href]');
    if (!link) {
      link = card.querySelector('.product-image, .product-title a, .product-link');
    }
    if (!link) return;

    event.preventDefault();
    window.location.href = link.getAttribute('href');
  }, true);
</script>

{% schema %}
{
	"name": "Featured Collection PDP",
	"tag": "section",
	"class": "featured-collection-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "checkbox",
			"id": "full",
			"default": false,
			"label": "t:general.layout.full.label"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "t:sections.featured-collection-tabs.settings.header_head.content"
		},
		{
			"type": "text",
			"id": "sub_heading",
			"default": "( Browser our products )",
			"label": "t:general.typography.sub_heading.label"
		},
		{
			"type": "text",
			"id": "heading",
			"default": "Most popular",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h3",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h2",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h3",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "header",
			"content": "t:sections.featured-collection-tabs.settings.header_content.content"
		},
		{
			"type": "range",
			"id": "columns",
			"min": 2,
			"max": 5,
			"step": 1,
