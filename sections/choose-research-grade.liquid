{% comment %}
  Section: Choose Your Research Grade
  Theme: BoostifyThemes
  Description: Two-column peptide product comparison with mobile/tablet/desktop responsive settings
{% endcomment %}

<style>
  /* ============================================================
     SECTION ROOT & CSS VARIABLES
  ============================================================ */
  #shopify-section-{{ section.id }} {
    --crg-bg:                   {{ section.settings.section_bg_color }};
    --crg-padding-top-desktop:  {{ section.settings.padding_top_desktop }}px;
    --crg-padding-bot-desktop:  {{ section.settings.padding_bottom_desktop }}px;
    --crg-padding-top-tablet:   {{ section.settings.padding_top_tablet }}px;
    --crg-padding-bot-tablet:   {{ section.settings.padding_bottom_tablet }}px;
    --crg-padding-top-mobile:   {{ section.settings.padding_top_mobile }}px;
    --crg-padding-bot-mobile:   {{ section.settings.padding_bottom_mobile }}px;

    --crg-title-color:          {{ section.settings.heading_color }};
    --crg-title-size-desktop:   {{ section.settings.heading_size_desktop }}px;
    --crg-title-size-tablet:    {{ section.settings.heading_size_tablet }}px;
    --crg-title-size-mobile:    {{ section.settings.heading_size_mobile }}px;

    --crg-subtitle-color:       {{ section.settings.subtitle_color }};
    --crg-subtitle-size-desktop:{{ section.settings.subtitle_size_desktop }}px;
    --crg-subtitle-size-tablet: {{ section.settings.subtitle_size_tablet }}px;
    --crg-subtitle-size-mobile: {{ section.settings.subtitle_size_mobile }}px;

    --crg-col-gap-desktop:      {{ section.settings.column_gap_desktop }}px;
    --crg-col-gap-tablet:       {{ section.settings.column_gap_tablet }}px;
    --crg-col-gap-mobile:       {{ section.settings.column_gap_mobile }}px;

    --crg-card-radius:          {{ section.settings.card_border_radius }}px;
    --crg-card-shadow:          {{ section.settings.card_box_shadow }};

    /* ---- Left card ---- */
    --crg-left-bg:              {{ section.settings.left_card_bg }};
    --crg-left-border:          {{ section.settings.left_card_border_color }};
    --crg-left-title-color:     {{ section.settings.left_title_color }};
    --crg-left-badge-bg:        {{ section.settings.left_badge_bg }};
    --crg-left-badge-color:     {{ section.settings.left_badge_text_color }};
    --crg-left-icon-color:      {{ section.settings.left_icon_color }};
    --crg-left-text-color:      {{ section.settings.left_feature_text_color }};
    --crg-left-btn-bg:          {{ section.settings.left_btn_bg }};
    --crg-left-btn-color:       {{ section.settings.left_btn_text_color }};
    --crg-left-btn-border:      {{ section.settings.left_btn_border_color }};
    --crg-left-btn-hover-bg:    {{ section.settings.left_btn_hover_bg }};
    --crg-left-label-color:     {{ section.settings.left_label_color }};

    /* ---- Right card ---- */
    --crg-right-bg:             {{ section.settings.right_card_bg }};
    --crg-right-border:         {{ section.settings.right_card_border_color }};
    --crg-right-title-color:    {{ section.settings.right_title_color }};
    --crg-right-badge-bg:       {{ section.settings.right_badge_bg }};
    --crg-right-badge-color:    {{ section.settings.right_badge_text_color }};
    --crg-right-icon-color:     {{ section.settings.right_icon_color }};
    --crg-right-text-color:     {{ section.settings.right_feature_text_color }};
    --crg-right-btn-bg:         {{ section.settings.right_btn_bg }};
    --crg-right-btn-color:      {{ section.settings.right_btn_text_color }};
    --crg-right-btn-hover-bg:   {{ section.settings.right_btn_hover_bg }};
    --crg-right-label-color:    {{ section.settings.right_label_color }};

    /* ---- Help bar ---- */
    --crg-help-bg:              {{ section.settings.help_bar_bg }};
    --crg-help-border:          {{ section.settings.help_bar_border_color }};
    --crg-help-bold-color:      {{ section.settings.help_bar_bold_color }};
    --crg-help-text-color:      {{ section.settings.help_bar_text_color }};
    --crg-help-text-size-desktop:{{ section.settings.help_bar_text_size_desktop }}px;
    --crg-help-text-size-tablet: {{ section.settings.help_bar_text_size_tablet }}px;
    --crg-help-text-size-mobile: {{ section.settings.help_bar_text_size_mobile }}px;
  }

  /* ============================================================
     BASE STYLES
  ============================================================ */
  .crg-section {
    background-color: var(--crg-bg);
    padding-top: var(--crg-padding-top-desktop);
    padding-bottom: var(--crg-padding-bot-desktop);
    font-family: {{ section.settings.body_font_family }}, sans-serif;
  }

  .crg-container {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding-left: {{ section.settings.container_side_padding }}px;
    padding-right: {{ section.settings.container_side_padding }}px;
  }

  /* ============================================================
     HEADING BLOCK
  ============================================================ */
  .crg-heading-block {
    text-align: center;
    margin-bottom: {{ section.settings.heading_margin_bottom_desktop }}px;
  }

  .crg-main-title {
    font-family: {{ section.settings.heading_font_family }}, serif;
    font-size: var(--crg-title-size-desktop);
    color: var(--crg-title-color);
    font-weight: {{ section.settings.heading_font_weight }};
    line-height: 1.2;
    margin: 0 0 12px;
    letter-spacing: {{ section.settings.heading_letter_spacing }}em;
  }

  .crg-subtitle {
    font-size: var(--crg-subtitle-size-desktop);
    color: var(--crg-subtitle-color);
    max-width: {{ section.settings.subtitle_max_width }}px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 400;
  }

  /* ============================================================
     CARDS GRID
  ============================================================ */
  .crg-cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--crg-col-gap-desktop);
    margin-bottom: {{ section.settings.cards_margin_bottom }}px;
  }

  /* ============================================================
     SINGLE CARD
  ============================================================ */
  .crg-card {
    border-radius: var(--crg-card-radius);
    overflow: hidden;
    box-shadow: var(--crg-card-shadow);
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  {% if section.settings.card_hover_lift %}
  .crg-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.14);
  }
  {% endif %}

  /* ---- LEFT CARD ---- */
  .crg-card--left {
    background: var(--crg-left-bg);
    border: 2px solid var(--crg-left-border);
  }

  .crg-card--left .crg-card__inner {
    padding: {{ section.settings.card_inner_padding_desktop }}px;
    flex: 1;
  }

  /* ---- RIGHT CARD ---- */
  .crg-card--right {
    background: var(--crg-right-bg);
    border: 2px solid var(--crg-right-border);
  }

  .crg-card--right .crg-card__inner {
    padding: {{ section.settings.card_inner_padding_desktop }}px;
    flex: 1;
  }

  /* ============================================================
     CARD PRODUCT ROW (image + title + badge)
  ============================================================ */
  .crg-card__product-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 20px;
  }

  .crg-card__img-wrap {
    flex-shrink: 0;
    width: {{ section.settings.product_image_size }}px;
  }

  .crg-card__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .crg-card__title-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .crg-card--left .crg-card__title {
    font-family: {{ section.settings.heading_font_family }}, serif;
    font-size: {{ section.settings.card_title_size_desktop }}px;
    font-weight: 700;
    color: var(--crg-left-title-color);
    line-height: 1.25;
    margin: 0;
  }

  .crg-card--right .crg-card__title {
    font-family: {{ section.settings.heading_font_family }}, serif;
    font-size: {{ section.settings.card_title_size_desktop }}px;
    font-weight: 700;
    color: var(--crg-right-title-color);
    line-height: 1.25;
    margin: 0;
  }

  /* ============================================================
     BADGES
  ============================================================ */
  .crg-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 30px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.01em;
    width: fit-content;
  }

  .crg-card--left .crg-badge {
    background: var(--crg-left-badge-bg);
    color: var(--crg-left-badge-color);
    border: 1.5px solid var(--crg-left-border);
  }

  .crg-card--right .crg-badge {
    background: var(--crg-right-badge-bg);
    color: var(--crg-right-badge-color);
  }

  /* ============================================================
     FEATURES LIST
  ============================================================ */
  .crg-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.feature_item_gap }}px;
  }

  .crg-features__item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: {{ section.settings.feature_text_size_desktop }}px;
    line-height: 1.45;
    font-weight: 500;
  }

  .crg-card--left .crg-features__item {
    color: var(--crg-left-text-color);
  }

  .crg-card--right .crg-features__item {
    color: var(--crg-right-text-color);
  }

  .crg-features__icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 1px;
  }

  .crg-card--left .crg-features__icon {
    color: var(--crg-left-icon-color);
  }

  .crg-card--right .crg-features__icon {
    color: var(--crg-right-icon-color);
  }

  /* ============================================================
     CTA BUTTON AREA
  ============================================================ */
  .crg-card__cta-area {
    padding: 0 {{ section.settings.card_inner_padding_desktop }}px {{ section.settings.card_inner_padding_desktop }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .crg-btn {
    display: block;
    width: 100%;
    padding: 15px 24px;
    border-radius: {{ section.settings.btn_border_radius }}px;
    font-family: {{ section.settings.body_font_family }}, sans-serif;
    font-size: {{ section.settings.btn_text_size_desktop }}px;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, opacity 0.2s ease, transform 0.15s ease;
    border: 2px solid transparent;
    letter-spacing: 0.02em;
  }

  .crg-btn:hover { transform: translateY(-1px); opacity: 0.9; }
  .crg-btn:active { transform: translateY(0); }

  .crg-card--left .crg-btn {
    background: var(--crg-left-btn-bg);
    color: var(--crg-left-btn-color);
    border-color: var(--crg-left-btn-border);
  }

  .crg-card--left .crg-btn:hover {
    background: var(--crg-left-btn-hover-bg);
  }

  .crg-card--right .crg-btn {
    background: var(--crg-right-btn-bg);
    color: var(--crg-right-btn-color);
    border-color: var(--crg-right-btn-bg);
  }

  .crg-card--right .crg-btn:hover {
    background: var(--crg-right-btn-hover-bg);
    border-color: var(--crg-right-btn-hover-bg);
  }

  .crg-card__label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .crg-card--left .crg-card__label { color: var(--crg-left-label-color); }
  .crg-card--right .crg-card__label { color: var(--crg-right-label-color); }

  /* ============================================================
     HELP BAR
  ============================================================ */
  .crg-help-bar {
    background: var(--crg-help-bg);
    border: 1.5px solid var(--crg-help-border);
    border-radius: {{ section.settings.help_bar_border_radius }}px;
    padding: {{ section.settings.help_bar_padding_desktop }}px {{ section.settings.help_bar_padding_desktop | plus: 8 }}px;
    font-size: var(--crg-help-text-size-desktop);
    color: var(--crg-help-text-color);
    line-height: 1.55;
    text-align: center;
  }

  .crg-help-bar strong {
    color: var(--crg-help-bold-color);
    font-weight: 700;
  }

  /* ============================================================
     DIVIDER
  ============================================================ */
  .crg-card__divider {
    height: 1px;
    background: rgba(0,0,0,0.08);
    margin: 16px 0;
  }

  .crg-card--right .crg-card__divider {
    background: rgba(255,255,255,0.12);
  }

  /* ============================================================
     TABLET — max 1024px
  ============================================================ */
  @media (max-width: 1024px) {
    .crg-section {
      padding-top: var(--crg-padding-top-tablet);
      padding-bottom: var(--crg-padding-bot-tablet);
    }

    .crg-cards-grid {
      gap: var(--crg-col-gap-tablet);
    }

    .crg-main-title {
      font-size: var(--crg-title-size-tablet);
    }

    .crg-subtitle {
      font-size: var(--crg-subtitle-size-tablet);
    }

    .crg-card--left .crg-card__title,
    .crg-card--right .crg-card__title {
      font-size: {{ section.settings.card_title_size_tablet }}px;
    }

    .crg-features__item {
      font-size: {{ section.settings.feature_text_size_tablet }}px;
    }

    .crg-btn {
      font-size: {{ section.settings.btn_text_size_tablet }}px;
    }

    .crg-help-bar {
      font-size: var(--crg-help-text-size-tablet);
    }

    .crg-card--left .crg-card__inner,
    .crg-card--right .crg-card__inner {
      padding: {{ section.settings.card_inner_padding_tablet }}px;
    }

    .crg-card__cta-area {
      padding: 0 {{ section.settings.card_inner_padding_tablet }}px {{ section.settings.card_inner_padding_tablet }}px;
    }

    .crg-heading-block {
      margin-bottom: {{ section.settings.heading_margin_bottom_tablet }}px;
    }

    .crg-help-bar {
      padding: {{ section.settings.help_bar_padding_tablet }}px {{ section.settings.help_bar_padding_tablet | plus: 8 }}px;
    }
  }

  /* ============================================================
     MOBILE — max 767px
  ============================================================ */
  @media (max-width: 767px) {
    .crg-section {
      padding-top: var(--crg-padding-top-mobile);
      padding-bottom: var(--crg-padding-bot-mobile);
    }

    .crg-container {
      padding-left: {{ section.settings.container_side_padding_mobile }}px;
      padding-right: {{ section.settings.container_side_padding_mobile }}px;
    }

    .crg-cards-grid {
      grid-template-columns: 1fr;
      gap: var(--crg-col-gap-mobile);
    }

    .crg-main-title {
      font-size: var(--crg-title-size-mobile);
    }

    .crg-subtitle {
      font-size: var(--crg-subtitle-size-mobile);
    }

    .crg-heading-block {
      margin-bottom: {{ section.settings.heading_margin_bottom_mobile }}px;
    }

    .crg-card--left .crg-card__title,
    .crg-card--right .crg-card__title {
      font-size: {{ section.settings.card_title_size_mobile }}px;
    }

    .crg-features__item {
      font-size: {{ section.settings.feature_text_size_mobile }}px;
    }

    .crg-btn {
      font-size: {{ section.settings.btn_text_size_mobile }}px;
      padding: 13px 20px;
    }

    .crg-help-bar {
      font-size: var(--crg-help-text-size-mobile);
      padding: {{ section.settings.help_bar_padding_mobile }}px;
      text-align: left;
    }

    .crg-card--left .crg-card__inner,
    .crg-card--right .crg-card__inner {
      padding: {{ section.settings.card_inner_padding_mobile }}px;
    }

    .crg-card__cta-area {
      padding: 0 {{ section.settings.card_inner_padding_mobile }}px {{ section.settings.card_inner_padding_mobile }}px;
    }

    .crg-card__img-wrap {
      width: {{ section.settings.product_image_size_mobile }}px;
    }
  }
</style>

{% unless section.settings.section_enabled == false %}
<section
  id="crg-{{ section.id }}"
  class="crg-section"
  aria-label="{{ section.settings.heading_text | escape }}"
>
  <div class="crg-container">

    {%- comment -%} ── HEADING BLOCK ── {%- endcomment -%}
    {% if section.settings.show_heading_block %}
    <div class="crg-heading-block">
      {% if section.settings.heading_text != blank %}
        <{{ section.settings.heading_tag }} class="crg-main-title">
          {{ section.settings.heading_text }}
        </{{ section.settings.heading_tag }}>
      {% endif %}
      {% if section.settings.subtitle_text != blank %}
        <p class="crg-subtitle">{{ section.settings.subtitle_text }}</p>
      {% endif %}
    </div>
    {% endif %}

    {%- comment -%} ── CARDS GRID ── {%- endcomment -%}
    <div class="crg-cards-grid">

      {%- comment -%} ========= LEFT CARD ========= {%- endcomment -%}
      <div class="crg-card crg-card--left">
        <div class="crg-card__inner">

          <div class="crg-card__product-row">
            {% if section.settings.left_product_image != blank %}
            <div class="crg-card__img-wrap">
              <img
                src="{{ section.settings.left_product_image | image_url: width: 200 }}"
                alt="{{ section.settings.left_product_image.alt | default: section.settings.left_card_title | escape }}"
                width="200"
                height="auto"
                loading="lazy"
              >
            </div>
            {% endif %}

            <div class="crg-card__title-block">
              {% if section.settings.left_card_title != blank %}
                <h3 class="crg-card__title">{{ section.settings.left_card_title }}</h3>
              {% endif %}
              {% if section.settings.left_badge_text != blank %}
                <span class="crg-badge">
                  {% if section.settings.left_badge_icon != blank %}
                    {{- section.settings.left_badge_icon -}}
                  {% endif %}
                  {{ section.settings.left_badge_text }}
                </span>
              {% endif %}
            </div>
          </div>

          <div class="crg-card__divider"></div>

          <ul class="crg-features" role="list">
            {% for i in (1..6) %}
              {% assign feat_key = 'left_feature_' | append: i %}
              {% assign feat_val = section.settings[feat_key] %}
              {% if feat_val != blank %}
              <li class="crg-features__item">
                <svg class="crg-features__icon" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M6.5 11.5l3 3 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ feat_val }}</span>
              </li>
              {% endif %}
            {% endfor %}
          </ul>

        </div>

        <div class="crg-card__cta-area">
          {% if section.settings.left_btn_text != blank %}
            <a
              href="{{ section.settings.left_btn_url | default: '#' }}"
              class="crg-btn"
              {% if section.settings.left_btn_new_tab %}target="_blank" rel="noopener"{% endif %}
            >
              {{ section.settings.left_btn_text }}
            </a>
          {% endif %}
          {% if section.settings.left_card_label != blank %}
            <span class="crg-card__label">{{ section.settings.left_card_label }}</span>
          {% endif %}
        </div>
      </div>

      {%- comment -%} ========= RIGHT CARD ========= {%- endcomment -%}
      <div class="crg-card crg-card--right">
        <div class="crg-card__inner">

          <div class="crg-card__product-row">
            {% if section.settings.right_product_image != blank %}
            <div class="crg-card__img-wrap">
              <img
                src="{{ section.settings.right_product_image | image_url: width: 200 }}"
                alt="{{ section.settings.right_product_image.alt | default: section.settings.right_card_title | escape }}"
                width="200"
                height="auto"
                loading="lazy"
              >
            </div>
            {% endif %}

            <div class="crg-card__title-block">
              {% if section.settings.right_card_title != blank %}
                <h3 class="crg-card__title">{{ section.settings.right_card_title }}</h3>
              {% endif %}
              {% if section.settings.right_badge_text != blank %}
                <span class="crg-badge">
                  {% if section.settings.right_badge_icon != blank %}
                    {{- section.settings.right_badge_icon -}}
                  {% endif %}
                  {{ section.settings.right_badge_text }}
                </span>
              {% endif %}
            </div>
          </div>

          <div class="crg-card__divider"></div>

          <ul class="crg-features" role="list">
            {% for i in (1..6) %}
              {% assign feat_key = 'right_feature_' | append: i %}
              {% assign feat_val = section.settings[feat_key] %}
              {% if feat_val != blank %}
              <li class="crg-features__item">
                <svg class="crg-features__icon" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="11" cy="11" r="10" fill="currentColor" fill-opacity="0.18"/>
                  <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M6.5 11.5l3 3 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ feat_val }}</span>
              </li>
              {% endif %}
            {% endfor %}
          </ul>

        </div>

        <div class="crg-card__cta-area">
          {% if section.settings.right_btn_text != blank %}
            <a
              href="{{ section.settings.right_btn_url | default: '#' }}"
              class="crg-btn"
              {% if section.settings.right_btn_new_tab %}target="_blank" rel="noopener"{% endif %}
            >
              {{ section.settings.right_btn_text }}
            </a>
          {% endif %}
          {% if section.settings.right_card_label != blank %}
            <span class="crg-card__label">{{ section.settings.right_card_label }}</span>
          {% endif %}
        </div>
      </div>

    </div>{%- comment -%} / .crg-cards-grid {%- endcomment -%}

    {%- comment -%} ── HELP BAR ── {%- endcomment -%}
    {% if section.settings.show_help_bar and section.settings.help_bar_text != blank %}
    <div class="crg-help-bar" role="note">
      {{ section.settings.help_bar_text }}
    </div>
    {% endif %}

  </div>{%- comment -%} / .crg-container {%- endcomment -%}
</section>
{% endunless %}


{% schema %}
{
  "name": "Research Grade Comparison",
  "tag": "section",
  "class": "section-research-grade",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [

    {
      "type": "header",
      "content": "⚙️ Section"
    },
    {
      "type": "checkbox",
      "id": "section_enabled",
      "label": "Enable section",
      "default": true
    },
    {
      "type": "color",
