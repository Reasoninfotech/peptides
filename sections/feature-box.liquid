{%- liquid
	assign section_id     = '#shopify-section-' | append: section.id
	assign animation      = settings.section_animation
	assign full           = section.settings.full
	assign layout         = section.settings.layout
	assign columns        = section.settings.columns
	assign heading        = section.settings.heading_text
	assign heading_size   = section.settings.heading_size
	assign description    = section.settings.text
	assign caption        = section.settings.caption

	if caption != blank or heading != blank or description != blank
		assign title = caption | default: heading | default: description
	endif
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	{% if section.settings.bg_title_img != blank %}
		{{ section_id }} .title-wrapper {
			background-image: url({{ section.settings.bg_title_img | image_url: width: 900 }});
			background-repeat: no-repeat;
			background-size: cover;
			min-height: 35rem;
		}
	{% endif %}

	@media (min-width: 992px) {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}

		{{ section_id }} .unity-slide {
			flex: 0 0 calc(var(--slide-size) / {{ columns | minus: 1 }});
		}

		{{ section_id }} .title-wrapper {
			flex: 0 0 calc(90% / {{ columns }});
		}
	}

	.icon-text-circle {
		width: 100px;
		height: 100px;
		border-radius: 50%;
		border: 1.5px solid #111827;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 24px;
		font-weight: 500;
		color: #111827;
		margin: 0 auto;
		text-align: center;
	}
</style>

<div class="section-wrapper color-{{ section.settings.color_scheme }}">
	<div class="{% if layout == 'carousel' %}custom-grid{% else %}{% if full %}stretch-section stretch-padding{% else %}container{% endif %}{% endif %}">
		<div class="section-feature-box">
			<div class="feature-box-content box-{{ layout }}">
				<div class="content-wrapper">
					{%- if layout == 'carousel' -%}
						<div class="title-wrapper box-item border-large{% if title %} has-title{% endif %} color-{{ section.settings.title_color_scheme }}">
							{%- if title -%}
								<div class="title-inner">
									{%- if caption != blank -%}
										<div class="sub-heading rte{% if animation %} scroll-trigger{% endif %}">{{- caption -}}</div>
									{%- endif -%}

									{%- if heading != blank -%}
										<h2 class="heading {{ heading_size }} rte{% if animation %} scroll-trigger{% endif %}">{{- heading -}}</h2>
									{%- endif -%}

									{%- if description != blank -%}
										<div class="description{% if animation %} scroll-trigger{% endif %}">{{- description -}}</div>
									{%- endif -%}
								</div>
							{% endif %}

							<div class="unity-arrows">
								<button class="unity-button unity-button-prev" title ="{{ 'general.unity.prev' | t }}-feature" aria-label="{{ 'general.unity.prev' | t }}-feature" id="{{ 'general.unity.prev' | t }}-feature" aria-labelledby="{{ 'general.unity.prev' | t }}-feature-feature" disabled>
									{%- render 'icon', code: 'chevron-left' -%}
								</button>

								<button class="unity-button unity-button-next" title ="{{ 'general.unity.next' | t }}-feature" aria-label="{{ 'general.unity.next' | t }}-feature" id="{{ 'general.unity.next' | t }}-feature" aria-labelledby="{{ 'general.unity.next' | t }}-feature" disabled>
									{%- render 'icon', code: 'chevron-right' -%}
								</button>
							</div>
						</div>

						<unity-slider class="unity-slider">
							<template data-options>
								{
									"align": "start",
									"_autoheight": true,
									"_fade": false,
									"_prevBtn": "{{ section_id }} .unity-button-prev",
									"_nextBtn": "{{ section_id }} .unity-button-next"
								}
							</template>

							<div class="unity-slider-viewport">
								<div class="unity-slider-container">
									{%- for block in section.blocks -%}
										<div class="unity-slide" {{ block.shopify_attributes }}>
											<div class="box-item border-large{% if animation %} scroll-trigger{% endif %} color-{{ section.settings.item_scheme }}">
												{%- case block.type -%}
													{%- when '@app' -%}
														{%- render block -%}

													{%- when 'item' -%}
														{%- assign image       = block.settings.icon_img -%}
														{%- assign popup_image = block.settings.popup_image -%}

														<div class="info-box" style="text-align: center;">
															<div class="image-wrap adapt-media">
																{%- if block.settings.icon_type == 'text' -%}
																	<div class="icon-text-circle">
																		{{ block.settings.icon_text }}
																	</div>
																{%- else -%}
																	<div class="image-box{% if settings.image_lazy and image != blank %} lazy-image{% endif %}">
																		{%- liquid
																			if image != blank
																				render 'lazy-image', image: image, width: 52
																			else
																				render 'icon', code: 'placeholder'
																			endif
																		-%}
																	</div>
																{%- endif -%}
															</div>

															{% if block.settings.text != blank %}
																<div class="heading-item rte">{{- block.settings.text -}}</div>
															{% endif %}

															{% if block.settings.description != blank %}
																<div class="description-item rte">{{- block.settings.description -}}</div>
															{% endif %}
														</div>

														{%- if block.settings.button_label != blank -%}
															<a class="button-box link-underline{% if animation %} scroll-trigger{% endif %}{% if block.settings.popup_content != blank or popup_image != blank %} has-popup{% endif %}" href="{{ block.settings.button_link | default: '#' }}" aria-label="{{- 'general.text.link' | t -}}" style="text-align: center;">
																{{- block.settings.button_label -}}
															</a>

															{% if block.settings.popup_content != blank or popup_image != blank %}
																<div class="popup">
																	{%- if popup_image != blank -%}
																		<div class="popup-image">
																			<div class="image-box">
																				<img
																					src="{{ popup_image | image_url: width: 1920 }}"
																					alt="{{ popup_image.alt | escape }}"
																					loading="eager"
																					width="{{ popup_image.width }}"
																					height="{{ popup_image.height }}"
																				>
																			</div>
																		</div>
																	{%- endif -%}

																	<div class="popup-content">{{- block.settings.popup_content -}}</div>
																</div>
															{% endif %}
														{%- endif -%}
												{%- endcase -%}
											</div>
										</div>
									{%- endfor -%}
								</div>
							</div>
						</unity-slider>
					{% else %}
						<div class="grid grid-{{ columns }} grid-tablet-1 grid-mobile-1">
							{%- if title -%}
								<div class="grid-item box-item title-wrapper border-large color-{{ section.settings.title_color_scheme }}">
									{%- if caption != blank -%}
										<div class="sub-heading rte{% if animation %} scroll-trigger{% endif %}">{{- caption -}}</div>
									{%- endif -%}

									{%- if heading != blank -%}
										<h2 class="heading {{ heading_size }} rte{% if animation %} scroll-trigger{% endif %}">{{- heading -}}</h2>
									{%- endif -%}

									{%- if description != blank -%}
										<div class="description{% if animation %} scroll-trigger{% endif %}">{{- description -}}</div>
									{%- endif -%}
								</div>
							{% endif %}

							{%- for block in section.blocks -%}
								<div class="grid-item box-item border-large color-{{ section.settings.item_scheme }}{% if animation %} scroll-trigger{% endif %}" {{ block.shopify_attributes }}>
									{%- case block.type -%}
										{%- when '@app' -%}
											{%- render block -%}

										{%- when 'item' -%}
											{%- assign image       = block.settings.icon_img -%}
											{%- assign popup_image = block.settings.popup_image -%}

											<div class="info-box" style="text-align: center;">
												<div class="image-wrap adapt-media">
													{%- if block.settings.icon_type == 'text' -%}
														<div class="icon-text-circle">
															{{ block.settings.icon_text }}
														</div>
													{%- else -%}
														<div class="image-box{% if settings.image_lazy and image != blank %} lazy-image{% endif %}">
															{%- liquid
																if image != blank
																	render 'lazy-image', image: image, width: 52
																else
																	render 'icon', code: 'placeholder'
																endif
															-%}
														</div>
													{%- endif -%}
												</div>

												{% if block.settings.text != blank %}
													<div class="heading-item rte">{{- block.settings.text -}}</div>
												{% endif %}

												{% if block.settings.description != blank %}
													<div class="description-item rte">{{- block.settings.description -}}</div>
												{% endif %}
											</div>

											{%- if block.settings.button_label != blank -%}
												<a class="button-box link-underline{% if animation %} scroll-trigger{% endif %}{% if block.settings.popup_content != blank or popup_image != blank %} has-popup{% endif %}" href="{{ block.settings.button_link | default: '#' }}" aria-label="{{- 'general.text.link' | t -}}" style="text-align: center;">
													{{- block.settings.button_label -}}
												</a>

												{% if block.settings.popup_content != blank or popup_image != blank %}
													<div class="popup">
														{%- if popup_image != blank -%}
															<div class="popup-image">
																<div class="image-box">
																	<img
																		src="{{ popup_image | image_url: width: 1920 }}"
																		alt="{{ popup_image.alt | escape }}"
																		loading="eager"
																		width="{{ popup_image.width }}"
																		height="{{ popup_image.height }}"
																	>
																</div>
															</div>
														{%- endif -%}

														<div class="popup-content">{{- block.settings.popup_content -}}</div>
													</div>
												{% endif %}
											{%- endif -%}
									{%- endcase -%}
								</div>
							{%- endfor -%}
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.feature-box.name",
	"class": "feature-box-section",
	"tag": "section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "checkbox",
			"id": "full",
			"default": false,
			"label": "t:general.layout.full.label"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "select",
			"id": "layout",
			"options": [
				{
					"value": "carousel",
					"label": "t:sections.feature-box.settings.layout.option_1.label"
				},
				{
					"value": "grid",
					"label": "t:sections.feature-box.settings.layout.option_2.label"
				}
			],
			"default": "carousel",
			"label": "t:general.layout.name"
		},
		{
			"type": "range",
			"id": "columns",
			"min": 2,
			"max": 4,
			"step": 1,
			"default": 3,
			"label": "t:sections.feature-box.settings.columns.label"
		},
		{
			"type": "color_scheme",
			"id": "item_scheme",
			"label": "t:sections.feature-box.settings.item_scheme.label",
			"default": "scheme-2"
		},
		{
			"type": "header",
			"content": "t:general.typography.content.label"
		},
		{
			"type": "text",
			"id": "caption",
			"default": "Caption",
			"label": "t:general.typography.caption.label"
		},
		{
			"type": "inline_richtext",
			"id": "heading_text",
			"default": "Heading text",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h3",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h2",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h3",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "richtext",
			"id": "text",
			"default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
			"label": "t:general.typography.description.label"
		},
		{
			"type":"image_picker",
			"id":"bg_title_img",
			"label": "t:general.background.image.label"
		},
		{
			"type": "color_scheme",
			"id": "title_color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"blocks": [
		{
			"type": "@app"
		},
		{
			"type": "item",
			"name": "t:sections.feature-box.blocks.item.name",
			"settings": [
				{
					"type": "select",
					"id": "icon_type",
					"label": "Icon Type",
					"options": [
						{
							"value": "image",
							"label": "Image"
						},
						{
							"value": "text",
							"label": "Text Circle"
						}
					],
					"default": "image"
				},
				{
					"type":"image_picker",
					"id":"icon_img",
					"label": "t:general.image.label"
				},
				{
					"type": "text",
					"id": "icon_text",
					"label": "Circle Text",
					"default": "≥98%"
				},
				{
					"type": "richtext",
					"id": "text",
					"default": "<h3>The title for your item</h3>",
					"label": "t:general.typography.text.label"
				},
				{
					"type": "richtext",
					"id": "description",
					"default": "<p>Give customers details about the banner image or content on the template.</p>",
					"label": "t:general.typography.description.label"
				},
				{
					"type": "text",
					"id": "button_label",
					"default": "Button label",
					"label": "t:general.typography.button_label.label"
				},
				{
					"type": "url",
					"id": "button_link",
					"label": "t:general.typography.link.label"
				},
				{
					"type":"image_picker",
					"id":"popup_image",
					"label": "t:sections.feature-box.blocks.popup_image.name"
				},
				{
					"type": "richtext",
					"id": "popup_content",
					"label": "t:sections.feature-box.blocks.popup.name"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.feature-box.name",
			"blocks": [
				{
					"type": "item"
				},
				{
					"type": "item"
				},
				{
					"type": "item"
				},
				{
					"type": "item"
				}
			]
		}
	]
}
{% endschema %}
