{%- liquid
	assign section_id       = '#shopify-section-' | append: section.id
	assign animation        = settings.section_animation
	assign heading          = section.settings.heading_text
	assign heading_size     = section.settings.heading_size
	assign text             = section.settings.text
	assign alignment        = section.settings.text_align
	assign alignment_mobile = section.settings.mobile_text_align
	assign height           = section.settings.height

	case height
		when 'small'
			assign height_value = '400px'
		when 'medium'
			assign height_value = '580px'
		when 'large'
			assign height_value = '800px'
		when 'fit-screen'
			assign height_value = 'calc(100svh)'
	endcase
-%}

<style>
	{{ section_id }} .section-wrapper {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;

		{%- if section.settings.background_image != blank -%}
			background-image: url({{ section.settings.background_image | image_url: width: 1920 }});
			background-repeat: no-repeat;
			background-size: cover;
			background-position: top center;

			{%- if section.settings.background_image != blank -%}
				{%- if height != 'auto' -%}
					height: {{ height_value }};
				{%- endif -%}
			{%- endif -%}
		{%- endif -%}
	}

	{%- if section.settings.background_image != blank -%}
		{%- assign overlay_opacity = section.settings.overlay_opacity -%}
		{{ section_id }} .section-wrapper:before {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			background: linear-gradient(to bottom,{%- if overlay_opacity == 100 -%}rgb(0,0,0){%- else -%}rgba(0,0,0,0.{{ overlay_opacity }}){%- endif -%},{%- if overlay_opacity == 100 -%}rgb(0,0,0){%- else -%}rgba(0,0,0,0.{{ overlay_opacity }}){%- endif -%});
		}
	{%- endif -%}

	@media (min-width: 992px) {
		{{ section_id }} .section-wrapper {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
</style>

<div class="section-wrapper color-{{ section.settings.color_scheme }} height-{{ height }}">
	<div class="container">
		<div class="email-signup-wrapper flex-justify-{{ section.settings.position_y }}">
			<div class="email-signup-content flex-align-{{ section.settings.position_x }}">
				<div class="email-signup-content-inner text-{{ alignment }} text-{{ alignment_mobile }}-mobile">
					{%- if heading != blank -%}
						<div class="heading rte {{ heading_size }}">{{- heading -}}</div>
					{%- endif -%}

					{%- if text != blank -%}
						<div class="description rte">{{- text -}}</div>
					{%- endif -%}

					<div class="email-signup-form flex-justify-{% if alignment == 'left' %}start{% elsif  alignment == 'right' %}end{% else %}center{% endif %}">
						{%- form 'customer', id: nil -%}
							<input type="hidden" name="contact[tags]" value="newsletter">

							<div class="field-wrapper{% if animation %} scroll-trigger{% endif %} border-large">
								<label for="{{ section.id }}-field" class="sr-only">{{ 'templates.form.email' | t }}</label>
								<input class="field-input"
									id="{{ section.id }}-field"
									type="email"
									name="contact[email]"
									value="{{ form.email }}"
									aria-required="true"
									autocorrect="off"
									autocapitalize="off"
									autocomplete="email"
									{% if form.errors %}
										autofocus
										aria-invalid="true"
										aria-describedby="{{ section.id }}-contact-error"
									{% elsif form.posted_successfully? %}
										aria-describedby="{{ section.id }}-contact-success"
									{% endif %}
									placeholder="{{ 'templates.form.email' | t }}"
									pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$"
									required >

								<button type="submit" class="button signup-button" class="primary-button add-to-cart-button" title ="{{ 'general.unity.prev' | t }}-email" aria-label="{{ 'general.unity.prev' | t }}-email" id="{{ 'general.unity.prev' | t }}-email" aria-labelledby="{{ 'general.unity.prev' | t }}-email">
									{%- render 'icon', code: 'envelope' -%}
								</button>
							</div>

							{%- if form.errors -%}
								<small class="message error-message" id="{{ section.id }}-contact-error">
									{%- liquid
										render 'icon', code: 'error'

										echo form.errors.translated_fields['email'] | capitalize
										echo form.errors.messages['email']
									-%}
								</small>
							{%- endif -%}

							{%- if form.posted_successfully? -%}
								<h3 class="message success-message" id="{{ section.id }}-contact-success" tabindex="-1" autofocus>
									{%- liquid
										render 'icon', code: 'success'
										echo 'newsletter.success' | t
									-%}
								</h3>
							{%- endif -%}



							{% comment %} Submit {% endcomment %}
							{%- if section.settings.button_label != blank -%}
								<div class="field-button">
									<button type="submit" class="button primary-button medium-button">
										{{- section.settings.button_label -}}
									</button>
								</div>
							{%- endif -%}
						{%- endform -%}
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.email-signup.name",
	"tag": "section",
	"class": "email-signup-section",
	"limit": 1,
	"disabled_on": {
		"groups": ["header"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "t:general.image.label"
		},
		{
			"type": "select",
			"id": "height",
			"default": "medium",
			"options": [
				{
					"value": "small",
					"label": "t:sections.slider.settings.height.option_2.label"
				},
				{
					"value": "medium",
					"label": "t:sections.slider.settings.height.option_3.label"
				},
				{
					"value": "large",
					"label": "t:sections.slider.settings.height.option_4.label"
				},
				{
					"value": "fit-screen",
					"label": "t:sections.slider.settings.height.option_5.label"
				}
			],
			"label": "t:general.dimensions.height.label"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 40,
			"unit": "%",
			"label": "t:sections.slider.blocks.slider.settings.overlay_opacity.label",
			"info": "t:sections.slider.blocks.slider.settings.overlay_opacity.info"
		},
		{
			"type": "header",
			"content": "t:sections.email-signup.settings.header_content.content"
		},
		{
			"type": "select",
			"id": "position_x",
			"options": [
				{
					"value": "start",
					"label": "t:general.layout.horizontal.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.horizontal.option_2.label"
				},
				{
					"value": "end",
					"label": "t:general.layout.horizontal.option_3.label"
				}
			],
			"default": "center",
			"label": "t:general.layout.horizontal.label",
			"info": "t:general.layout.alignment.mobile_center.label"
		},
		{
			"type": "select",
			"id": "position_y",
			"options": [
				{
					"value": "start",
					"label": "t:general.layout.vertical.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.vertical.option_2.label"
				},
				{
					"value": "end",
					"label": "t:general.layout.vertical.option_3.label"
				}
			],
			"default": "center",
			"label": "t:general.layout.vertical.label",
			"info": "t:general.layout.alignment.mobile_center.label"
		},
		{
			"type": "select",
			"id": "text_align",
			"options": [
				{
					"value": "left",
					"label": "t:general.layout.alignment.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.alignment.option_2.label"
				},
				{
					"value": "right",
					"label": "t:general.layout.alignment.option_3.label"
				}
			],
			"default": "center",
			"label": "t:general.layout.alignment.label"
		},
		{
			"type": "select",
			"id": "mobile_text_align",
			"options": [
				{
					"value": "left",
					"label": "t:general.layout.mobile_alignment.option_1.label"
				},
				{
					"value": "center",
					"label": "t:general.layout.mobile_alignment.option_2.label"
				},
				{
					"value": "right",
					"label": "t:general.layout.mobile_alignment.option_3.label"
				}
			],
			"default": "center",
			"label": "t:general.layout.mobile_alignment.label"
		},
		{
			"type": "richtext",
			"id": "heading_text",
			"default": "<p>Subscribe to our emails</p>",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h3",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h2",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h3",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "richtext",
			"id": "text",
			"default": "<p>Be the first to know about new collections and exclusive offers.</p>",
			"label": "t:general.typography.description.label"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "Subscrible",
			"label": "t:general.typography.button_label.label"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 60,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 60,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.email-signup.name"
		}
	]
}
{% endschema %}
