{%- liquid
	assign section_id   = '#shopify-section-' | append: section.id
	assign animation    = settings.section_animation
	assign full         = section.settings.full
	assign sub_heading  = section.settings.sub_heading
	assign heading      = section.settings.heading
	assign columns      = section.settings.columns
	assign heading_size = section.settings.heading_size
	assign total        = section.settings.total
-%}

<style>
	{{ section_id }} .featured-collection-tab {
		padding-top: {{ section.settings.padding_top_mobile }}px;
		padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
	}

	{{ section_id }} .unity-slider {
		--slide-size: 93%;
	}

	@media (min-width: 992px) {
		{{ section_id }} .featured-collection-tab {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}

		{{ section_id }} .unity-slider {
			--slide-size: calc( 100% / {{ columns  }});
			--slide-spacing: 0.8rem;
		}
	}
</style>

{%- if customer -%}
{%- if section.blocks.size > 0 -%}
	<div class="featured-collection-tab color-{{ section.settings.color_scheme }}">
		<div class="{% if full %}stretch-section stretch-padding{% else %} container{% endif %}">
			<div class="featured-collection-tabs tabs">
				{%- for block in section.blocks -%}
					{%- liquid
						assign class_tab = section.blocks.size

						if class_tab == 1
							assign class_tab = 'single'
						endif
					-%}
				{%- endfor -%}

				{%- if sub_heading != blank -%}
					<div class="sub-heading">
						{{ sub_heading }}
					</div>
				{%- endif -%}

				{%- if heading != blank -%}
					<div class="heading" style="color: black; font-size: 30px; line-height: 1.2; ">
						{{ heading }}
					</div>
					{% comment %} <div class="heading {{ heading_size }}">
						{{ heading }}
					</div> {% endcomment %}
				{%- endif -%}

				<div class="tabs-head tabs-{% echo class_tab %}">
					<div class="tabs-head-desktop{% if animation %} scroll-trigger{% endif %}">
						{%- for block in section.blocks -%}
							<button class="tab-head{% if forloop.index == 1 %} active{% endif %}" data-index="{{ forloop.index }}" {{ block.shopify_attributes }}{% if request.design_mode %} data-id="{{ block.id }}"{% endif %} style="border: .1rem solid oklch(87.2% .01 258.338); font-weight: 400; ">
								{%- liquid
									assign collection = block.settings.collection

									if block.settings.name != blank
										echo block.settings.name | escape
									elsif collection != blank
										echo collection.title
									else
										echo 'general.text.tab' | t | append: ' ' | append: forloop.index
									endif
								-%}
							</button>
						{%- endfor -%}
					</div>

					<div class="toggle-dropdown tabs-head-mobile tab-{% echo class_tab %}">
						<div class="dropdown-summary">
							<span class="summary-info">
								{%- liquid
									for block in section.blocks limit: 1
										assign collection = block.settings.collection

										if block.settings.name != blank
											echo block.settings.name | escape
										elsif collection != blank
											echo collection.title
										else
											echo 'general.text.tab' | t | append: ' ' | append: forloop.index
										endif
									endfor
								-%}
							</span>

							{%- render 'icon', code: 'chevron-down' -%}
						</div>

						<div class="dropdown-content" role="list">
							<div class="dropdown-content-inner">
								<header class="dropdown-content-header">
									<span class="dropdown-content-title">
										{%- liquid
											for block in section.blocks limit: 1
												assign collection = block.settings.collection

												if block.settings.name != blank
													echo block.settings.name | escape
												elsif collection != blank
													echo collection.title
												else
													echo 'general.text.tab' | t | append: ' ' | append: forloop.index
												endif
											endfor
										-%}
									</span>

									{%- render 'icon', code: 'chevron-down' -%}
								</header>

								<ul class="content" role="list">
									{%- for block in section.blocks -%}
										{%- liquid
											assign collection = block.settings.collection

											if block.settings.name != blank
												assign name = block.settings.name | escape
											elsif collection != blank
												assign name = collection.title
											else
												assign name = 'general.text.tab' | t | append: ' ' | append: forloop.index
											endif
										-%}

										<li class="dropdown-item" data-value="{{ name }}" data-index="{{ forloop.index }}">{{- name -}}</li>
									{%- endfor -%}
								</ul>
							</div>
						</div>
					</div>
				</div>

				<div class="tabs-content animation-{{ section.settings.animation }}">
					{%- for block in section.blocks -%}
						{%- assign collection = block.settings.collection -%}
							<div class="product-main-slide{% if forloop.index == 1 %} active{% endif %}">
								<unity-slider class="unity-slider">
									<template data-options>
										{
											{%- if section.settings.loop -%}
												"loop": true,
											{%- endif -%}

											{%- if section.settings.autoplay -%}
												"_autoplay": {{ section.settings.delay | times: 1000 }},
											{%- endif -%}

											"align": "start",
											"_autoheight": true,
											"_fade": false,
											"speed": 10,
											"_prevBtn": "{{ section_id }} .unity-button-prev",
											"_nextBtn": "{{ section_id }} .unity-button-next",
											"_dotsNode": "{{ section_id }} .unity-dots"
										}
									</template>

									<div class="unity-arrows {% if forloop.index == 1 %} active{% endif %}" data-index="{{ forloop.index }}" style="display: none;">
										<button class="unity-button unity-button-prev" title ="{{ 'general.unity.prev' | t }}-feature-clt" aria-label="{{ 'general.unity.prev' | t }}-feature-clt" id="{{ 'general.unity.prev' | t }}-feature-clt" aria-labelledby="{{ 'general.unity.prev' | t }}-feature-clt" disabled>
											{%- render 'icon', code: 'chevron-left' -%}
										</button>

										<button class="unity-button unity-button-next" title ="{{ 'general.unity.next' | t }}-feature-clt" aria-label="{{ 'general.unity.next' | t }}-feature-clt" id="{{ 'general.unity.next' | t }}-feature-clt" aria-labelledby="{{ 'general.unity.next' | t }}-feature-clt" disabled>
											{%- render 'icon', code: 'chevron-right' -%}
										</button>
									</div>

									<div class="unity-slider-viewport">
										<div class="unity-slider-container tab-content{% if forloop.index == 1 %} active{% endif %}" data-id="{{ block.id }}" data-index="{{ forloop.index }}">
											{%- for product in collection.products limit: total -%}
												<div class="unity-slide">
													{%- render 'product-card', product: product -%}
												</div>
											{%- else -%}
												{%- for i in (1..total) -%}
													<div class="unity-slide">
														{%- render 'product-card-placeholder', index: forloop.index -%}
													</div>
												{%- endfor -%}
											{%- endfor -%}
										</div>
									</div>

									{%- if section.settings.dots -%}
									<div class="align-dots-center">
										<div class="unity-dots{% if forloop.index == 1 %} active{% endif %}" data-index="{{ forloop.index }}">
										</div>
									</div>
									{%- endif -%}
								</unity-slider>
							</div>
					{%- endfor -%}
				</div>
			</div>
		</div>
	</div>
{%- endif -%}
{%- else -%}
  {%- liquid
    assign global_prod = all_products[section.settings.global_product]
    assign american_prod = all_products[section.settings.american_product]
  -%}
  <style>
    .comparison-section {
      padding: 60px 0;
      background: #ffffff;
      text-align: center;
    }
    .comparison-header {
      max-width: 800px;
      margin: 0 auto 50px;
      padding: 0 20px;
    }
    .comparison-header h2 {
      font-size: 32px;
      font-weight: 600;
      margin-bottom: 15px;
      color: #000;
      letter-spacing: -0.5px;
    }
    .comparison-header p {
      color: #666;
      line-height: 1.6;
      font-size: 16px;
    }
    .comparison-grid {
      display: flex;
      justify-content: center;
      gap: 30px;
      max-width: 1140px;
      margin: 0 auto;
      padding: 0 20px;
    }
    .comparison-card {
      flex: 1;
      border-radius: 16px;
      padding: 35px;
      text-align: left;
      position: relative;
      display: flex;
      flex-direction: column;
      box-shadow: 0 10px 30px rgba(0,0,0,0.04);
      border: 1px solid #f0f0f0;
    }
    .comparison-card.premium {
      background: #1a4d2e;
      color: #fff;
      border: none;
    }
    .card-header-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }
    .card-title {
      font-size: 20px;
      font-weight: 600;
      margin: 0;
	  color: #0A0A0A;
    }
    .card-badge {
      font-size: 11px;
      padding: 6px 14px;
      border-radius: 30px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }
    .standard .card-badge {
      background: #f4f6f8;
      color: #5c5f62;
      border: 1px solid #dfe3e8;
    }
    .premium .card-badge {
      background: #e9bc47;
      color: #000;
    }
    .card-subtitle {
      font-size: 13px;
      opacity: 0.8;
      margin-bottom: 25px;
    }
    .card-image-box {
      background: #f9fafb;
      border-radius: 12px;
      height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
      overflow: hidden;
    }
    .premium .card-image-box {
      background: rgba(255,255,255,0.06);
    }
    .card-image-box img {
      max-height: 80%;
      object-fit: contain;
    }
    .comparison-table {
      margin-bottom: 30px;
      flex-grow: 1;
    }
    .comparison-item {
      display: flex;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid #f0f0f0;
      font-size: 13px;
    }
    .premium .comparison-item {
      border-bottom-color: rgba(255,255,255,0.1);
    }
    .item-label {
      opacity: 0.7;
    }
    .item-value {
      font-weight: 500;
    }
    .card-action-btn {
      display: block;
      width: 100%;
      padding: 14px;
      border-radius: 8px;
      text-align: center;
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.2s;
    }
    .standard .card-action-btn {
      background: #111827;
      color: #fff;
    }
    .premium .card-action-btn {
      background: #fff;
      color: #1a4d2e;
    }
    .grade-tip {
      max-width: 1140px;
      margin: 40px auto 0;
      background: #f9fafb;
      padding: 20px 30px;
      border-radius: 12px;
      font-size: 13px;
      color: #5c5f62;
      line-height: 1.6;
    }

    @media (max-width: 900px) {
      .comparison-grid {
        flex-direction: column;
        gap: 20px;
      }
    }
  </style>

  <div class="comparison-section">
    <div class="container">
      <div class="comparison-header">
        <h2>{{ section.settings.guest_heading }}</h2>
        <p>{{ section.settings.guest_subtext }}</p>
      </div>

      <div class="comparison-grid">
        <!-- GLOBAL -->
        <div class="comparison-card standard">
          <div class="card-header-top">
            <h3 class="card-title">{{ section.settings.global_title }}</h3>
            <span class="card-badge">{{ section.settings.global_badge }}</span>
          </div>
          <p class="card-subtitle" style="color: #4A5565;">{{ section.settings.global_subtitle }}</p>
          <div class="card-image-box">
             {% if global_prod and global_prod.featured_image %}
               <img src="{{ global_prod.featured_image | img_url: '400x' }}" alt="{{ global_prod.title }}" loading="lazy">
             {% else %}
               <img src="https://cdn.shopify.com/s/files/1/0805/0013/7979/files/glp-1_international.png?v=1710925000" alt="Global" loading="lazy">
             {% endif %}
          </div>
          <div class="comparison-table">
            <div class="comparison-item"><span class="item-label">Origin</span><span class="item-value">{{ section.settings.global_origin }}</span></div>
            <div class="comparison-item"><span class="item-label">Purity Level</span><span class="item-value">{{ section.settings.global_purity }}</span></div>
            <div class="comparison-item"><span class="item-label">Testing Standards</span><span class="item-value">{{ section.settings.global_testing }}</span></div>
            <div class="comparison-item"><span class="item-label">Lead Time</span><span class="item-value">{{ section.settings.global_lead_time }}</span></div>
            <div class="comparison-item"><span class="item-label">Price Point</span><span class="item-value">{{ section.settings.global_price }}</span></div>
            <div class="comparison-item"><span class="item-label">COA Available</span><span class="item-value">{{ section.settings.global_coa }}</span></div>
          </div>
          <a href="/pages/sign-up" class="card-action-btn">Browse Global Collection</a>
        </div>

        <!-- AMERICAN -->
        <div class="comparison-card premium">
          <div class="card-header-top">
            <h3 class="card-title" style="color: #fff;">{{ section.settings.american_title }}</h3>
            <span class="card-badge">⭐ {{ section.settings.american_badge }}</span>
          </div>
          <p class="card-subtitle" style="color: #E5E7EB;">{{ section.settings.american_subtitle }}</p>
          <div class="card-image-box">
             {% if american_prod and american_prod.featured_image %}
               <img src="{{ american_prod.featured_image | img_url: '400x' }}" alt="{{ american_prod.title }}" loading="lazy">
             {% else %}
               <img src="https://cdn.shopify.com/s/files/1/0805/0013/7979/files/glp-1_usa.png?v=1710925000" alt="USA" loading="lazy">
             {% endif %}
          </div>
          <div class="comparison-table">
            <div class="comparison-item"><span class="item-label">Origin</span><span class="item-value">{{ section.settings.american_origin }}</span></div>
            <div class="comparison-item"><span class="item-label">Purity Level</span><span class="item-value">{{ section.settings.american_purity }}</span></div>
            <div class="comparison-item"><span class="item-label">Testing Standards</span><span class="item-value">{{ section.settings.american_testing }}</span></div>
            <div class="comparison-item"><span class="item-label">Lead Time</span><span class="item-value">{{ section.settings.american_lead_time }}</span></div>
            <div class="comparison-item"><span class="item-label">Price Point</span><span class="item-value">{{ section.settings.american_price }}</span></div>
            <div class="comparison-item"><span class="item-label">COA Available</span><span class="item-value" style="color: #D4AF37;">{{ section.settings.american_coa }}</span></div>
          </div>
          <a href="/pages/sign-up" class="card-action-btn">Browse US Collection</a>
        </div>
      </div>

      <div class="grade-tip">
        {{ section.settings.guest_tip }}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
	"name": "t:sections.featured-collection.name",
	"tag": "section",
	"class": "featured-collection-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "checkbox",
			"id": "full",
			"default": false,
			"label": "t:general.layout.full.label"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "t:sections.featured-collection-tabs.settings.header_head.content"
		},
		{
			"type": "text",
			"id": "sub_heading",
			"default": "( Browser our products )",
			"label": "t:general.typography.sub_heading.label"
		},
		{
			"type": "text",
			"id": "heading",
			"default": "Most popular",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h4",
					"label": "t:general.typography.heading_size.option_1.label"
				},
				{
					"value": "h3",
					"label": "t:general.typography.heading_size.option_2.label"
				},
				{
					"value": "h2",
					"label": "t:general.typography.heading_size.option_3.label"
				}
			],
			"default": "h3",
			"label": "t:general.typography.heading_size.label"
		},
		{
			"type": "header",
			"content": "t:sections.featured-collection-tabs.settings.header_content.content"
		},
		{
			"type": "range",
			"id": "columns",
			"min": 2,
			"max": 5,
			"step": 1,
			"default": 4,
			"label": "t:general.slider.column.label"
		},
		{
			"type": "range",
			"min": 2,
			"max": 20,
			"step": 1,
			"default": 8,
			"id": "total",
			"label": "t:general.slider.total.label"
		},
		{
			"type": "header",
			"content": "t:general.slider.options.label"
		},
		{
			"type": "checkbox",
			"id": "dots",
			"default": false,
			"label": "t:general.slider.show_dots.label"
		},
		{
			"type": "checkbox",
			"id": "loop",
			"default": false,
			"label": "t:general.slider.loop.label"
		},
		{
			"type": "checkbox",
			"id": "autoplay",
			"default": false,
			"label": "t:general.slider.autoplay.label"
		},
		{
			"type": "range",
			"id": "delay",
			"min": 2,
			"max": 20,
			"step": 1,
			"default": 2,
			"unit": "s",
			"label": "t:general.slider.delay.label"
		},
		{
			"type": "header",
			"content": "t:general.padding.header_padding.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.padding.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 20,
			"unit": "px",
			"label": "t:general.padding.bottom.label"
		},
    {
      "type": "header",
      "content": "Guest View Settings"
    },
    {
      "type": "text",
      "id": "guest_heading",
      "label": "Guest Heading",
      "default": "Choose Your Research Grade"
    },
    {
      "type": "textarea",
      "id": "guest_subtext",
      "label": "Guest Subtext",
      "default": "Not sure which peptide line is right for your research? Compare the key benefits of International Peptides and America-made Peptides to find the perfect solution for your laboratory requirements."
    },
    {
      "type": "richtext",
      "id": "guest_tip",
      "label": "Bottom Help Text",
      "default": "<p><strong>Need help deciding?</strong> Our America-made Peptides line offers superior purity (≥99%), faster shipping (2-3 days vs 7-10 days), and enhanced quality documentation from FDA-registered facilities.</p>"
    },
    {
      "type": "header",
      "content": "Left Card (Global Grade)"
    },
    {
      "type": "text",
      "id": "global_title",
      "label": "Title",
      "default": "Global Clinical Grade"
    },
    {
      "type": "text",
      "id": "global_badge",
      "label": "Badge",
      "default": "Standard Line"
    },
    {
      "type": "text",
      "id": "global_subtitle",
      "label": "Subtitle",
      "default": "Cost-effective research peptides for standard laboratory protocols"
    },
    {
      "type": "product",
      "id": "global_product",
      "label": "Select Product for Image"
    },
    {
      "type": "text",
      "id": "global_origin",
      "label": "Origin Value",
      "default": "International"
    },
    {
      "type": "text",
      "id": "global_purity",
      "label": "Purity Value",
      "default": "≥98% (HPLC)"
    },
    {
      "type": "text",
      "id": "global_testing",
      "label": "Testing Value",
      "default": "ISO Certified"
    },
    {
      "type": "text",
      "id": "global_lead_time",
      "label": "Lead Time Value",
      "default": "7-10 business days"
    },
    {
      "type": "text",
      "id": "global_price",
      "label": "Price Value",
      "default": "Standard pricing"
    },
    {
      "type": "text",
      "id": "global_coa",
      "label": "COA Value",
      "default": "✓ Yes"
    },
    {
      "type": "header",
      "content": "Right Card (American Grade)"
    },
    {
      "type": "text",
      "id": "american_title",
      "label": "Title",
      "default": "American Clinical Grade"
    },
    {
      "type": "text",
      "id": "american_badge",
      "label": "Badge",
      "default": "RECOMMENDED"
    },
    {
      "type": "text",
      "id": "american_subtitle",
      "label": "Subtitle",
      "default": "Premium USA-manufactured peptides with superior quality standards"
    },
    {
      "type": "product",
      "id": "american_product",
      "label": "Select Product for Image"
    },
    {
      "type": "text",
      "id": "american_origin",
      "label": "Origin Value",
      "default": "USA 🇺🇸"
    },
    {
      "type": "text",
      "id": "american_purity",
      "label": "Purity Value",
      "default": "≥99% (HPLC + MS)"
    },
