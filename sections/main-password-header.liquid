{%- liquid
	assign logo_image  = settings.logo_image
	assign transparent_header = section.settings.transparent_header

	### Transparent header logo
	assign overlay_logo = section.settings.overlay_logo
-%}

<header class="header color-{{ section.settings.color_scheme }}{% if transparent_header %} transparent-password{% endif %}{% if section.settings.separator_line %} separator-line{% endif %}">
	<div class="container">
		<div class="password-header">
			<h1 class="h4 logo">
				{%- liquid
					if logo_image != blank or transparent_header and overlay_logo != blank
						if transparent_header and overlay_logo != blank
							echo overlay_logo | image_url: width: 800 | image_tag: width: 60, height: 29, loading: 'lazy', class: 'overlay-logo-image'
						endif

						if logo_image != blank
							echo logo_image | image_url: width: 800 | image_tag: width: 60, height: 29, loading: 'lazy', class: 'site-branding-image'
						endif
					else
						echo shop.name
					endif
				-%}
			</h1>

			<details class="password-modal">
				<summary class="modal-toggle" aria-haspopup="dialog" aria-label="{{ 'general.password_page.modal' | t }}" aria-expanded="false">
					<div class="modal-toggle-open buttton primary-button">
						{% render 'icon', code: 'padlock' %}
						{{- 'general.password_page.login_password_button' | t -}}
					</div>

					<div class="modal-toggle-close" aria-hidden="true">
						{% render 'icon', code: 'close-thin' %}
					</div>
				</summary>

				<div class="modal-content" role="dialog" aria-labelledby="DialogHeading" aria-modal="true">
					<div class="password-modal-content" tabindex="-1">
						<h2 class="password-modal-content-heading" id="DialogHeading">
							{{ 'general.password_page.login_form_heading' | t }}
						</h2>

						{%- form 'storefront_password', class: 'password-form' -%}
							<div class="password-field field{% if form.errors %} password-field--error{% endif %}">
								<input
									type="password"
									name="password"
									id="Password"
									class="field__input"
									autocomplete="current-password"
									{% if form.errors %}
										aria-invalid="true"
										aria-describedby="PasswordLoginForm-password-error"
									{%- endif -%}
									placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}">
								<label class="field__label" for="{{ 'general.password_page.login_form_password_label' | t }}">{{ 'general.password_page.login_form_password_placeholder' | t }}</label>

								{%- if form.errors -%}
									<h2 class="message error-message" tabindex="-1" autofocus id="PasswordLoginForm-password-error">
										<span class="sr-only">{{ 'accessibility.error' | t }}: </span>
										{{- 'general.password_page.login_form_error' | t -}}
									</h2>
								{%- endif -%}
							</div>

							<button name="commit" class="password-button button primary-button">
								{{ 'general.password_page.login_form_submit' | t }}
							</button>
						{%- endform -%}

						<p class="password-footer-text">{{- 'general.password_page.admin_link_html' | t -}}</p>
					</div>
				</div>
			</details>
		</div>
	</div>
</header>

{% schema %}
{
	"name": "t:sections.main-password-header.name",
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "checkbox",
			"id": "transparent_header",
			"default": false,
			"label": "t:sections.main-password-header.settings.transparent_header.label"
		},
		{
			"type": "image_picker",
			"id": "overlay_logo",
			"label": "t:sections.main-password-header.settings.overlay_logo.label"
		},
		{
			"type": "checkbox",
			"id": "separator_line",
			"default": false,
			"label": "t:sections.main-password-header.settings.separator_line.label"
		}
	]
}
{% endschema %}
