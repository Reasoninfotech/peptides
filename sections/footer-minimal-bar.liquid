{%- liquid
  assign section_id = '#shopify-section-' | append: section.id
-%}

<style>
    {{ section_id }} .footer-minimal-bar {
        background-color: {{ section.settings.bg_color | default: '#1a4d2e' }};
        color: {{ section.settings.text_color | default: '#ffffff' }};
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        padding-right: 32px;
        padding-left: 32px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    }

    {{ section_id }} .footer-minimal-container {
        max-width: 100%;
        margin: 0 auto;
        padding: 0 40px;
    }

    {{ section_id }} .footer-top-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 24px;
        flex-wrap: wrap;
        gap: 20px;
    }

    {{ section_id }} .footer-copyright {
        font-size: 14px;
        font-family: poppins;
        letter-spacing: 0.2px;
        opacity: 0.9;
    }

    {{ section_id }} .footer-nav {
        font-family: poppins;
        display: flex;
        gap: 30px;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    {{ section_id }} .footer-nav-item a {
        color: inherit;
        text-decoration: none;
        font-size: 14px;
        transition: opacity 0.2s;
        white-space: nowrap;
    }

    {{ section_id }} .footer-nav-item a:hover {
        opacity: 0.7;
    }

    {{ section_id }} .footer-divider {
        height: 1px;
        background-color: rgba(255, 255, 255, 0.15);
        width: 100%;
        margin-bottom: 24px;
    }

    {{ section_id }} .footer-bottom-row {
        text-align: center;
    }

    {{ section_id }} .footer-disclaimer {
        font-family: poppins;
        font-size: 12px;
        line-height: 1.6;
        opacity: 0.65;
        max-width: 900px;
        margin: 0 auto;
        font-weight: 300;
        letter-spacing: 0.1px;
    }

    @media (max-width: 768px) {
        {{ section_id }} .footer-minimal-container {
            padding: 0 20px;
        }
        
        {{ section_id }} .footer-top-row {
            flex-direction: column;
            text-align: center;
        }

        {{ section_id }} .footer-nav {
            justify-content: center;
            gap: 20px;
        }
    }
</style>

<section class="footer-minimal-bar">
    <div class="footer-minimal-container">
        <!-- Top Row: Copyright and Three Links -->
        <div class="footer-top-row">
            <div class="footer-copyright">
                &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_name | default: shop.name }}. All rights reserved.
            </div>
            
            {%- if section.settings.menu != blank -%}
                <ul class="footer-nav">
                    {%- for link in section.settings.menu.links limit: 3 -%}
                        <li class="footer-nav-item">
                            <a href="{{ link.url }}">{{ link.title }}</a>
                        </li>
                    {%- endfor -%}
                </ul>
            {%- endif -%}
        </div>

        <!-- Horizontal Divider -->
        <div class="footer-divider"></div>

        <!-- Bottom Row: Centered Disclaimer -->
        <div class="footer-bottom-row">
            {%- if section.settings.disclaimer != blank -%}
                <div class="footer-disclaimer">
                    {{ section.settings.disclaimer }}
                </div>
            {%- endif -%}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Minimal Bottom Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a4d2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "copyright_name",
      "label": "Copyright Name",
      "default": "Longevity Labs"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu (First 3 links will show)",
      "default": "footer"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer Text",
      "default": "Research Use Only. Not for human consumption. All peptides are intended exclusively for laboratory investigation."
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container Width",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Minimal Bottom Footer"
    }
  ]
}
{% endschema %}

