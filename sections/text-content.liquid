{%- liquid
	assign section_id = '#shopify-section-' | append: section.id
	assign animation  = settings.section_animation
-%}

<style>
	{{ section_id }} .section-wrapper {
		margin-top: {{ section.settings.margin_top_mobile }}px;
		margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
	}

	{%- for block in section.blocks -%}
		.list-item[data-{{ block.id }}] {
			margin-bottom: {{ block.settings.space | times: 0.6 }}px;
		}
	{%- endfor -%}

	@media (min-width: 992px) {
		{{ section_id }} .text-content {
			max-width: {{ section.settings.width }}%;
		}

		{{ section_id }} .section-wrapper {
			margin-top: {{ section.settings.margin_top }}px;
			margin-bottom: {{ section.settings.margin_bottom }}px;
		}

		{%- for block in section.blocks -%}
			.list-item[data-{{ block.id }}] {
				margin-bottom: {{ block.settings.space }}px;
			}
		{%- endfor -%}
	}
</style>

<div class="section-wrapper color-{{ section.settings.color_scheme }}">
	<div class="container">
		<div class="text-content">
			{%- if section.settings.heading != blank -%}
				<h2 class="heading{% if animation %} scroll-trigger{% endif %}">{{- section.settings.heading -}}</h2>
			{%- endif -%}

			{%- for block in section.blocks -%}
				{%- liquid
					assign layout = block.settings.layout
				-%}

				<div class="list-item {{ layout }}-first{% if animation %} scroll-trigger{% endif %}" data-{{ block.id }} {{ block.shopify_attributes }}>
					{%- if block.settings.image != blank -%}
						<div class="image{% if animation %} scroll-trigger{% endif %}">{{- block.settings.image | image_url: width: 840 | image_tag: width: 370, loading: 'lazy' -}}</div>
					{%- endif -%}

					{%- if block.settings.text != blank -%}
						<div class="content rte">
							{{- block.settings.text -}}
						</div>
					{%- endif -%}
				</div>
			{%- endfor -%}
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.text-content.name",
	"tag": "section",
	"class": "text-content-section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "t:settings_schema.colors.label",
			"default": "scheme-1"
		},
		{
			"type": "range",
			"id": "width",
			"default": 64,
			"min": 30,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "t:general.dimensions.width.label"
		},
		{
			"type": "text",
			"id": "heading",
			"default": "Some heading",
			"label": "t:general.typography.heading.label"
		},
		{
			"type": "header",
			"content": "t:general.margin.header_margin.content"
		},
		{
			"type": "range",
			"id": "margin_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 30,
			"unit": "px",
			"label": "t:general.margin.top.label"
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 80,
			"unit": "px",
			"label": "t:general.margin.bottom.label"
		},
		{
			"type": "paragraph",
			"content": "t:general.margin.paragraph_mobile.content"
		},
		{
			"type": "range",
			"id": "margin_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 10,
			"unit": "px",
			"label": "t:general.margin.top.label"
		},
		{
			"type": "range",
			"id": "margin_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"default": 50,
			"unit": "px",
			"label": "t:general.margin.bottom.label"
		}
	],
	"blocks": [
		{
			"type": "text",
			"name": "t:general.typography.content.label",
			"settings": [
				{
					"type": "select",
					"id": "layout",
					"options": [
						{
							"value": "image",
							"label": "t:sections.image-with-text.settings.layout.option_1.label"
						},
						{
							"value": "text",
							"label": "t:sections.image-with-text.settings.layout.option_2.label"
						}
					],
					"default": "image",
					"label": "t:sections.image-with-text.settings.layout.label"
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "t:general.image.label"
				},
				{
					"type": "richtext",
					"id": "text",
					"default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>",
					"label": "t:general.typography.text.label"
				},
				{
					"type": "range",
					"id": "space",
					"min": 0,
					"max": 100,
					"step": 1,
					"default": 0,
					"unit": "px",
					"label": "t:general.dimensions.space.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.text-content.presets.name",
			"blocks": [
				{
					"type": "text",
					"settings": {
						"text": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
					}
				},
				{
					"type": "text",
					"settings": {
						"text": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
					}
				},
				{
					"type": "text",
					"settings": {
						"text": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
					}
				}
			]
		}
	]
}
{% endschema %}
