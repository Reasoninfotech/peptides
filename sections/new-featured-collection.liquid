{%- liquid
  assign section_id = '#shopify-section-' | append: section.id
  assign animation = settings.section_animation
  assign full = section.settings.full
  assign sub_heading = section.settings.sub_heading
  assign heading = section.settings.heading
  assign columns = section.settings.columns
  assign heading_size = section.settings.heading_size
  assign total = section.settings.total

  assign tab_count = 0
  for block in section.blocks
    if block.type == 'tab'
      assign tab_count = tab_count | plus: 1
    endif
  endfor
-%}

<style>
  {{ section_id }} .featured-collection-tab {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  {{ section_id }} .unity-slider {
    --slide-size: 93%;
  }

  {{ section_id }} .heading {
    color: black;
    font-size: 30px;
    line-height: 1.2;
  }

  {{ section_id }} .tabs-head .tab-head {
    border: .1rem solid oklch(87.2% .01 258.338);
    font-weight: 400;
  }

  @media (min-width: 992px) {
    {{ section_id }} .featured-collection-tab {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    {{ section_id }} .unity-slider {
      --slide-size: calc(100% / {{ columns }});
      --slide-spacing: 0.8rem;
    }
  }



  {% comment %} new section {% endcomment %}
    .guests-comparison-section {
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
     @media (min-width: 992px) {
        .guests-comparison-section {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        }
        
    }
   .comparison-header {
        margin-bottom: 48px;
    }
    .comparison-header h2 {
        color: #0A0A0A;
        font-weight: 500;
        font-size: 36px;
        line-height: 40px;
        letter-spacing: 0px;
        text-align: center;
        margin: 0;
        padding-bottom: 14px;
    }
    .comparison-header p {
        color: #4A5565;
        font-weight: 400;
        font-size: 16px;
        line-height: 24px;
        letter-spacing: 0px;
        text-align: center;
        max-width: 654px;
        margin: 0 auto;
    }
   .guests-comparison-section .container {
        max-width: 1152px;
        margin: 0 auto;
        width: 100%;
    }
   .guests-comparison-grid {
        display: flex;
        gap: 24px;
    }
     .guests-comparison-grid .guests-cards-grid {
       width:calc(50% - 12px);
    }
    .guests-comparison-grid .guests-cards-grid .guests-cards-grid-block {
        position: relative;
    }
    .guests-comparison-grid .guests-cards-grid-top {
        display: flex;
        gap: 14px;
    }
    .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-top-img {
        width: calc(32% - 7px);
        position: absolute;
        bottom: 0;
        max-width: 166px;
    }
    .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content {
        width: calc(66% - 7px);
        margin: 0 0 0 auto;
        padding-bottom: 20px;
    }
     .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content h3 {
        font-weight: 700;
        font-size: 24px;
        line-height: 32px;
        letter-spacing: 0px;
        margin:0;
    }
    .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content p {
        font-weight: 500;
        font-size: 16px;
        line-height: 32px;
        letter-spacing: 0px;
        margin: 0;
        border: 1px solid #1A4D2E;
        width: fit-content;
        padding: 0 24px;
        height: 40px;
        display: flex;
        align-items: center;
        background: #DDEDED;
        border-radius: 32px;
        color: #1A4D2E;
    }
    .guests-comparison-grid .guests-cards-grid-right .guests-cards-grid-top .guests-cards-grid-content p {
        background: linear-gradient(90deg, #D4AF37 0%, #FFE9A0 52.88%, #D4AF37 100%);
        color: #1A4D2E;
        border: 1px solid #FFFFFF;
    }

    .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content .guests-heading-block {
        display: flex;
        gap: 8px;
        align-items: center;
        margin-bottom: 8px;
    }
    .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content .guests-heading-block .guests-heading-image {
        flex-shrink: 0;
    }
    .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content .guests-heading-block .guests-heading-image img {
        width: 56px;
        height: 56px;
    }
    .guests-comparison-grid .guests-cards-grid-bottom p {
        position: relative;
        padding-left: 40px;
        font-weight: 400;
        font-size: 18px;
        line-height: 20px;
        letter-spacing: 0px;
        color: #000000;
        margin: 0;

    }
    .guests-comparison-grid .guests-cards-grid-right .guests-cards-grid-bottom p {
        color: #FFFFFF;
    }
    .guests-comparison-grid .guests-cards-grid-bottom p span {
        position: absolute;
        left: 0;
    }
    .guests-comparison-grid .guests-cards-grid-bottom {
        width: 100%;
        background: #1A4D2E1A;
        border-radius: 16px;
        padding: 24px 30px 24px 20px;
    }
    .guests-comparison-grid .guests-cards-grid-right .guests-cards-grid-bottom {
        background: #1A4D2E;
    }
    .guests-comparison-grid .guests-cards-grid-bottom .guests-cards-grid-bottom-text {
        width: 66%;
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin: 0 0 0 auto;
    }
    .guests-comparison-grid .guests-cards-grid-left .guests-cards-grid-top-img {
        left: 20px;
        bottom: 34px;
    }
    .guests-comparison-grid .guests-cards-grid-left {
        padding-top: 40px;
    }
    .guests-comparison-grid .guests-cards-grid-right  .guests-cards-grid-top-img {
        left: 17px;
        bottom: 24px;
    }
    .guests-comparison-grid .guests-cards-grid-right {
         padding-top: 40px;
    }
    .guests-comparison-grid .guests-cards-grid .guests-cards-grid-btn {
        margin-top: 24px;
    }
    .guests-comparison-grid .guests-cards-grid .guests-cards-grid-btn .button {
        border: 2px solid #1A4D2E;
        width: 100%;
        display: block;
        padding: 15px 0;
        border-radius: 14px;
        color: #1A4D2E;
        font-weight: 700;
        font-size: 16px;
        line-height: 24px;
        letter-spacing: 0px;
        text-align: center;
    }
    .guests-comparison-grid .guests-cards-grid .guests-cards-grid-btn .button:hover {
        opacity: 0.9;
        transform: scale(0.98);
    }

     .guests-comparison-grid .guests-cards-grid .guests-cards-grid-btn p{
        margin: 0;
        padding-top: 8px;
        font-weight: 500;
        font-size: 12px;
        line-height: 16px;
        letter-spacing: 0px;
        text-align: center;
        color: #828282;
    }
    .guests-comparison-grid .guests-cards-grid-right .guests-cards-grid-btn .button {
        background: linear-gradient(90deg, #D4AF37 0%, #FFE9A0 52.88%, #D4AF37 100%);
        border: 0;
    }
    .guests-comparison-grid  .guests-cards-grid-right .guests-cards-grid-btn p {
        color: #1A4D2E;
    }
    .guests-comparison-section .grade-tip {
        border: 0.56px solid #E5E7EB;
        background: #F9FAFB;
        border-radius: 14px;
        padding: 24px;
        margin-top: 16px;
    }
    .guests-comparison-section .grade-tip p {
        margin: 0;
        font-weight: 400;
        font-size: 14px;
        line-height: 20px;
        letter-spacing: 0px;
        text-align: center;
        color: #4A5565;
    }
    @media (max-width: 1140px) {
        .guests-comparison-grid .guests-cards-grid-bottom p {
            padding-left: 30px;
            font-size: 14px;
        }
        .guests-comparison-grid .guests-cards-grid-bottom .guests-cards-grid-bottom-text {
            width: 63%;
        }
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content h3 {
            font-size: 20px;
            line-height: 26px;
        }
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content .guests-heading-block .guests-heading-image img {
            width: 40px;
            height: 40px;
        }
        .comparison-header {
            margin-bottom: 30px;
        }
    }
    @media (max-width: 991px) {
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-top-img {
            position: unset;
        }
        .guests-comparison-grid .guests-cards-grid-bottom .guests-cards-grid-bottom-text {
            width: 100%;
        }
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content{
             width: 100%;
        }
        .guests-comparison-grid .guests-cards-grid-top {
             flex-direction: column;
        }
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content h3 br,
        .guests-comparison-grid .guests-cards-grid-bottom p br {
            display: none;
        }
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content .guests-heading-block {
            min-height: 52px;
        }
    }
     @media (max-width: 767px) {
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-top-img {
            margin: 0 auto;
            width: 100%;
        }
        .guests-comparison-grid .guests-cards-grid-bottom p {
           font-size: 12px;
           line-height: 20px;
        }
        .guests-comparison-grid .guests-cards-grid-bottom {
            padding: 16px;
        }
        .guests-comparison-grid .guests-cards-grid .guests-cards-grid-btn .button {
            font-size: 10px;
            padding: 8px 0;
        }
        .guests-comparison-grid .guests-cards-grid .guests-cards-grid-btn p {
            padding-top: 4px;
            font-size: 8px;
        }
        .guests-comparison-section .grade-tip p {
            font-size: 12px;
        }
        .guests-comparison-grid {
            gap: 16px;
        }
        .guests-comparison-grid .guests-cards-grid {
            width: calc(50% - 8px);
        }
    }
    @media (max-width: 575px) {
        .comparison-header h2 {
            font-size: 30px;
            line-height: 120%;
            padding-bottom: 16px;
            max-width: 300px;
            margin: 0 auto;
        }
        .comparison-header p {
            font-size: 14px;
            line-height: 120%;
        }
        .guests-comparison-section .grade-tip {
            padding: 18px;
            margin-top: 24px;
        }
        .comparison-header {
            margin-bottom: 24px;
        }
        .guests-comparison-grid .guests-cards-grid-right,
        .guests-comparison-grid .guests-cards-grid-left {
            padding-top: 0;
        }
        .guests-comparison-grid .guests-cards-grid-bottom p span svg {
            width: 16px;
            height: 16px;
        }
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content p {
            font-size: 12px;
            line-height: 13px;
            padding: 0 14px;

        }
        .guests-comparison-grid .guests-cards-grid-bottom p {
            padding-left: 25px;
        }
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content .guests-heading-block .guests-heading-image img {
            width: 30px;
            height: 30px;
        }
        .guests-comparison-grid .guests-cards-grid-top .guests-cards-grid-content h3 {
            font-size: 18px;
            line-height: 120%;
            
        }
        
    }
    @media (max-width: 400px) {
        
    }
   
</style>

{%- if customer.tags contains 'approved' or section.settings.hide_comparison_for_guests -%}
  <div class="guests-comparison-section">
    <div class="container">
      <div class="comparison-header">
        <h2>{{ section.settings.guest_heading }}</h2>
        <p>{{ section.settings.guest_subtext }}</p>
      </div>
      <div class="guests-comparison-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'card_left' %}
              <div class="guests-cards-grid guests-cards-grid-left">
                <div class="guests-cards-grid-block">
                  <div class="guests-cards-grid-top">
                    <div class="guests-cards-grid-top-img">
                      {% if block.settings.image != blank %}
                        <img
                          src="{{ block.settings.image | image_url: width: 600 }}"
                          alt="{{ block.settings.heading }}"
                          width=""
                          height=""
                        >
                      {% endif %}
                    </div>
                    <div class="guests-cards-grid-content">
                      <div class="guests-heading-block">
                        {% if block.settings.heading_image != blank %}
                          <div class="guests-heading-image">
                            <img
                              src="{{ block.settings.heading_image | image_url: width: 300 }}"
                              alt="{{ block.settings.heading }}"
                            >
                          </div>
                        {% endif %}
                        {% if block.settings.heading != blank %}
                          <h3>{{ block.settings.heading }}</h3>
                        {% endif %}
                      </div>
                      {% if block.settings.text != blank %}
                        <p>{{ block.settings.text }}</p>
                      {% endif %}

                      {% if block.settings.button_label != blank %}
                        <a href="{{ block.settings.button_link }}" class="button">
                          {{ block.settings.button_label }}
                        </a>
                      {% endif %}
                    </div>
                  </div>
                  <div class="guests-cards-grid-bottom">
                    <div class="guests-cards-grid-bottom-text">
                      {% for i in (1..5) %}
                        {% assign text_key = 'guests_cards_bottom_text_' | append: i %}
                        {% if block.settings[text_key] != blank %}
                          <p>
                            <span>
                              <svg
                                width="20"
                                height="20"
                                viewBox="0 0 20 20"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                              >
                                <rect x="0.5" y="0.5" width="19" height="19" rx="9.5" stroke="#1A4D2E"/>
                                <path d="M5.33984 11.1765L8.19699 14.3765L15.3398 6.37646" stroke="#1A4D2E" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </span>

                            {{ block.settings[text_key] }}
                          </p>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                </div>
                <div class="guests-cards-grid-btn">
                  {% if block.settings.bottom_btn_label != blank %}
                    <a href="{{ block.settings.bottom_btn_link }}" class="button">
                      {{ block.settings.bottom_btn_label }}
                    </a>
                  {% endif %}

                  {% if block.settings.bottom_btn_text != blank %}
                    <p>{{ block.settings.bottom_btn_text }}</p>
                  {% endif %}
                </div>
              </div>

            {% when 'card_right' %}
              <div class="guests-cards-grid guests-cards-grid-right">
                <div class="guests-cards-grid-block">
                  <div class="guests-cards-grid-top">
                    <div class="guests-cards-grid-top-img">
                      {% if block.settings.image != blank %}
                        <img
                          src="{{ block.settings.image | image_url: width: 600 }}"
                          alt="{{ block.settings.heading }}"
                          width=""
                          height=""
                        >
                      {% endif %}
                    </div>
                    <div class="guests-cards-grid-content">
                      <div class="guests-heading-block">
                        {% if block.settings.heading_image != blank %}
                          <div class="guests-heading-image">
                            <img
                              src="{{ block.settings.heading_image | image_url: width: 300 }}"
                              alt="{{ block.settings.heading }}"
                            >
                          </div>
                        {% endif %}
                        {% if block.settings.heading != blank %}
                          <h3>{{ block.settings.heading }}</h3>
                        {% endif %}
                      </div>
                      {% if block.settings.text != blank %}
                        <p>{{ block.settings.text }}</p>
                      {% endif %}

                      {% if block.settings.button_label != blank %}
                        <a href="{{ block.settings.button_link }}" class="button">
                          {{ block.settings.button_label }}
                        </a>
                      {% endif %}
                    </div>
                  </div>
                  <div class="guests-cards-grid-bottom">
                    <div class="guests-cards-grid-bottom-text">
                      {% for i in (1..5) %}
                        {% assign text_key = 'guests_cards_bottom_text_' | append: i %}
                        {% if block.settings[text_key] != blank %}
                          <p>
                            <span>
                              <svg
                                width="20"
                                height="20"
                                viewBox="0 0 20 20"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                              >
                                <rect x="0.5" y="0.5" width="19" height="19" rx="9.5" fill="url(#paint0_linear_649_441)"/>
                                <rect x="0.5" y="0.5" width="19" height="19" rx="9.5" stroke="#D4AF37"/>
                                <path d="M5.33984 11.1765L8.19699 14.3765L15.3398 6.37646" stroke="white" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                                <defs>
                                <linearGradient id="paint0_linear_649_441" x1="0" y1="10" x2="20" y2="10" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#D4AF37"/>
                                <stop offset="0.528846" stop-color="#FFE9A0"/>
                                <stop offset="1" stop-color="#D4AF37"/>
                                </linearGradient>
                                </defs>
                              </svg>
                            </span>

                            {{ block.settings[text_key] }}
                          </p>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                </div>
                <div class="guests-cards-grid-btn">
                  {% if block.settings.bottom_btn_label != blank %}
                    <a href="{{ block.settings.bottom_btn_link }}" class="button">
                      {{ block.settings.bottom_btn_label }}
                    </a>
                  {% endif %}

                  {% if block.settings.bottom_btn_text != blank %}
                    <p>{{ block.settings.bottom_btn_text }}</p>
                  {% endif %}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>

      <div class="grade-tip">
        {{ section.settings.guest_tip }}
      </div>
    </div>
  </div>

{%- else -%}
  {%- if tab_count > 0 -%}
    <div id="featured-collection-section" class="featured-collection-tab color-{{ section.settings.color_scheme }}">
      <div class="{% if full %}stretch-section stretch-padding{% else %}container{% endif %}">
        <div class="featured-collection-tabs tabs">
          {%- liquid
            assign class_tab = tab_count

            if class_tab == 1
              assign class_tab = 'single'
            endif
          -%}

          {%- if sub_heading != blank -%}
            <div class="sub-heading">{{ sub_heading }}</div>
          {%- endif -%}

          {%- if heading != blank -%}
            <div class="heading">
              {{ heading }}
            </div>
          {%- endif -%}

          <!-- Tabs Head -->
          <div class="tabs-head tabs-{% echo class_tab %}">
            <!-- Desktop -->
            <div class="tabs-head-desktop{% if animation %} scroll-trigger{% endif %}">
              {%- assign tab_index = 0 -%}

              {%- for block in section.blocks -%}
                {% if block.type == 'tab' %}
                  {%- assign tab_index = tab_index | plus: 1 -%}

                  <button
                    class="tab-head{% if tab_index == 1 %} active{% endif %}"
                    data-index="{{ tab_index }}"
                    {{ block.shopify_attributes }}
                  >
                    {%- liquid
                      assign collection = block.settings.collection

                      if block.settings.name != blank
                        echo block.settings.name | escape
                      elsif collection != blank
                        echo collection.title
                      else
                        echo 'Tab ' | append: tab_index
                      endif
                    -%}
                  </button>
                {% endif %}
              {%- endfor -%}
            </div>

            <!-- Mobile -->
            <div class="toggle-dropdown tabs-head-mobile tab-{% echo class_tab %}">
              <div class="dropdown-summary">
                <span class="summary-info">
                  {%- for block in section.blocks -%}
                    {% if block.type == 'tab' %}
                      {%- liquid
                        assign collection = block.settings.collection

                        if block.settings.name != blank
                          echo block.settings.name | escape
                        elsif collection != blank
                          echo collection.title
                        endif
                      -%}

                      {% break %}
                    {% endif %}
                  {%- endfor -%}
                </span>

                {%- render 'icon', code: 'chevron-down' -%}
              </div>

              <div class="dropdown-content" role="list">
                <div class="dropdown-content-inner">
                  <ul class="content" role="list">
                    {%- assign tab_index = 0 -%}

                    {%- for block in section.blocks -%}
                      {% if block.type == 'tab' %}
                        {%- assign tab_index = tab_index | plus: 1 -%}

                        {%- liquid
                          assign collection = block.settings.collection

                          if block.settings.name != blank
                            assign name = block.settings.name | escape
                          elsif collection != blank
                            assign name = collection.title
                          else
                            assign name = 'Tab ' | append: tab_index
                          endif
                        -%}

                        <li
                          class="dropdown-item"
                          data-value="{{ name }}"
                          data-index="{{ tab_index }}"
                        >
                          {{ name }}
                        </li>
                      {% endif %}
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Tab Content -->
          <div class="tabs-content animation-{{ section.settings.animation }}">
            {%- assign tab_index = 0 -%}

            {%- for block in section.blocks -%}
              {% if block.type == 'tab' %}
                {%- assign tab_index = tab_index | plus: 1 -%}
                {%- assign collection = block.settings.collection -%}

                <div class="product-main-slide{% if tab_index == 1 %} active{% endif %}">
                  <unity-slider class="unity-slider">
                    <div class="unity-slider-viewport">
                      <div
                        class="unity-slider-container tab-content{% if tab_index == 1 %} active{% endif %}"
                        data-id="{{ block.id }}"
                        data-index="{{ tab_index }}"
                      >
                        {%- for product in collection.products limit: total -%}
                          <div class="unity-slide">
                            {%- render 'product-card', product: product -%}
                          </div>

                        {%- else -%}
                          {%- for i in (1..total) -%}
                            <div class="unity-slide">
                              {%- render 'product-card-placeholder', index: forloop.index -%}
                            </div>
                          {%- endfor -%}
                        {%- endfor -%}
                      </div>
                    </div>
                  </unity-slider>
                </div>
              {% endif %}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}
{% schema %}
{
  "name": "Featured Collection Tabs",
  "tag": "section",
  "class": "featured-collection-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },

  "settings": [
    {
      "type": "checkbox",
      "id": "full",
      "default": false,
      "label": "Full Width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },

    {
      "type": "header",
      "content": "Guest Comparison Settings"
    },
    {
      "type": "checkbox",
      "id": "hide_comparison_for_guests",
      "default": false,
      "label": "Show comparison section for guests"
    },
    {
      "type": "text",
      "id": "guest_heading",
      "label": "Guest Heading",
